<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Clear all dynamic script handlers in this folder -->
      <clear />
      <!-- Only allow static files (images, PDFs, documents) to be served -->
      <add name="StaticFile" path="*" verb="*" modules="StaticFileModule,DirectoryListingModule,DefaultDocumentModule" resourceType="Either" requireAccess="Read" />
    </handlers>
  </system.webServer>
</configuration>
