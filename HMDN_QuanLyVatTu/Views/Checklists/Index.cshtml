@{
    ViewBag.Title = "Lập lịch & Thực hiện Checklist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --cl-primary: #3b82f6;
        --cl-primary-dark: #2563eb;
        --cl-primary-light: #eff6ff;
        --cl-success: #10b981;
        --cl-success-dark: #059669;
        --cl-success-light: #ecfdf5;
        --cl-warning: #f59e0b;
        --cl-warning-dark: #d97706;
        --cl-warning-light: #fffbeb;
        --cl-danger: #ef4444;
        --cl-danger-dark: #dc2626;
        --cl-danger-light: #fef2f2;
        --cl-neutral: #64748b;
        --cl-neutral-dark: #475569;
        --cl-neutral-light: #f8fafc;
        --cl-border: #e2e8f0;
        --cl-text: #1e293b;
        --cl-text-muted: #64748b;
        --cl-card-bg: #ffffff;
        --cl-shadow-sm: 0 1px 3px rgba(0,0,0,0.02), 0 8px 12px -4px rgba(0,0,0,0.02);
        --cl-shadow-md: 0 4px 6px -1px rgba(15,23,42,0.03), 0 10px 15px -3px rgba(15,23,42,0.05);
        --cl-shadow-lg: 0 20px 25px -5px rgba(15,23,42,0.08), 0 10px 10px -5px rgba(15,23,42,0.04);
        --cl-tr: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        --cl-radius-sm: 8px;
        --cl-radius-md: 12px;
        --cl-radius-lg: 16px;
    }

    /* Apply Premium Font & Base */
    #app {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: var(--cl-text);
        line-height: 1.5;
    }

    .cl-dashboard {
        display: flex;
        flex-direction: column;
        gap: 28px;
        animation: fadeIn 0.4s ease-out;
    }

    /* ── KPI CARDS (PREMIUM STYLE) ── */
    .cl-kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }
    .cl-kpi-card {
        background: var(--cl-card-bg);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-lg);
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: var(--cl-shadow-sm);
        transition: var(--cl-tr);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }
    .cl-kpi-card::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: transparent;
        transition: var(--cl-tr);
    }
    .cl-kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--cl-shadow-md);
        border-color: rgba(59, 130, 246, 0.2);
    }
    .cl-kpi-card.kpi-blue:hover::after { background: var(--cl-primary); }
    .cl-kpi-card.kpi-amber:hover::after { background: var(--cl-warning); }
    .cl-kpi-card.kpi-green:hover::after { background: var(--cl-success); }
    .cl-kpi-card.kpi-red:hover::after { background: var(--cl-danger); }

    /* ── DEVICE GROUP CARDS (PREMIUM STYLE) ── */
    .cl-group-card-container {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding: 4px 4px 12px 4px;
        margin-bottom: 8px;
        scrollbar-width: thin;
        scrollbar-color: var(--cl-border) transparent;
    }
    .cl-group-card {
        flex: 0 0 210px;
        background: #ffffff;
        border: 1.5px solid var(--cl-border);
        border-radius: 10px;
        padding: 10px 12px;
        display: flex;
        align-items: flex-start;
        gap: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px rgba(15, 23, 42, 0.02);
    }
    .cl-group-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--cl-shadow-md);
        border-color: var(--cl-primary);
    }
    .cl-group-card.active {
        border-color: var(--cl-primary-dark);
        background-color: var(--cl-primary-light);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
    }
    .cl-group-card-icon {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        background-color: var(--cl-primary-light);
        color: var(--cl-primary-dark);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }
    .cl-group-card.active .cl-group-card-icon {
        background-color: #3b82f6;
        color: #ffffff;
    }
    .cl-group-card-info {
        flex: 1;
        min-width: 0;
    }
    .cl-group-card-name {
        font-size: 12px;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.35;
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
    }
    .cl-group-card-sub {
        font-size: 10.5px;
        color: var(--cl-text-muted);
        line-height: 1.3;
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
        margin-top: 2px;
        font-weight: 500;
    }
    .cl-group-card-count {
        font-size: 9.5px;
        font-weight: 700;
        color: var(--cl-primary-dark);
        background: #dbeafe;
        padding: 1.5px 5px;
        border-radius: 99px;
        display: inline-block;
    }
    .cl-group-card.active .cl-group-card-count {
        background: #3b82f6;
        color: #ffffff;
    }

    .cl-kpi-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        transition: var(--cl-tr);
    }
    .cl-kpi-card:hover .cl-kpi-icon {
        transform: scale(1.08);
    }

    /* Beautiful Soft Icon Colors */
    .cl-kpi-icon.blue { background: var(--cl-primary-light); color: var(--cl-primary); }
    .cl-kpi-icon.amber { background: var(--cl-warning-light); color: var(--cl-warning); }
    .cl-kpi-icon.green { background: var(--cl-success-light); color: var(--cl-success); }
    .cl-kpi-icon.red { background: var(--cl-danger-light); color: var(--cl-danger); }
    
    .cl-kpi-val { 
        font-size: 28px; 
        font-weight: 700; 
        color: #0f172a; 
        line-height: 1.1;
        letter-spacing: -0.5px;
    }
    .cl-kpi-label { 
        font-size: 13px; 
        color: var(--cl-text-muted); 
        margin-top: 4px; 
        font-weight: 500;
    }

    /* ── TABS (PREMIUM MINIMALIST) ── */
    .cl-tabs-nav {
        display: flex;
        border-bottom: 2px solid var(--cl-border);
        gap: 32px;
        margin-bottom: 4px;
    }
    .cl-tab-btn {
        padding: 14px 4px;
        font-size: 14.5px;
        font-weight: 600;
        color: var(--cl-text-muted);
        background: none;
        border: none;
        cursor: pointer;
        position: relative;
        transition: var(--cl-tr);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .cl-tab-btn i {
        font-size: 15px;
    }
    .cl-tab-btn:hover {
        color: var(--cl-primary-dark);
    }
    .cl-tab-btn.active {
        color: var(--cl-primary-dark);
    }
    .cl-tab-btn.active::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--cl-primary-dark);
        border-radius: 99px;
    }

    /* ── FILTER BAR ── */
    .cl-filter-bar {
        background: var(--cl-card-bg);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-lg);
        padding: 20px;
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        align-items: flex-end;
        box-shadow: var(--cl-shadow-sm);
    }
    .cl-input-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 150px;
    }
    .cl-input-group.flex-grow {
        flex: 1;
        min-width: 240px;
    }
    .cl-input-group label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--cl-text-muted);
        letter-spacing: 0.8px;
    }
    .cl-input, .cl-select {
        height: 42px;
        padding: 0 14px;
        border: 1px solid var(--cl-border);
        border-radius: 10px;
        font-size: 13.5px;
        outline: none;
        background: #fff;
        color: var(--cl-text);
        transition: var(--cl-tr);
    }
    .cl-input::placeholder {
        color: #94a3b8;
    }
    .cl-input:focus, .cl-select:focus {
        border-color: var(--cl-primary);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        background: #fff;
    }

    /* ── BUTTONS ── */
    .cl-btn {
        height: 42px;
        padding: 0 22px;
        border-radius: 12px;
        font-size: 13.5px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        cursor: pointer;
        border: 1px solid transparent;
        transition: var(--cl-tr);
        user-select: none;
    }
    .cl-btn:active {
        transform: scale(0.96);
    }
    .cl-btn-primary {
        background: linear-gradient(135deg, var(--cl-primary-dark) 0%, var(--cl-primary) 100%);
        color: #fff;
        box-shadow: 0 4px 14px 0 rgba(37, 99, 235, 0.25);
    }
    .cl-btn-primary:hover { 
        background: linear-gradient(135deg, #1d4ed8 0%, var(--cl-primary-dark) 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px 0 rgba(37, 99, 235, 0.35);
    }
    .cl-btn-success {
        background: linear-gradient(135deg, var(--cl-success-dark) 0%, var(--cl-success) 100%);
        color: #fff;
        box-shadow: 0 4px 14px 0 rgba(16, 185, 129, 0.25);
    }
    .cl-btn-success:hover { 
        background: linear-gradient(135deg, #047857 0%, var(--cl-success-dark) 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px 0 rgba(16, 185, 129, 0.35);
    }
    .cl-btn-outline {
        background: #fff;
        border: 1px solid var(--cl-border);
        color: var(--cl-text);
        box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.02);
    }
    .cl-btn-outline:hover { 
        background: #f8fafc; 
        border-color: #cbd5e1;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px 0 rgba(0, 0, 0, 0.05);
        color: var(--cl-primary-dark);
    }

    /* ── TABLES (MODERN VIEW) ── */
    .cl-card-table {
        background: var(--cl-card-bg);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-lg);
        box-shadow: var(--cl-shadow-sm);
        overflow: hidden;
    }
    .cl-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 13.5px;
    }
    .cl-table th {
        background: var(--cl-neutral-light);
        padding: 16px 20px;
        font-weight: 600;
        color: var(--cl-text-muted);
        border-bottom: 1px solid var(--cl-border);
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.5px;
    }
    .cl-table td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--cl-border);
        color: var(--cl-text);
    }
    .cl-table tbody tr:last-child td {
        border-bottom: none;
    }
    .cl-table tbody tr {
        transition: var(--cl-tr);
    }
    .cl-table tbody tr:hover {
        background: #f8fafc;
    }

    /* ── CAPSULE BADGES (PREMIUM DESIGN) ── */
    .cl-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid transparent;
    }
    .cl-badge-pending { 
        background: #fef3c7 !important; 
        color: #78350f !important;
        border-color: #f59e0b !important;
    }
    .cl-badge-overdue { 
        background: #fee2e2 !important; 
        color: #7f1d1d !important;
        border-color: #ef4444 !important;
    }
    .cl-badge-completed { 
        background: #d1fae5 !important; 
        color: #044e37 !important;
        border-color: #10b981 !important;
    }
    .cl-badge-skipped { 
        background: #f3f4f6 !important; 
        color: #374151 !important;
        border-color: #9ca3af !important;
    }
    .cl-badge-pass { 
        background: #d1fae5 !important; 
        color: #044e37 !important;
        border-color: #10b981 !important;
    }
    .cl-badge-fail { 
        background: #fee2e2 !important; 
        color: #7f1d1d !important;
        border-color: #ef4444 !important;
    }
    .cl-badge-partial { 
        background: #fef3c7 !important; 
        color: #78350f !important;
        border-color: #f59e0b !important;
    }

    /* ── MODALS (GLASSMORPHISM & ACCENT SHADOW) ── */
    .cl-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1100;
        padding: 16px;
        animation: fadeIn 0.2s ease-out;
    }
    .cl-modal-card {
        background: #fff;
        border-radius: var(--cl-radius-lg);
        width: 100%;
        max-width: 680px;
        max-height: calc(100vh - 48px);
        box-shadow: var(--cl-shadow-lg);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid var(--cl-border);
        animation: modalScale 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .cl-modal-card.lg { max-width: 820px; }
    
    .cl-modal-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--cl-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--cl-neutral-light);
    }
    .cl-modal-header h3 {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .cl-modal-close {
        background: #e2e8f0;
        border: none;
        font-size: 18px;
        color: var(--cl-text-muted);
        cursor: pointer;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--cl-tr);
    }
    .cl-modal-close:hover { 
        background: #cbd5e1;
        color: #0f172a; 
    }
    
    .cl-modal-body {
        padding: 24px;
        overflow-y: auto;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .cl-modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--cl-border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        background: var(--cl-neutral-light);
    }

    /* ── DEVICE INFO CHIPS ── */
    .cl-device-info-grid {
        background: var(--cl-neutral-light);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-md);
        padding: 16px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
    }
    .cl-info-chip-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: #475569;
        letter-spacing: 0.5px;
    }
    .cl-info-chip-val {
        display: block;
        font-size: 13.5px;
        font-weight: 700;
        color: #0f172a;
        margin-top: 2px;
    }

    /* ── EXECUTION ITEMS (CARDS) ── */
    .cl-exec-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .cl-exec-item {
        background: #ffffff;
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-md);
        padding: 16px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
        transition: var(--cl-tr);
        box-shadow: 0 1px 2px rgba(0,0,0,0.01);
    }
    .cl-exec-item:hover {
        border-color: #cbd5e1;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
    }
    
    @@media(min-width: 640px) {
        .cl-exec-item {
            grid-template-columns: 1fr auto;
            align-items: center;
        }
    }
    .cl-exec-name {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }
    .cl-exec-desc {
        font-size: 12px;
        color: var(--cl-text-muted);
        margin-top: 4px;
    }
    .cl-exec-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    /* Premium Toggle button style */
    .cl-toggle-btn {
        height: 38px;
        padding: 0 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        border: 1.5px solid var(--cl-border);
        background: #fff;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--cl-tr);
        color: var(--cl-text-muted);
        user-select: none;
    }
    .cl-toggle-btn:active {
        transform: scale(0.95);
    }
    .cl-toggle-btn:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: var(--cl-text);
    }
    .cl-toggle-btn.pass.active {
        background: linear-gradient(135deg, var(--cl-success) 0%, var(--cl-success-dark) 100%);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.35);
    }
    .cl-toggle-btn.fail.active {
        background: linear-gradient(135deg, var(--cl-danger) 0%, var(--cl-danger-dark) 100%);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.35);
    }

    /* ── EMPTY STATE DESIGN ── */
    .cl-empty-state {
        padding: 48px 24px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
    }
    .cl-empty-icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--cl-neutral-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        color: var(--cl-text-muted);
        margin-bottom: 4px;
        border: 1px dashed var(--cl-border);
    }
    .cl-empty-title {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }
    .cl-empty-text {
        font-size: 13.5px;
        color: var(--cl-text-muted);
        max-width: 320px;
        margin: 0 auto;
        line-height: 1.5;
    }

    /* ── TECHNOLOGY QR SCANNER ── */
    .cl-tech-qr-panel {
        display: flex;
        flex-direction: column;
        gap: 14px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: var(--cl-radius-md);
        padding: 20px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.01);
    }
    .cl-tech-qr-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }
    .cl-tech-qr-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        font-weight: 700;
        color: #166534;
    }
    .cl-tech-qr-title i {
        font-size: 18px;
    }
    .cl-tech-qr-action-group {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .cl-tech-checkbox-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-size: 13.5px;
        font-weight: 600;
        color: #15803d;
        user-select: none;
        margin: 0;
    }
    .cl-tech-checkbox-label input {
        width: 16px;
        height: 16px;
        accent-color: var(--cl-success);
        cursor: pointer;
    }
    .cl-scanner-camera-simulation {
        background: #090d16;
        border-radius: 12px;
        padding: 20px;
        color: #fff;
        display: flex;
        flex-direction: column;
        gap: 14px;
        animation: fadeIn 0.25s ease;
        border: 1px solid #1e293b;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
    }
    .cl-scanner-status-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .cl-scanner-blink-label {
        font-size: 11px;
        font-weight: 800;
        color: #10b981;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .cl-scanner-blink-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #ef4444;
        animation: pulse-red 1.2s infinite;
    }
    .cl-scanner-viewport {
        height: 100px;
        border: 1px dashed rgba(255,255,255,0.25);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        background: rgba(15, 23, 42, 0.6);
    }
    .cl-scanner-laser-line {
        position: absolute;
        width: 100%;
        height: 2px;
        background: #10b981;
        top: 0;
        animation: laserMove 2.5s infinite linear;
        box-shadow: 0 0 10px #10b981, 0 0 4px #10b981;
    }
    .cl-scanner-laser-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(16,185,129,0.03) 0%, rgba(16,185,129,0) 10%);
        pointer-events: none;
    }
    .cl-scanner-text {
        font-size: 12px;
        color: #94a3b8;
        text-align: center;
        line-height: 1.4;
        z-index: 2;
    }
    .cl-scanner-controls {
        display: flex;
        gap: 10px;
        align-items: center;
    }
    .cl-scanner-input {
        flex: 1;
        height: 38px;
        background: #111827;
        border: 1px solid #1f2937;
        color: #fff;
        font-size: 13px;
        border-radius: 8px;
        padding: 0 12px;
        outline: none;
        transition: var(--cl-tr);
    }
    .cl-scanner-input:focus {
        border-color: var(--cl-success);
        box-shadow: 0 0 0 2px rgba(16,185,129,0.25);
    }

    /* ── ANIMATIONS ── */
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes modalScale { from { opacity: 0; transform: scale(0.96); } to { opacity: 1; transform: scale(1); } }
    @@keyframes laserMove {
        0% { top: 0%; }
        50% { top: 100%; }
        100% { top: 0%; }
    }
    @@keyframes pulse-red {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.5); }
        70% { transform: scale(1.1); box-shadow: 0 0 0 6px rgba(239, 68, 68, 0); }
        100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }

    /* ── PAGINATION ── */
    .cl-pagination {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 20px;
        padding: 0 4px;
    }
    .cl-page-btn {
        height: 36px;
        padding: 0 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid var(--cl-border);
        background: #fff;
        color: var(--cl-text);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--cl-tr);
    }
    .cl-page-btn:hover:not(:disabled) {
        background: var(--cl-primary-light);
        border-color: var(--cl-primary);
        color: var(--cl-primary);
    }
    .cl-page-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .cl-page-info {
        font-size: 13px;
        color: var(--cl-text-muted);
        font-weight: 500;
    }
</style>

<div id="app" class="cl-dashboard" v-cloak>
