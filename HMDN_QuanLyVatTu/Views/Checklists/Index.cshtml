@{
    ViewBag.Title = "Lập lịch & Thực hiện Checklist";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --cl-primary: #3b82f6;
        --cl-primary-dark: #2563eb;
        --cl-primary-light: #eff6ff;
        --cl-success: #10b981;
        --cl-success-dark: #059669;
        --cl-success-light: #ecfdf5;
        --cl-warning: #f59e0b;
        --cl-warning-dark: #d97706;
        --cl-warning-light: #fffbeb;
        --cl-danger: #ef4444;
        --cl-danger-dark: #dc2626;
        --cl-danger-light: #fef2f2;
        --cl-neutral: #64748b;
        --cl-neutral-dark: #475569;
        --cl-neutral-light: #f8fafc;
        --cl-border: #e2e8f0;
        --cl-text: #1e293b;
        --cl-text-muted: #64748b;
        --cl-card-bg: #ffffff;
        --cl-shadow-sm: 0 1px 3px rgba(0,0,0,0.02), 0 8px 12px -4px rgba(0,0,0,0.02);
        --cl-shadow-md: 0 4px 6px -1px rgba(15,23,42,0.03), 0 10px 15px -3px rgba(15,23,42,0.05);
        --cl-shadow-lg: 0 20px 25px -5px rgba(15,23,42,0.08), 0 10px 10px -5px rgba(15,23,42,0.04);
        --cl-tr: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        --cl-radius-sm: 8px;
        --cl-radius-md: 12px;
        --cl-radius-lg: 16px;
    }

    /* Apply Premium Font & Base */
    #app {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: var(--cl-text);
        line-height: 1.5;
    }

    .cl-dashboard {
        display: flex;
        flex-direction: column;
        gap: 28px;
        animation: fadeIn 0.4s ease-out;
    }

    /* ── KPI CARDS (PREMIUM STYLE) ── */
    .cl-kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }
    .cl-kpi-card {
        background: var(--cl-card-bg);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-lg);
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: var(--cl-shadow-sm);
        transition: var(--cl-tr);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }
    .cl-kpi-card::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: transparent;
        transition: var(--cl-tr);
    }
    .cl-kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--cl-shadow-md);
        border-color: rgba(59, 130, 246, 0.2);
    }
    .cl-kpi-card.kpi-blue:hover::after { background: var(--cl-primary); }
    .cl-kpi-card.kpi-amber:hover::after { background: var(--cl-warning); }
    .cl-kpi-card.kpi-green:hover::after { background: var(--cl-success); }
    .cl-kpi-card.kpi-red:hover::after { background: var(--cl-danger); }

    .cl-kpi-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        transition: var(--cl-tr);
    }
    .cl-kpi-card:hover .cl-kpi-icon {
        transform: scale(1.08);
    }

    /* Beautiful Soft Icon Colors */
    .cl-kpi-icon.blue { background: var(--cl-primary-light); color: var(--cl-primary); }
    .cl-kpi-icon.amber { background: var(--cl-warning-light); color: var(--cl-warning); }
    .cl-kpi-icon.green { background: var(--cl-success-light); color: var(--cl-success); }
    .cl-kpi-icon.red { background: var(--cl-danger-light); color: var(--cl-danger); }
    
    .cl-kpi-val { 
        font-size: 28px; 
        font-weight: 700; 
        color: #0f172a; 
        line-height: 1.1;
        letter-spacing: -0.5px;
    }
    .cl-kpi-label { 
        font-size: 13px; 
        color: var(--cl-text-muted); 
        margin-top: 4px; 
        font-weight: 500;
    }

    /* ── TABS (PREMIUM MINIMALIST) ── */
    .cl-tabs-nav {
        display: flex;
        border-bottom: 2px solid var(--cl-border);
        gap: 32px;
        margin-bottom: 4px;
    }
    .cl-tab-btn {
        padding: 14px 4px;
        font-size: 14.5px;
        font-weight: 600;
        color: var(--cl-text-muted);
        background: none;
        border: none;
        cursor: pointer;
        position: relative;
        transition: var(--cl-tr);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .cl-tab-btn i {
        font-size: 15px;
    }
    .cl-tab-btn:hover {
        color: var(--cl-primary-dark);
    }
    .cl-tab-btn.active {
        color: var(--cl-primary-dark);
    }
    .cl-tab-btn.active::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--cl-primary-dark);
        border-radius: 99px;
    }

    /* ── FILTER BAR ── */
    .cl-filter-bar {
        background: var(--cl-card-bg);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-lg);
        padding: 20px;
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        align-items: flex-end;
        box-shadow: var(--cl-shadow-sm);
    }
    .cl-input-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 150px;
    }
    .cl-input-group.flex-grow {
        flex: 1;
        min-width: 240px;
    }
    .cl-input-group label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--cl-text-muted);
        letter-spacing: 0.8px;
    }
    .cl-input, .cl-select {
        height: 42px;
        padding: 0 14px;
        border: 1px solid var(--cl-border);
        border-radius: 10px;
        font-size: 13.5px;
        outline: none;
        background: #fff;
        color: var(--cl-text);
        transition: var(--cl-tr);
    }
    .cl-input::placeholder {
        color: #94a3b8;
    }
    .cl-input:focus, .cl-select:focus {
        border-color: var(--cl-primary);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        background: #fff;
    }

    /* ── BUTTONS ── */
    .cl-btn {
        height: 42px;
        padding: 0 22px;
        border-radius: 12px;
        font-size: 13.5px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        cursor: pointer;
        border: 1px solid transparent;
        transition: var(--cl-tr);
        user-select: none;
    }
    .cl-btn:active {
        transform: scale(0.96);
    }
    .cl-btn-primary {
        background: linear-gradient(135deg, var(--cl-primary-dark) 0%, var(--cl-primary) 100%);
        color: #fff;
        box-shadow: 0 4px 14px 0 rgba(37, 99, 235, 0.25);
    }
    .cl-btn-primary:hover { 
        background: linear-gradient(135deg, #1d4ed8 0%, var(--cl-primary-dark) 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px 0 rgba(37, 99, 235, 0.35);
    }
    .cl-btn-success {
        background: linear-gradient(135deg, var(--cl-success-dark) 0%, var(--cl-success) 100%);
        color: #fff;
        box-shadow: 0 4px 14px 0 rgba(16, 185, 129, 0.25);
    }
    .cl-btn-success:hover { 
        background: linear-gradient(135deg, #047857 0%, var(--cl-success-dark) 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px 0 rgba(16, 185, 129, 0.35);
    }
    .cl-btn-outline {
        background: #fff;
        border: 1px solid var(--cl-border);
        color: var(--cl-text);
        box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.02);
    }
    .cl-btn-outline:hover { 
        background: #f8fafc; 
        border-color: #cbd5e1;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px 0 rgba(0, 0, 0, 0.05);
        color: var(--cl-primary-dark);
    }

    /* ── TABLES (MODERN VIEW) ── */
    .cl-card-table {
        background: var(--cl-card-bg);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-lg);
        box-shadow: var(--cl-shadow-sm);
        overflow: hidden;
    }
    .cl-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-size: 13.5px;
    }
    .cl-table th {
        background: var(--cl-neutral-light);
        padding: 16px 20px;
        font-weight: 600;
        color: var(--cl-text-muted);
        border-bottom: 1px solid var(--cl-border);
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.5px;
    }
    .cl-table td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--cl-border);
        color: var(--cl-text);
    }
    .cl-table tbody tr:last-child td {
        border-bottom: none;
    }
    .cl-table tbody tr {
        transition: var(--cl-tr);
    }
    .cl-table tbody tr:hover {
        background: #f8fafc;
    }

    /* ── CAPSULE BADGES (PREMIUM DESIGN) ── */
    .cl-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid transparent;
    }
    .cl-badge-pending { 
        background: var(--cl-warning-light); 
        color: var(--cl-warning-dark);
        border-color: rgba(245, 158, 11, 0.15);
    }
    .cl-badge-completed { 
        background: var(--cl-success-light); 
        color: var(--cl-success-dark);
        border-color: rgba(16, 185, 129, 0.15);
    }
    .cl-badge-skipped { 
        background: var(--cl-neutral-light); 
        color: var(--cl-neutral-dark);
        border-color: rgba(100, 116, 139, 0.15);
    }
    .cl-badge-pass { 
        background: var(--cl-success-light); 
        color: var(--cl-success-dark);
        border-color: rgba(16, 185, 129, 0.15);
    }
    .cl-badge-fail { 
        background: var(--cl-danger-light); 
        color: var(--cl-danger-dark);
        border-color: rgba(239, 68, 68, 0.15);
    }
    .cl-badge-partial { 
        background: var(--cl-warning-light); 
        color: var(--cl-warning-dark);
        border-color: rgba(245, 158, 11, 0.15);
    }

    /* ── MODALS (GLASSMORPHISM & ACCENT SHADOW) ── */
    .cl-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1100;
        padding: 16px;
        animation: fadeIn 0.2s ease-out;
    }
    .cl-modal-card {
        background: #fff;
        border-radius: var(--cl-radius-lg);
        width: 100%;
        max-width: 680px;
        max-height: calc(100vh - 48px);
        box-shadow: var(--cl-shadow-lg);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid var(--cl-border);
        animation: modalScale 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .cl-modal-card.lg { max-width: 820px; }
    
    .cl-modal-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--cl-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--cl-neutral-light);
    }
    .cl-modal-header h3 {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .cl-modal-close {
        background: #e2e8f0;
        border: none;
        font-size: 18px;
        color: var(--cl-text-muted);
        cursor: pointer;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--cl-tr);
    }
    .cl-modal-close:hover { 
        background: #cbd5e1;
        color: #0f172a; 
    }
    
    .cl-modal-body {
        padding: 24px;
        overflow-y: auto;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .cl-modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--cl-border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        background: var(--cl-neutral-light);
    }

    /* ── DEVICE INFO CHIPS ── */
    .cl-device-info-grid {
        background: var(--cl-neutral-light);
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-md);
        padding: 16px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
    }
    .cl-info-chip-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--cl-text-muted);
        letter-spacing: 0.5px;
    }
    .cl-info-chip-val {
        display: block;
        font-size: 13.5px;
        font-weight: 600;
        color: #1e293b;
        margin-top: 2px;
    }

    /* ── EXECUTION ITEMS (CARDS) ── */
    .cl-exec-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .cl-exec-item {
        background: #ffffff;
        border: 1px solid var(--cl-border);
        border-radius: var(--cl-radius-md);
        padding: 16px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
        transition: var(--cl-tr);
        box-shadow: 0 1px 2px rgba(0,0,0,0.01);
    }
    .cl-exec-item:hover {
        border-color: #cbd5e1;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
    }
    
    @@media(min-width: 640px) {
        .cl-exec-item {
            grid-template-columns: 1fr auto;
            align-items: center;
        }
    }
    .cl-exec-name {
        font-size: 14px;
        font-weight: 600;
        color: #0f172a;
    }
    .cl-exec-desc {
        font-size: 12px;
        color: var(--cl-text-muted);
        margin-top: 4px;
    }
    .cl-exec-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    /* Premium Toggle button style */
    .cl-toggle-btn {
        height: 38px;
        padding: 0 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        border: 1.5px solid var(--cl-border);
        background: #fff;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--cl-tr);
        color: var(--cl-text-muted);
        user-select: none;
    }
    .cl-toggle-btn:active {
        transform: scale(0.95);
    }
    .cl-toggle-btn:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: var(--cl-text);
    }
    .cl-toggle-btn.pass.active {
        background: linear-gradient(135deg, var(--cl-success) 0%, var(--cl-success-dark) 100%);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.35);
    }
    .cl-toggle-btn.fail.active {
        background: linear-gradient(135deg, var(--cl-danger) 0%, var(--cl-danger-dark) 100%);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.35);
    }

    /* ── EMPTY STATE DESIGN ── */
    .cl-empty-state {
        padding: 48px 24px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
    }
    .cl-empty-icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--cl-neutral-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        color: var(--cl-text-muted);
        margin-bottom: 4px;
        border: 1px dashed var(--cl-border);
    }
    .cl-empty-title {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }
    .cl-empty-text {
        font-size: 13.5px;
        color: var(--cl-text-muted);
        max-width: 320px;
        margin: 0 auto;
        line-height: 1.5;
    }

    /* ── TECHNOLOGY QR SCANNER ── */
    .cl-tech-qr-panel {
        display: flex;
        flex-direction: column;
        gap: 14px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: var(--cl-radius-md);
        padding: 20px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.01);
    }
    .cl-tech-qr-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }
    .cl-tech-qr-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        font-weight: 700;
        color: #166534;
    }
    .cl-tech-qr-title i {
        font-size: 18px;
    }
    .cl-tech-qr-action-group {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .cl-tech-checkbox-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-size: 13.5px;
        font-weight: 600;
        color: #15803d;
        user-select: none;
        margin: 0;
    }
    .cl-tech-checkbox-label input {
        width: 16px;
        height: 16px;
        accent-color: var(--cl-success);
        cursor: pointer;
    }
    .cl-scanner-camera-simulation {
        background: #090d16;
        border-radius: 12px;
        padding: 20px;
        color: #fff;
        display: flex;
        flex-direction: column;
        gap: 14px;
        animation: fadeIn 0.25s ease;
        border: 1px solid #1e293b;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.8);
    }
    .cl-scanner-status-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .cl-scanner-blink-label {
        font-size: 11px;
        font-weight: 800;
        color: #10b981;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .cl-scanner-blink-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #ef4444;
        animation: pulse-red 1.2s infinite;
    }
    .cl-scanner-viewport {
        height: 100px;
        border: 1px dashed rgba(255,255,255,0.25);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        background: rgba(15, 23, 42, 0.6);
    }
    .cl-scanner-laser-line {
        position: absolute;
        width: 100%;
        height: 2px;
        background: #10b981;
        top: 0;
        animation: laserMove 2.5s infinite linear;
        box-shadow: 0 0 10px #10b981, 0 0 4px #10b981;
    }
    .cl-scanner-laser-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(16,185,129,0.03) 0%, rgba(16,185,129,0) 10%);
        pointer-events: none;
    }
    .cl-scanner-text {
        font-size: 12px;
        color: #94a3b8;
        text-align: center;
        line-height: 1.4;
        z-index: 2;
    }
    .cl-scanner-controls {
        display: flex;
        gap: 10px;
        align-items: center;
    }
    .cl-scanner-input {
        flex: 1;
        height: 38px;
        background: #111827;
        border: 1px solid #1f2937;
        color: #fff;
        font-size: 13px;
        border-radius: 8px;
        padding: 0 12px;
        outline: none;
        transition: var(--cl-tr);
    }
    .cl-scanner-input:focus {
        border-color: var(--cl-success);
        box-shadow: 0 0 0 2px rgba(16,185,129,0.25);
    }

    /* ── ANIMATIONS ── */
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes modalScale { from { opacity: 0; transform: scale(0.96); } to { opacity: 1; transform: scale(1); } }
    @@keyframes laserMove {
        0% { top: 0%; }
        50% { top: 100%; }
        100% { top: 0%; }
    }
    @@keyframes pulse-red {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.5); }
        70% { transform: scale(1.1); box-shadow: 0 0 0 6px rgba(239, 68, 68, 0); }
        100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }

    /* ── PAGINATION ── */
    .cl-pagination {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 20px;
        padding: 0 4px;
    }
    .cl-page-btn {
        height: 36px;
        padding: 0 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid var(--cl-border);
        background: #fff;
        color: var(--cl-text);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--cl-tr);
    }
    .cl-page-btn:hover:not(:disabled) {
        background: var(--cl-primary-light);
        border-color: var(--cl-primary);
        color: var(--cl-primary);
    }
    .cl-page-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .cl-page-info {
        font-size: 13px;
        color: var(--cl-text-muted);
        font-weight: 500;
    }
</style>

<div id="app" class="cl-dashboard" v-cloak>
    <!-- KPI SUMMARY CARDS -->
    <div class="cl-kpi-grid">
        <div class="cl-kpi-card kpi-blue" @@click="filterByKpi('pending')">
            <div class="cl-kpi-icon blue">
                <i class="fa-solid fa-calendar-days"></i>
            </div>
            <div>
                <div class="cl-kpi-val">${ kpi.pending }</div>
                <div class="cl-kpi-label">Lịch kiểm tra chờ xử lý</div>
            </div>
        </div>
        <div class="cl-kpi-card kpi-amber" @@click="filterByKpi('overdue')">
            <div class="cl-kpi-icon amber">
                <i class="fa-solid fa-clock-rotate-left"></i>
            </div>
            <div>
                <div class="cl-kpi-val">${ kpi.overdue }</div>
                <div class="cl-kpi-label">Schedules quá hạn</div>
            </div>
        </div>
        <div class="cl-kpi-card kpi-green" @@click="filterByKpi('completed')">
            <div class="cl-kpi-icon green">
                <i class="fa-solid fa-square-check"></i>
            </div>
            <div>
                <div class="cl-kpi-val">${ kpi.completed }</div>
                <div class="cl-kpi-label">Hoàn thành tháng này</div>
            </div>
        </div>
        <div class="cl-kpi-card kpi-red">
            <div class="cl-kpi-icon red">
                <i class="fa-solid fa-chart-line"></i>
            </div>
            <div>
                <div class="cl-kpi-val">${ kpi.passRate }%</div>
                <div class="cl-kpi-label">Tỷ lệ đạt chuẩn</div>
            </div>
        </div>
    </div>

    <!-- TABS NAVIGATION -->
    <div class="cl-tabs-nav">
        <button class="cl-tab-btn" :class="{active: activeTab==='schedules'}" @@click="activeTab='schedules'">
            <i class="fa-solid fa-clock"></i> Lịch Trình Kiểm Tra
        </button>
        <button class="cl-tab-btn" :class="{active: activeTab==='logs'}" @@click="activeTab='logs'">
            <i class="fa-solid fa-book"></i> Nhật Ký Hoàn Thành
        </button>
    </div>

    <!-- ===== TAB CONTENT: SCHEDULES ===== -->
    <div v-if="activeTab==='schedules'" style="display:flex; flex-direction:column; gap:20px;">
        <div class="cl-filter-bar">
            <div class="cl-input-group flex-grow">
                <label><i class="fa-solid fa-magnifying-glass mr-1"></i> Tìm kiếm thiết bị</label>
                <input type="text" class="cl-input" placeholder="Nhập tên, serial hoặc mã tài sản..." v-model="schedulesFilter.query" />
            </div>
            <div class="cl-input-group">
                <label><i class="fa-solid fa-circle-info mr-1"></i> Trạng thái</label>
                <select class="cl-select" v-model="schedulesFilter.status">
                    <option value="">Tất cả</option>
                    <option value="pending">Chờ thực hiện</option>
                    <option value="completed">Đã hoàn thành</option>
                </select>
            </div>
            <div class="cl-input-group">
                <label><i class="fa-solid fa-arrows-spin mr-1"></i> Chu kỳ</label>
                <select class="cl-select" v-model="schedulesFilter.cycleType">
                    <option value="">Tất cả</option>
                    <option value="daily">Hàng ngày (Daily)</option>
                    <option value="weekly">Hàng tuần (Weekly)</option>
                    <option value="monthly">Hàng tháng (Monthly)</option>
                    <option value="quarterly">Hàng quý (Quarterly)</option>
                    <option value="yearly">Hàng năm (Yearly)</option>
                </select>
            </div>
            <div class="cl-input-group">
                <label><i class="fa-solid fa-calendar-day mr-1"></i> Từ ngày</label>
                <input type="date" class="cl-input" v-model="schedulesFilter.fromDate" style="width: 145px;" />
            </div>
            <div class="cl-input-group">
                <label><i class="fa-solid fa-calendar-day mr-1"></i> Đến ngày</label>
                <input type="date" class="cl-input" v-model="schedulesFilter.toDate" style="width: 145px;" />
            </div>
            <div style="margin-top:auto; display:flex; gap:10px;">
                <button class="cl-btn cl-btn-primary" @@click="loadSchedules"><i class="fa-solid fa-arrows-rotate"></i> Tải lại</button>
                <button class="cl-btn cl-btn-outline" @@click="resetFilters" title="Xóa tất cả bộ lọc"><i class="fa-solid fa-filter-circle-xmark"></i> Xóa lọc</button>
                <button class="cl-btn cl-btn-outline" @@click="showGenerateModal = true"><i class="fa-solid fa-plus"></i> Sinh lịch mới</button>
            </div>
        </div>

        <div class="cl-card-table">
            <table class="cl-table">
                <thead>
                    <tr>
                        <th>Mã Tài Sản</th>
                        <th>Tên thiết bị</th>
                        <th>Serial</th>
                        <th>Khoa phòng</th>
                        <th>Ngày kiểm tra</th>
                        <th>Chu kỳ</th>
                        <th>Hạn cuối</th>
                        <th>Trạng thái</th>
                        <th style="text-align: center;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="sch in paginatedSchedules" :key="sch.Id">
                        <td><strong class="text-primary">${ sch.AssetCode }</strong></td>
                        <td class="font-weight-bold">${ sch.ItemName }</td>
                        <td><small class="text-muted font-weight-bold">${ sch.SerialNumber || '—' }</small></td>
                        <td>${ sch.DepartmentName || '—' }</td>
                        <td>${ sch.ScheduledDate }</td>
                        <td><span class="font-weight-bold">${ cycleLabel(sch.CycleType) }</span></td>
                        <td><span :class="{'text-danger font-weight-bold': isOverdue(sch.DueDate) && sch.Status==='pending'}">${ sch.DueDate }</span></td>
                        <td>
                            <span class="cl-badge" :class="'cl-badge-' + sch.Status">${ statusLabel(sch.Status) }</span>
                        </td>
                        <td style="text-align: center;">
                            <button class="cl-btn cl-btn-success" style="height:32px; padding:0 12px; font-size:12px; border-radius:8px;" v-if="sch.Status === 'pending'" @@click="openPerformModal(sch)">
                                <i class="fa-solid fa-play"></i> Thực hiện
                            </button>
                            <span v-else style="color:var(--cl-text-muted); font-size:12.5px; font-style:italic; font-weight:600;"><i class="fa-solid fa-circle-check text-successmr-1"></i> Hoàn tất</span>
                        </td>
                    </tr>
                    <tr v-if="filteredSchedules.length === 0">
                        <td colspan="9" style="padding: 0;">
                            <div class="cl-empty-state">
                                <div class="cl-empty-icon-wrap">
                                    <i class="fa-solid fa-calendar-xmark"></i>
                                </div>
                                <h4 class="cl-empty-title">Không tìm thấy lịch trình kiểm tra</h4>
                                <p class="cl-empty-text">Hiện tại không có lịch kiểm tra nào chờ xử lý khớp với bộ lọc của bạn.</p>
                                <button class="cl-btn cl-btn-primary" style="height:36px; font-size:12.5px; margin-top:8px;" @@click="showGenerateModal = true">
                                    <i class="fa-solid fa-calendar-plus"></i> Sinh lịch trình mới
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination UI -->
        <div class="cl-pagination" v-if="schedulesTotalPages > 1">
            <button class="cl-page-btn" :disabled="schedulesPage === 1" @@click="setSchedulesPage(schedulesPage - 1)">
                <i class="fa-solid fa-chevron-left"></i> Trước
            </button>
            <span class="cl-page-info">Trang ${ schedulesPage } / ${ schedulesTotalPages }</span>
            <button class="cl-page-btn" :disabled="schedulesPage === schedulesTotalPages" @@click="setSchedulesPage(schedulesPage + 1)">
                Sau <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- ===== TAB CONTENT: LOGS ===== -->
    <div v-if="activeTab==='logs'" style="display:flex; flex-direction:column; gap:20px;">
        <div class="cl-filter-bar">
            <div class="cl-input-group flex-grow">
                <label><i class="fa-solid fa-magnifying-glass mr-1"></i> Tìm kiếm nhật ký</label>
                <input type="text" class="cl-input" placeholder="Mã tài sản, tên thiết bị..." v-model="logsFilter.query" />
            </div>
            <div class="cl-input-group">
                <label><i class="fa-solid fa-clipboard-question mr-1"></i> Kết quả chung</label>
                <select class="cl-select" v-model="logsFilter.result">
                    <option value="">Tất cả</option>
                    <option value="pass">Đạt chuẩn</option>
                    <option value="fail">Không đạt</option>
                    <option value="partial">Đạt một phần</option>
                </select>
            </div>
            <div style="margin-top:auto; display:flex; gap:10px;">
                <button class="cl-btn cl-btn-primary" @@click="loadLogs"><i class="fa-solid fa-arrows-rotate"></i> Tải lại</button>
            </div>
        </div>

        <div class="cl-card-table">
            <table class="cl-table">
                <thead>
                    <tr>
                        <th>Mã Tài Sản</th>
                        <th>Tên thiết bị</th>
                        <th>Serial</th>
                        <th>Khoa phòng</th>
                        <th>Người kiểm tra</th>
                        <th>Thời gian thực hiện</th>
                        <th>Loại chu kỳ</th>
                        <th>Kết quả</th>
                        <th style="text-align: center;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="log in paginatedLogs" :key="log.Id">
                        <td><strong class="text-primary">${ log.AssetCode }</strong></td>
                        <td class="font-weight-bold">${ log.ItemName }</td>
                        <td><small class="text-muted font-weight-bold">${ log.SerialNumber || '—' }</small></td>
                        <td>${ log.DepartmentName || '—' }</td>
                        <td class="font-weight-bold">${ log.CheckedByName }</td>
                        <td>${ log.CheckedAt }</td>
                        <td><span class="font-weight-bold">${ cycleLabel(log.CycleType) }</span></td>
                        <td>
                            <span class="cl-badge" :class="'cl-badge-' + log.OverallResult">${ resultLabel(log.OverallResult) }</span>
                        </td>
                        <td style="text-align: center;">
                            <button class="cl-btn cl-btn-outline" style="height:32px; padding:0 12px; font-size:12px; border-radius:8px;" @@click="openDetailsModal(log.Id)">
                                <i class="fa-solid fa-eye"></i> Chi tiết
                            </button>
                        </td>
                    </tr>
                    <tr v-if="filteredLogs.length === 0">
                        <td colspan="9" style="padding: 0;">
                            <div class="cl-empty-state">
                                <div class="cl-empty-icon-wrap">
                                    <i class="fa-solid fa-folder-open"></i>
                                </div>
                                <h4 class="cl-empty-title">Chưa có nhật ký kiểm tra</h4>
                                <p class="cl-empty-text">Chưa có nhật ký ghi nhận kết quả kiểm tra nào trong hệ thống.</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination UI -->
        <div class="cl-pagination" v-if="logsTotalPages > 1">
            <button class="cl-page-btn" :disabled="logsPage === 1" @@click="setLogsPage(logsPage - 1)">
                <i class="fa-solid fa-chevron-left"></i> Trước
            </button>
            <span class="cl-page-info">Trang ${ logsPage } / ${ logsTotalPages }</span>
            <button class="cl-page-btn" :disabled="logsPage === logsTotalPages" @@click="setLogsPage(logsPage + 1)">
                Sau <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>


    <!-- ===== MODAL: SINH LỊCH TRÌNH MỚI ===== -->
    <div class="cl-modal-overlay" v-if="showGenerateModal" @@click.self="showGenerateModal=false">
        <div class="cl-modal-card">
            <div class="cl-modal-header">
                <h3>Tạo lịch trình Checklist tự động</h3>
                <button class="cl-modal-close" @@click="showGenerateModal=false">×</button>
            </div>
            <div class="cl-modal-body">
                <p style="font-size:13.5px; color:var(--cl-text-muted); margin-bottom:16px;">
                    Hệ thống sẽ dựa vào thiết lập **Chu kỳ kiểm tra** của từng thiết bị trong kho để tự động tính toán và sinh lịch kiểm tra (Schedules).
                </p>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="cl-input-group">
                        <label>Từ ngày</label>
                        <input type="date" class="cl-input" v-model="generateForm.fromDate" />
                    </div>
                    <div class="cl-input-group">
                        <label>Đến ngày</label>
                        <input type="date" class="cl-input" v-model="generateForm.toDate" />
                    </div>
                </div>
            </div>
            <div class="cl-modal-footer">
                <button class="cl-btn cl-btn-outline" @@click="showGenerateModal=false">Hủy bỏ</button>
                <button class="cl-btn cl-btn-primary" @@click="generateSchedules" :disabled="isGenerating">
                    <span v-if="isGenerating"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang tạo...</span>
                    <span v-else><i class="fa-solid fa-check"></i> Xác nhận tạo</span>
                </button>
            </div>
        </div>
    </div>


    <!-- ===== MODAL: THỰC HIỆN CHECKLIST ===== -->
    <div class="cl-modal-overlay" v-if="showPerformModal" @@click.self="showPerformModal=false">
        <div class="cl-modal-card lg">
            <div class="cl-modal-header">
                <h3>Thực hiện kiểm tra thiết bị</h3>
                <button class="cl-modal-close" @@click="showPerformModal=false">×</button>
            </div>
            <div class="cl-modal-body">
                <!-- Device Prefilled Info -->
                <div class="cl-device-info-grid">
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-file-signature text-primary mr-1"></i> Tên thiết bị</span>
                        <strong class="cl-info-chip-val" style="color: var(--cl-primary-dark); font-size:14.5px;">${ activeSchedule.ItemName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-hashtag text-primary mr-1"></i> Mã Tài Sản</span>
                        <strong class="cl-info-chip-val">${ activeSchedule.AssetCode }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-barcode text-primary mr-1"></i> Số Serial</span>
                        <strong class="cl-info-chip-val">${ activeSchedule.SerialNumber || 'N/A' }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-hospital-user text-primary mr-1"></i> Khoa phòng</span>
                        <strong class="cl-info-chip-val">${ activeSchedule.DepartmentName }</strong>
                    </div>
                </div>

                <!-- Simulated QR Scan Verification -->
                <div class="cl-tech-qr-panel">
                    <div class="cl-tech-qr-header">
                        <div class="cl-tech-qr-title">
                            <i class="fa-solid fa-qrcode"></i>
                            <span>Xác thực quét mã QR Code thiết bị</span>
                        </div>
                        <div class="cl-tech-qr-action-group">
                            <button type="button" class="cl-btn cl-btn-success" style="height:32px; padding:0 12px; font-size:12px; border-radius:8px;" @@click="openQrScanner">
                                <i class="fa-solid fa-camera"></i> Quét mã QR thiết bị
                            </button>
                            <label class="cl-tech-checkbox-label">
                                <input type="checkbox" v-model="performForm.qrScanned" /> Đã xác thực tại vị trí
                            </label>
                        </div>
                    </div>
                    
                    <!-- Simulated Scanner UI Area -->
                    <div v-if="showQrScannerArea" class="cl-scanner-camera-simulation">
                        <div class="cl-scanner-status-line">
                            <span class="cl-scanner-blink-label">
                                <span class="cl-scanner-blink-dot"></span> Active Camera Scanning
                            </span>
                            <button type="button" @@click="showQrScannerArea = false" style="background:none; border:none; color:#94a3b8; font-size:18px; cursor:pointer;">&times;</button>
                        </div>
                        
                        <!-- Scanning viewport with laser -->
                        <div class="cl-scanner-viewport">
                            <div class="cl-scanner-laser-line"></div>
                            <div class="cl-scanner-laser-overlay"></div>
                            <span class="cl-scanner-text">Hướng camera về phía mã QR dán trên thiết bị<br><small style="color:#64748b;">(Giả lập: Nhập mã hoặc chọn lấy mã mẫu ở dưới)</small></span>
                        </div>
                        
                        <div class="cl-scanner-controls">
                            <input type="text" class="cl-scanner-input" placeholder="Quét hoặc nhập mã QR thiết bị..." v-model="scannedQrInput" @@keyup.enter="verifyQrCode" />
                            <button type="button" class="cl-btn cl-btn-outline" style="height:38px; padding:0 12px; font-size:12.5px; border-color:#334155; background:#1e293b; color:#cbd5e1;" @@click="autoFillQrCode" title="Lấy mã QR chuẩn để test">
                                Lấy mã QR mẫu
                            </button>
                            <button type="button" class="cl-btn cl-btn-success" style="height:38px; padding:0 14px; font-size:12.5px;" @@click="verifyQrCode">
                                Xác thực
                            </button>
                        </div>
                        
                        <div style="font-size:11.5px; color:#64748b;">
                            Mã QR chuẩn của thiết bị này: <strong style="color:#38bdf8; font-family: monospace;">${ activeSchedule.QrCode || 'QR-' + activeSchedule.AssetCode }</strong>
                        </div>
                    </div>
                </div>

                <!-- Checklist Definitions List -->
                <div v-if="performLoading" style="padding:48px; text-align:center; color:var(--cl-text-muted);">
                    <i class="fa-solid fa-circle-notch fa-spin" style="font-size:24px;"></i>
                    <p style="margin-top:10px; font-weight:500;">Đang tải danh sách hạng mục kiểm tra...</p>
                </div>
                
                <div v-else-if="checklistItems.length === 0" style="padding:48px; text-align:center; color:var(--cl-text-muted); font-style:italic;">
                    Không tìm thấy hạng mục nào áp dụng cho thiết bị này. Bạn có thể bấm xác nhận hoàn tất.
                </div>

                <div v-else style="display:flex; flex-direction:column; gap:16px;">
                    <div style="display: flex; align-items: center; justify-content: space-between; border-bottom:1px solid var(--cl-border); padding-bottom:8px; margin: 0;">
                        <h4 style="font-size:14px; font-weight:700; color:var(--cl-text); margin: 0;"><i class="fa-solid fa-circle-list mr-1 text-primary"></i> Hạng mục kiểm tra bắt buộc</h4>
                        <button type="button" class="cl-btn cl-btn-outline" style="height: 28px; padding: 0 10px; font-size: 11.5px; border-radius: 6px; border-color: var(--cl-success); color: var(--cl-success-dark);" @@click="bulkSetAllPassed()">
                            <i class="fa-solid fa-check-double"></i> Xác nhận đạt tất cả
                        </button>
                    </div>
                    <div class="cl-exec-grid">
                        <div class="cl-exec-item" v-for="(item, idx) in checklistItems" :key="item.Id">
                            <div>
                                <div class="cl-exec-name">${ item.CheckName } <span style="color:var(--cl-danger)" v-if="item.IsRequired">*</span></div>
                                <div class="cl-exec-desc" v-if="item.Description">${ item.Description }</div>
                            </div>
                            <div class="cl-exec-actions">
                                <button type="button" class="cl-toggle-btn pass" :class="{active: item.isPassed === true}" @@click="setItemPassed(idx, true)">
                                    <i class="fa-solid fa-circle-check"></i> Đạt
                                </button>
                                <button type="button" class="cl-toggle-btn fail" :class="{active: item.isPassed === false}" @@click="setItemPassed(idx, false)">
                                    <i class="fa-solid fa-circle-xmark"></i> Lỗi
                                </button>
                                <input type="text" class="cl-input" placeholder="Ghi chú lỗi nếu có..." style="height:36px; width:180px; font-size:12.5px;" v-model="item.note" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Checklist General Note -->
                <div class="cl-input-group">
                    <label>Ghi chú chung của toàn bộ ca kiểm tra</label>
                    <textarea class="cl-input" style="height:80px; padding:8px 12px; resize:none;" placeholder="Nhập tình trạng tổng quát của thiết bị..." v-model="performForm.note"></textarea>
                </div>
            </div>
            <div class="cl-modal-footer">
                <button class="cl-btn cl-btn-outline" @@click="showPerformModal=false">Hủy bỏ</button>
                <button class="cl-btn cl-btn-success" @@click="submitChecklist" :disabled="isSubmitting">
                    <span v-if="isSubmitting"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang lưu...</span>
                    <span v-else><i class="fa-solid fa-cloud-arrow-up"></i> Hoàn thành & Lưu kết quả</span>
                </button>
            </div>
        </div>
    </div>


    <!-- ===== MODAL: CHI TIẾT NHẬT KÝ ===== -->
    <div class="cl-modal-overlay" v-if="showDetailsModal" @@click.self="showDetailsModal=false">
        <div class="cl-modal-card lg" v-if="logDetails">
            <div class="cl-modal-header">
                <h3>Chi tiết nhật ký kiểm tra thiết bị</h3>
                <button class="cl-modal-close" @@click="showDetailsModal=false">×</button>
            </div>
            <div class="cl-modal-body">
                <!-- General Log Info -->
                <div class="cl-device-info-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-file-signature text-primary mr-1"></i> Thiết bị</span>
                        <strong class="cl-info-chip-val" style="color: var(--cl-primary-dark); font-size: 14px;">${ logDetails.ItemName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-barcode text-primary mr-1"></i> Mã Tài Sản / Serial</span>
                        <strong class="cl-info-chip-val">${ logDetails.AssetCode } / ${ logDetails.SerialNumber || '—' }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-hospital-user text-primary mr-1"></i> Khoa phòng thực hiện</span>
                        <strong class="cl-info-chip-val">${ logDetails.DepartmentName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-user-gear text-primary mr-1"></i> Kỹ thuật viên</span>
                        <strong class="cl-info-chip-val">${ logDetails.CheckedByName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-clock text-primary mr-1"></i> Thời gian kiểm tra</span>
                        <strong class="cl-info-chip-val">${ logDetails.CheckedAt }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-arrows-spin text-primary mr-1"></i> Chu kỳ kiểm tra</span>
                        <strong class="cl-info-chip-val">${ cycleLabel(logDetails.CycleType) }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-square-poll-vertical text-primary mr-1"></i> Kết quả chung</span>
                        <strong class="cl-info-chip-val">
                            <span class="cl-badge" :class="'cl-badge-' + logDetails.OverallResult">${ resultLabel(logDetails.OverallResult) }</span>
                        </strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-qrcode text-primary mr-1"></i> Xác thực mã QR</span>
                        <strong class="cl-info-chip-val">
                            <span style="color:var(--cl-success)" v-if="logDetails.QrScannedAt"><i class="fa-solid fa-square-check"></i> Đã quét mã tại vị trí</span>
                            <span style="color:var(--cl-neutral)" v-else><i class="fa-solid fa-ban"></i> Không quét QR</span>
                        </strong>
                    </div>
                </div>

                <!-- Log Details Checklist Items -->
                <div style="display:flex; flex-direction:column; gap:12px;">
                    <h4 style="font-size:14px; font-weight:700; color:var(--cl-text); border-bottom:1px solid var(--cl-border); padding-bottom:8px; margin: 0;"><i class="fa-solid fa-circle-list mr-1 text-primary"></i> Chi tiết kết quả từng hạng mục</h4>
                    <div style="border:1px solid var(--cl-border); border-radius:10px; overflow:hidden;">
                        <table class="cl-table">
                            <thead>
                                <tr style="background:#f8fafc;">
                                    <th style="width: 60px;">STT</th>
                                    <th>Hạng mục kiểm tra</th>
                                    <th style="width: 140px;">Đánh giá</th>
                                    <th>Ghi chú lỗi / Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="(item, idx) in logDetails.Items" :key="item.Id">
                                    <td>${ idx + 1 }</td>
                                    <td><strong>${ item.CheckName }</strong></td>
                                    <td>
                                        <span class="cl-badge" :class="item.IsPassed ? 'cl-badge-pass' : 'cl-badge-fail'">
                                            ${ item.IsPassed ? 'Đạt' : 'Lỗi / Hỏng' }
                                        </span>
                                    </td>
                                    <td>
                                        <span v-if="item.Note" style="color:var(--cl-danger); font-weight:600;">${ item.Note }</span>
                                        <span v-else style="color:var(--cl-text-muted); font-style:italic;">Bình thường</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- General Note -->
                <div v-if="logDetails.Note" style="background:#f1f5f9; border-radius:10px; padding:16px;">
                    <small style="color:var(--cl-text-muted); font-weight:600; text-transform:uppercase; font-size:10px; display:block; margin-bottom:4px;">Ghi chú chung</small>
                    <p style="margin:0; font-size:13.5px; line-height:1.5; color:var(--cl-text);">${ logDetails.Note }</p>
                </div>
            </div>
            <div class="cl-modal-footer">
                <button class="cl-btn cl-btn-primary" @@click="showDetailsModal=false">Đóng cửa sổ</button>
            </div>
        </div>
    </div>

</div>

@section scripts {
    <script src="~/Scripts/app/checklists.js?v=@DateTime.Now.Ticks.ToString()"></script>
}
