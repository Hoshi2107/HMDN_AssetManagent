                        <td><span :class="{'text-danger font-weight-bold': isOverdue(sch.DueDate) && sch.Status==='pending'}">${ sch.DueDate }</span></td>
                        <td>
                            <span class="cl-badge" :class="'cl-badge-' + sch.Status">${ statusLabel(sch.Status) }</span>
                        </td>
                        <td style="text-align: center;">
                            <div v-if="sch.Status === 'pending' || sch.Status === 'overdue'" style="display:inline-flex; border-radius:8px; overflow:hidden; border:1px solid var(--cl-success); height: 32px; vertical-align: middle; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                                <button class="cl-btn" style="height:32px; padding:0 12px; font-size:12px; background:var(--cl-success); color:#fff; border:none; border-radius:0; font-weight:600;" @@click="openPerformModal(sch)">
                                    <i class="fa-solid fa-play"></i> Thực hiện
                                </button>
                                <button class="cl-btn" style="height:32px; width:36px; padding:0; display:flex; align-items:center; justify-content:center; background:var(--cl-success-dark); color:#fff; border:none; border-radius:0; border-left:1px solid rgba(255,255,255,0.3); transition: background 0.2s;" v-if="isQuickPassAvailableForSch(sch)" @@click.prevent.stop="quickPassSingle(sch)" title="Duyệt nhanh (Đánh giá Đạt toàn bộ)">
                                    <span v-if="sch._isQuickPassing"><i class="fa-solid fa-circle-notch fa-spin"></i></span>
                                    <span v-else><i class="fa-solid fa-bolt"></i></span>
                                </button>
                            </div>
                            <span v-else-if="sch.Status !== 'pending' && sch.Status !== 'overdue'" style="color:var(--cl-text-muted); font-size:12.5px; font-style:italic; font-weight:600;"><i class="fa-solid fa-circle-check text-success mr-1"></i> Hoàn tất</span>
                        </td>
                    </tr>
                    <tr v-if="filteredSchedules.length === 0">
                        <td colspan="9" style="padding: 0;">
                            <div class="cl-empty-state">
                                <div class="cl-empty-icon-wrap">
                                    <i class="fa-solid fa-calendar-xmark"></i>
                                </div>
                                <h4 class="cl-empty-title">Không tìm thấy lịch trình kiểm tra</h4>
                                <p class="cl-empty-text">Hiện tại không có lịch kiểm tra nào chờ xử lý khớp với bộ lọc của bạn.</p>
                                <button class="cl-btn cl-btn-primary" style="height:36px; font-size:12.5px; margin-top:8px;" @@click="showGenerateModal = true">
                                    <i class="fa-solid fa-calendar-plus"></i> Sinh lịch trình mới
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination UI -->
        <div class="cl-pagination" v-if="schedulesTotalPages > 1">
            <button class="cl-page-btn" :disabled="schedulesPage === 1" @@click="setSchedulesPage(schedulesPage - 1)">
                <i class="fa-solid fa-chevron-left"></i> Trước
            </button>
            <span class="cl-page-info">Trang ${ schedulesPage } / ${ schedulesTotalPages }</span>
            <button class="cl-page-btn" :disabled="schedulesPage === schedulesTotalPages" @@click="setSchedulesPage(schedulesPage + 1)">
                Sau <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- ===== TAB CONTENT: LOGS ===== -->
    <div v-if="activeTab==='logs'" style="display:flex; flex-direction:column; gap:20px;">
        <div class="cl-filter-bar">
            <div class="cl-input-group flex-grow">
                <label><i class="fa-solid fa-magnifying-glass mr-1"></i> Tìm kiếm nhật ký</label>
                <input type="text" class="cl-input" placeholder="Mã tài sản, tên thiết bị..." v-model="logsFilter.query" />
            </div>
            <div class="cl-input-group">
                <label><i class="fa-solid fa-clipboard-question mr-1"></i> Kết quả chung</label>
                <select class="cl-select" v-model="logsFilter.result">
                    <option value="">Tất cả</option>
                    <option value="pass">Đạt chuẩn</option>
                    <option value="fail">Không đạt</option>
                    <option value="partial">Đạt một phần</option>
                </select>
            </div>
            <div style="margin-top:auto; display:flex; gap:10px;">
                <button class="cl-btn cl-btn-primary" @@click="loadLogs"><i class="fa-solid fa-arrows-rotate"></i> Tải lại</button>
            </div>
        </div>

        <div class="cl-card-table">
            <table class="cl-table">
                <thead>
                    <tr>
                        <th>Mã Tài Sản</th>
                        <th>Tên thiết bị</th>
                        <th>Serial</th>
                        <th>Khoa phòng</th>
                        <th>Người kiểm tra</th>
                        <th>Thời gian thực hiện</th>
                        <th>Loại chu kỳ</th>
                        <th>Kết quả</th>
                        <th style="text-align: center;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="log in paginatedLogs" :key="log.Id">
                        <td><strong class="text-primary">${ log.AssetCode }</strong></td>
                        <td class="font-weight-bold">${ log.ItemName }</td>
                        <td><small class="text-muted font-weight-bold">${ log.SerialNumber || '—' }</small></td>
                        <td>${ log.DepartmentName || '—' }</td>
                        <td class="font-weight-bold">${ log.CheckedByName }</td>
                        <td>${ log.CheckedAt }</td>
                        <td><span class="font-weight-bold">${ cycleLabel(log.CycleType) }</span></td>
                        <td>
                            <span class="cl-badge" :class="'cl-badge-' + log.OverallResult">${ resultLabel(log.OverallResult) }</span>
                        </td>
                        <td style="text-align: center;">
                            <button class="cl-btn cl-btn-outline" style="height:32px; padding:0 12px; font-size:12px; border-radius:8px;" @@click="openDetailsModal(log.Id)">
                                <i class="fa-solid fa-eye"></i> Chi tiết
                            </button>
                        </td>
                    </tr>
                    <tr v-if="filteredLogs.length === 0">
                        <td colspan="9" style="padding: 0;">
                            <div class="cl-empty-state">
                                <div class="cl-empty-icon-wrap">
                                    <i class="fa-solid fa-folder-open"></i>
                                </div>
                                <h4 class="cl-empty-title">Chưa có nhật ký kiểm tra</h4>
                                <p class="cl-empty-text">Chưa có nhật ký ghi nhận kết quả kiểm tra nào trong hệ thống.</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination UI -->
        <div class="cl-pagination" v-if="logsTotalPages > 1">
            <button class="cl-page-btn" :disabled="logsPage === 1" @@click="setLogsPage(logsPage - 1)">
                <i class="fa-solid fa-chevron-left"></i> Trước
            </button>
            <span class="cl-page-info">Trang ${ logsPage } / ${ logsTotalPages }</span>
            <button class="cl-page-btn" :disabled="logsPage === logsTotalPages" @@click="setLogsPage(logsPage + 1)">
                Sau <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- ===== TAB CONTENT: MANAGER APPROVALS ===== -->
    <div v-if="activeTab==='manager_approvals'" style="display:flex; flex-direction:column; gap:28px;">
        <!-- 1. Department Compliance Rates -->
        <div style="background:var(--cl-card-bg); border:1px solid var(--cl-border); border-radius:var(--cl-radius-lg); padding:24px; box-shadow:var(--cl-shadow-sm);">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; border-bottom:1px solid var(--cl-border); padding-bottom:12px;">
                <h4 style="font-size:15px; font-weight:700; color:var(--cl-text); margin:0;">
                    <i class="fa-solid fa-chart-bar mr-2 text-primary"></i>Tỷ lệ tuân thủ Checklist theo khoa phòng ban
                </h4>
                <div style="display:flex; gap:10px;">
                    <input type="date" class="cl-input" v-model="complianceFilter.fromDate" style="height:36px; padding:0 10px; font-size:12.5px;" />
                    <input type="date" class="cl-input" v-model="complianceFilter.toDate" style="height:36px; padding:0 10px; font-size:12.5px;" />
                    <button class="cl-btn cl-btn-primary" style="height:36px; padding:0 12px; font-size:12.5px;" @@click="loadDepartmentProgress">
                        <i class="fa-solid fa-arrows-rotate"></i> Lấy dữ liệu
                    </button>
                </div>
            </div>
            
            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap:20px;">
                <div v-for="dept in departmentCompliance" :key="dept.DepartmentId" style="border:1px solid var(--cl-border); border-radius:var(--cl-radius-md); padding:16px; background:var(--cl-neutral-light);">
                    <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:8px;">
                        <strong style="font-size:13.5px; color:#0f172a;">${ dept.DepartmentName }</strong>
                        <span class="cl-badge" :class="dept.ComplianceRate >= 80 ? 'cl-badge-completed' : (dept.ComplianceRate >= 50 ? 'cl-badge-pending' : 'cl-badge-fail')" style="font-size:11px; padding:2px 8px;">
                            ${ dept.ComplianceRate }%
                        </span>
                    </div>
                    <!-- Progress Bar -->
                    <div style="height:8px; background:#e2e8f0; border-radius:99px; overflow:hidden; margin-bottom:8px;">
                        <div :style="'width: ' + dept.ComplianceRate + '%; height:100%; background:' + (dept.ComplianceRate >= 80 ? 'var(--cl-success)' : (dept.ComplianceRate >= 50 ? 'var(--cl-warning)' : 'var(--cl-danger)'))"></div>
                    </div>
                    <div style="display:flex; justify-content:space-between; font-size:12px; color:var(--cl-text-muted);">
                        <span>Hoàn thành: <strong>${ dept.DoneCount }</strong></span>
                        <span>Tổng lịch trình: <strong>${ dept.TotalCount }</strong></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Checklist Awaiting Approval List -->
        <div style="display:flex; flex-direction:column; gap:20px;">
            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
                <h4 style="font-size:15px; font-weight:700; color:var(--cl-text); margin:0;">
                    <i class="fa-solid fa-list-check mr-2 text-warning"></i>Danh sách checklists chờ duyệt (${ pendingApprovals.length } nhật ký)
                </h4>
                <div style="display:flex; gap:10px;">
                    <button class="cl-btn cl-btn-success" style="height:38px; font-size:13px;" @@click="approveSelectedLogs" :disabled="selectedLogIds.length === 0 || isApproving">
                        <span v-if="isApproving"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang duyệt...</span>
                        <span v-else><i class="fa-solid fa-check-double mr-1"></i> Duyệt hàng loạt (${ selectedLogIds.length } đã chọn)</span>
                    </button>
                    <button class="cl-btn cl-btn-primary" style="height:38px; font-size:13px;" @@click="loadPendingApprovals">
                        <i class="fa-solid fa-arrows-rotate"></i> Tải lại
                    </button>
                </div>
            </div>

            <div class="cl-card-table">
                <table class="cl-table">
                    <thead>
                        <tr>
                            <th style="width:40px; text-align:center;">
                                <input type="checkbox" @@change="toggleSelectAll($event)" :checked="selectedLogIds.length === pendingApprovals.length && pendingApprovals.length > 0" />
                            </th>
                            <th>Mã Tài Sản</th>
                            <th>Tên thiết bị</th>
                            <th>Khoa phòng</th>
                            <th>Kỹ thuật viên</th>
                            <th>Thời gian làm</th>
                            <th>Chu kỳ</th>
                            <th>Kết quả</th>
                            <th style="text-align: center;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="log in pendingApprovals" :key="log.Id">
                            <td style="text-align:center;">
                                <input type="checkbox" :value="log.Id" v-model="selectedLogIds" />
                            </td>
                            <td><strong class="text-primary">${ log.AssetCode }</strong></td>
                            <td class="font-weight-bold">${ log.ItemName }</td>
                            <td>${ log.DepartmentName || '—' }</td>
                            <td>${ log.CheckedByName }</td>
                            <td>${ log.CheckedAt }</td>
                            <td><span class="font-weight-bold">${ cycleLabel(log.CycleType) }</span></td>
                            <td>
                                <span class="cl-badge" :class="'cl-badge-' + log.OverallResult">${ resultLabel(log.OverallResult) }</span>
                            </td>
                            <td style="text-align: center; display:flex; justify-content:center; gap:8px;">
                                <button class="cl-btn cl-btn-success" style="height:28px; padding:0 10px; font-size:11.5px; border-radius:6px;" @@click="approveSingleLog(log.Id)">
                                    <i class="fa-solid fa-circle-check"></i> Duyệt
                                </button>
                                <button class="cl-btn cl-btn-outline" style="height:28px; padding:0 10px; font-size:11.5px; border-radius:6px;" @@click="openDetailsModal(log.Id)">
                                    <i class="fa-solid fa-eye"></i> Chi tiết
                                </button>
                            </td>
                        </tr>
                        <tr v-if="pendingApprovals.length === 0">
                            <td colspan="9" style="padding: 0;">
                                <div class="cl-empty-state">
                                    <div class="cl-empty-icon-wrap" style="background:#f0fdf4; border-color:#bbf7d0; color:#166534;">
                                        <i class="fa-solid fa-shield-heart"></i>
                                    </div>
                                    <h4 class="cl-empty-title" style="color:#166534;">Không có checklist chờ duyệt</h4>
                                    <p class="cl-empty-text">Tất cả checklist định kỳ đạt tiêu chuẩn đã được tự động duyệt. Các checklists lỗi hoặc chu kỳ dài hiện tại đều sạch sẽ.</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    <!-- ===== MODAL: SINH LỊCH TRÌNH MỚI ===== -->
    <div class="cl-modal-overlay" v-if="showGenerateModal" @@click.self="showGenerateModal=false">
        <div class="cl-modal-card">
            <div class="cl-modal-header">
                <h3>Tạo lịch trình Checklist tự động</h3>
                <button class="cl-modal-close" @@click="showGenerateModal=false">×</button>
            </div>
            <div class="cl-modal-body">
                <p style="font-size:13.5px; color:var(--cl-text-muted); margin-bottom:16px;">
                    Hệ thống sẽ dựa vào thiết lập **Chu kỳ kiểm tra** của từng thiết bị trong kho để tự động tính toán và sinh lịch kiểm tra (Schedules).
                </p>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="cl-input-group">
                        <label>Từ ngày</label>
                        <input type="date" class="cl-input" v-model="generateForm.fromDate" />
                    </div>
                    <div class="cl-input-group">
                        <label>Đến ngày</label>
                        <input type="date" class="cl-input" v-model="generateForm.toDate" />
                    </div>
                </div>
            </div>
            <div class="cl-modal-footer">
                <button class="cl-btn cl-btn-outline" @@click="showGenerateModal=false">Hủy bỏ</button>
                <button class="cl-btn cl-btn-primary" @@click="generateSchedules" :disabled="isGenerating">
                    <span v-if="isGenerating"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang tạo...</span>
                    <span v-else><i class="fa-solid fa-check"></i> Xác nhận tạo</span>
                </button>
            </div>
        </div>
    </div>


    <!-- ===== MODAL: THỰC HIỆN CHECKLIST ===== -->
    <div class="cl-modal-overlay" v-if="showPerformModal" @@click.self="showPerformModal=false">
        <div class="cl-modal-card lg">
            <div class="cl-modal-header">
                <h3>Thực hiện kiểm tra thiết bị</h3>
                <button class="cl-modal-close" v-on:click="showPerformModal=false">×</button>
            </div>
            
            <!-- 1. Normal View (Not submitted yet) -->
            <div class="cl-modal-body" v-if="!performForm.submitted">
                <!-- Device Prefilled Info -->
                <div class="cl-device-info-grid">
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-file-signature text-primary mr-1"></i> Tên thiết bị</span>
                        <strong class="cl-info-chip-val" style="color: var(--cl-primary-dark); font-size:14.5px;">${ activeSchedule.ItemName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-hashtag text-primary mr-1"></i> Mã Tài Sản</span>
                        <strong class="cl-info-chip-val">${ activeSchedule.AssetCode }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-barcode text-primary mr-1"></i> Số Serial</span>
                        <strong class="cl-info-chip-val">${ activeSchedule.SerialNumber || 'N/A' }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-hospital-user text-primary mr-1"></i> Khoa phòng</span>
                        <strong class="cl-info-chip-val">${ activeSchedule.DepartmentName }</strong>
                    </div>
                </div>

                <!-- History Warnings Alert Box -->
                <div v-if="historyWarnings.length > 0" style="background:var(--cl-danger-light); border:1px solid rgba(239,68,68,0.25); border-radius:var(--cl-radius-md); padding:14px; display:flex; flex-direction:column; gap:6px;">
                    <strong style="color:var(--cl-danger-dark); font-size:13px; display:flex; align-items:center; gap:6px; margin:0;">
                        <i class="fa-solid fa-triangle-exclamation"></i> CẢNH BÃT TÌNH TRẠNG THIẾT BỊ
                    </strong>
                    <ul style="margin:0; padding-left:20px; color:var(--cl-text); font-size:12.5px;">
                        <li v-for="(warn, wIdx) in historyWarnings" :key="wIdx"><strong>${ warn }</strong></li>
                    </ul>
                </div>

                <!-- Sub-tab Navigation inside Perform Modal -->
                <div class="cl-tabs-nav" style="margin-bottom:8px; border-bottom:1px solid var(--cl-border); gap:20px;">
                    <button type="button" class="cl-tab-btn" :class="{active: activePerformModalTab==='checklist'}" v-on:click="activePerformModalTab='checklist'" style="padding:10px 4px; font-size:13.5px;">
                        <i class="fa-solid fa-clipboard-check"></i> Biểu mẫu kiểm tra
                    </button>
                    <button type="button" class="cl-tab-btn" :class="{active: activePerformModalTab==='history'}" v-on:click="activePerformModalTab='history'" style="padding:10px 4px; font-size:13.5px;">
                        <i class="fa-solid fa-clock-rotate-left"></i> Lịch sử kiểm tra (${ recentInspectionHistory.length })
                    </button>
                </div>

                <!-- SUB-TAB CONTENT: CHECKLIST FORM -->
                <div v-if="activePerformModalTab === 'checklist'" style="display:flex; flex-direction:column; gap:16px;">


                <!-- Checklist Definitions List -->
                <div v-if="performLoading" style="padding:48px; text-align:center; color:var(--cl-text-muted);">
                    <i class="fa-solid fa-circle-notch fa-spin" style="font-size:24px;"></i>
                    <p style="margin-top:10px; font-weight:500;">Đang tải danh sách hạng mục kiểm tra...</p>
                </div>
                
                <div v-else-if="checklistItems.length === 0" style="padding:48px; text-align:center; color:var(--cl-text-muted); font-style:italic;">
                    Không tìm thấy hạng mục nào áp dụng cho thiết bị này. Bạn có thể bấm xác nhận hoàn tất.
                </div>

                <div v-else style="display:flex; flex-direction:column; gap:16px;">
                    <div style="display:flex; flex-direction:column; gap:8px; border-bottom:1px solid var(--cl-border); padding-bottom:8px; margin: 0;">
                        <div style="display: flex; align-items: center; justify-content: space-between; margin: 0;">
                            <h4 style="font-size:14px; font-weight:700; color:var(--cl-text); margin: 0;"><i class="fa-solid fa-list-check mr-1 text-primary"></i> Hạng mục kiểm tra bắt buộc</h4>
                            <div style="display:flex; gap:10px;">
                                <button type="button" v-if="recentInspectionHistory.length > 0" class="cl-btn cl-btn-outline" style="height: 28px; padding: 0 10px; font-size: 11.5px; border-radius: 6px; border-color: var(--cl-primary); color: var(--cl-primary-dark);" @@click="applyYesterdayResults()">
                                    <i class="fa-solid fa-copy"></i> Sao chép từ lần trước
                                </button>
                                <button type="button" class="cl-btn cl-btn-outline" style="height: 28px; padding: 0 10px; font-size: 11.5px; border-radius: 6px; border-color: var(--cl-success); color: var(--cl-success-dark);" @@click="bulkSetAllPassed()">
                                    <i class="fa-solid fa-check-double"></i> Xác nhận đạt tất cả
                                </button>
                            </div>
                        </div>
                        <!-- Pass rate & Progress -->
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-top:4px; background:var(--cl-neutral-light); padding:8px 12px; border-radius:6px; border:1px solid var(--cl-border);">
                            <div style="display:flex; align-items:center; gap:8px; font-size:12.2px; color:var(--cl-text); font-weight:500;">
                                <span>Tiến độ: <strong>${ checklistProgress.completed }/${ checklistProgress.total }</strong></span>
                                <span style="color:var(--cl-border)">|</span>
                                <span style="display:inline-flex; align-items:center; gap:4px;">
                                    Đạt: <strong style="color:var(--cl-success-dark);">${ checklistPassRate.passed }/${ checklistPassRate.total } (${ checklistPassRate.percentage }%)</strong>
                                </span>
                            </div>
                            <div style="flex:1; max-width:200px; height:8px; background:#e2e8f0; border-radius:99px; overflow:hidden;">
                                <div :style="'width: ' + checklistPassRate.percentage + '%; height:100%; background:var(--cl-success)'"></div>
                            </div>
                        </div>
                    </div>
                    <div class="cl-exec-grid">
                        <div class="cl-exec-item" v-for="(item, idx) in checklistItems" :key="item.Id">
                            <div>
                                <div class="cl-exec-name">${ item.CheckName } <span style="color:var(--cl-danger)" v-if="item.IsRequired">*</span></div>
                                <div class="cl-exec-desc" v-if="item.Description">${ item.Description }</div>
                            </div>
                            <div class="cl-exec-actions">
                                <button type="button" class="cl-toggle-btn pass" :class="{active: item.isPassed === true}" @@click="setItemPassed(idx, true)">
                                    <i class="fa-solid fa-circle-check"></i> Đạt
                                </button>
                                <button type="button" class="cl-toggle-btn fail" :class="{active: item.isPassed === false}" @@click="setItemPassed(idx, false)">
                                    <i class="fa-solid fa-circle-xmark"></i> Lỗi
                                </button>
                                <input type="text" class="cl-input" placeholder="Ghi chú lỗi nếu có..." :style="{ height: '36px', width: '180px', fontSize: '12.5px', borderColor: (item.isPassed === false && (!item.note || !item.note.trim())) ? '#dc2626' : '' }" v-model="item.note" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Checklist General Note -->
                <div class="cl-input-group">
                    <label>Ghi chú chung của toàn bộ ca kiểm tra</label>
                    <textarea class="cl-input" style="height:60px; padding:8px 12px; resize:none;" placeholder="Nhập tình trạng tổng quát của thiết bị..." v-model="performForm.note"></textarea>
                </div>
                </div>

                <!-- SUB-TAB CONTENT: HISTORY LOGS -->
                <div v-if="activePerformModalTab === 'history'" style="display:flex; flex-direction:column; gap:12px;">
                    <h4 style="font-size:14px; font-weight:700; color:var(--cl-text); margin: 0; border-bottom:1px solid var(--cl-border); padding-bottom:8px;">
                        <i class="fa-solid fa-history mr-1 text-primary"></i> 5 lần kiểm tra gần nhất
                    </h4>
                    <div v-if="recentInspectionHistory.length === 0" style="padding:24px; text-align:center; color:var(--cl-text-muted); font-style:italic;">
                        Chưa có lịch sử kiểm tra cho thiết bị này.
                    </div>
                    <div v-else class="cl-card-table">
                        <table class="cl-table">
                            <thead>
                                <tr style="background:#f8fafc;">
                                    <th>Thời gian</th>
                                    <th>Người kiểm</th>
                                    <th>Kết quả</th>
                                    <th>Ghi chú</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="hLog in recentInspectionHistory" :key="hLog.Id">
                                    <td>${ hLog.CheckedAt }</td>
                                    <td>${ hLog.CheckedByName }</td>
                                    <td>
                                        <span class="cl-badge" :class="'cl-badge-' + hLog.OverallResult">${ resultLabel(hLog.OverallResult) }</span>
                                    </td>
                                    <td><small>${ hLog.Note || '—' }</small></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="cl-modal-footer" v-if="!performForm.submitted">
                <button type="button" v-if="hasFailedItem" class="cl-btn cl-btn-outline" style="border-color: var(--cl-danger); color: var(--cl-danger-dark); margin-right: auto;" v-on:click="redirectToCreateTicketDirectly()">
                    <i class="fa-solid fa-wrench"></i> Chuyển sang tạo phiếu báo hỏng
                </button>
                <button class="cl-btn cl-btn-outline" v-on:click="showPerformModal=false">Hủy bỏ</button>
                <button class="cl-btn cl-btn-success" v-on:click="submitChecklist" :disabled="isSubmitting">
                    <span v-if="isSubmitting"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang lưu...</span>
                    <span v-else><i class="fa-solid fa-cloud-arrow-up"></i> Hoàn thành & Lưu kết quả</span>
                </button>
            </div>

            <!-- 2. Success Completion View -->
            <div class="cl-modal-body" v-if="performForm.submitted" style="text-align:center; padding:40px 24px; display:flex; flex-direction:column; align-items:center; gap:20px;">
                <div style="width:72px; height:72px; border-radius:50%; background:var(--cl-success-light); display:flex; align-items:center; justify-content:center; color:var(--cl-success); font-size:36px; border: 2px solid var(--cl-success);">
                    <i class="fa-solid fa-check"></i>
                </div>
                <div>
                    <h3 style="font-size:18px; font-weight:700; color:var(--cl-success-dark); margin:0;">Checklist completed successfully.</h3>
                    <p style="font-size:13.5px; color:var(--cl-text-muted); margin-top:8px; max-width:400px; margin-left:auto; margin-right:auto;">
                        Nhật ký kiểm tra đã được ghi nhận và lưu trữ.
                    </p>
                </div>
                
                <!-- Repair Ticket creation suggestion -->
                <div v-if="lastSubmitResult === 'fail' && lastSubmitLogId" style="background:var(--cl-danger-light); border:1px solid rgba(239,68,68,0.2); border-radius:var(--cl-radius-md); padding:16px; width:100%; max-width:440px; text-align:left; margin-bottom:8px;">
                    <strong style="color:var(--cl-danger-dark); font-size:13px; display:block;">Phát hiện lỗi/hỏng trong quá trình kiểm tra</strong>
                    <span style="font-size:12.5px; color:var(--cl-text-muted); display:block; margin-top:4px;">
                        Thiết bị không đạt chuẩn. Hệ thống khuyên bạn nên tạo Ticket sửa chữa để khắc phục sự cố.
                    </span>
                    <button class="cl-btn cl-btn-neutral" style="margin-top:12px; height:32px; padding:0 12px; font-size:12px; color:var(--cl-danger); border-color:var(--cl-danger);" v-on:click="createRepairTicket({ Id: lastSubmitLogId, InventoryId: activeSchedule.InventoryId, Note: performForm.note })">
                        <i class="fa-solid fa-wrench mr-1"></i> Tạo Ticket Sửa Chữa Ngay
                    </button>
                </div>
                
                <!-- Next Asset Suggestion Card -->
                <div v-if="nextPendingAsset" style="background:var(--cl-primary-light); border:1px solid rgba(59,130,246,0.2); border-radius:var(--cl-radius-md); padding:16px; width:100%; max-width:440px; display:flex; flex-direction:column; gap:8px; text-align:left;">
                    <small style="color:var(--cl-primary); font-weight:700; text-transform:uppercase; font-size:10.5px; letter-spacing:0.5px;">Gợi ý thiết bị tiếp theo trong nhóm</small>
                    <div>
                        <strong style="color:#0f172a; font-size:13.5px;">${ nextPendingAsset.ItemName }</strong>
                        <div style="font-size:12.5px; color:var(--cl-text-muted); margin-top:2px;">
                            Mã TS: ${ nextPendingAsset.AssetCode } | Khoa: ${ nextPendingAsset.DepartmentName }
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="cl-modal-footer" v-if="performForm.submitted">
                <button v-if="nextPendingAsset" class="cl-btn cl-btn-primary" v-on:click="goToNextAsset">
                    <i class="fa-solid fa-forward mr-1"></i> Next Asset
                </button>
                <button class="cl-btn cl-btn-outline" v-on:click="showPerformModal=false; loadSchedules(); loadLogs();">
                    <i class="fa-solid fa-list mr-1"></i> Back to Schedule List
                </button>
            </div>
        </div>
    </div>


    <!-- ===== MODAL: KIỂM TRA HÀNG LOẠT NHÓM THIẾT BỊ ===== -->
    <div class="cl-modal-overlay" v-if="showBatchCheckModal" v-on:click.self="showBatchCheckModal=false">
        <div class="cl-modal-card lg" v-if="batchCheckGroup">
            <div class="cl-modal-header">
                <h3>Thực hiện kiểm tra hàng loạt</h3>
                <button class="cl-modal-close" v-on:click="showBatchCheckModal=false">×</button>
            </div>
            
            <!-- Side-by-side Layout -->
            <div class="cl-modal-body" style="display:flex; flex-direction:row; gap:24px; min-height:450px; padding:20px;" v-if="!performForm.submitted">
                <!-- LEFT PANEL: Asset Selection -->
                <div style="flex: 2; border-right: 1px solid var(--cl-border); padding-right:20px; display:flex; flex-direction:column; gap:16px;">
                    <div>
                        <h4 style="font-size:13.5px; font-weight:700; color:var(--cl-text); margin: 0;">Danh sách thiết bị áp dụng</h4>
                        <small style="color:var(--cl-text-muted); display:block; margin-top:2px;">Bỏ chọn thiết bị gặp sự cố riêng để kiểm tra cá nhân.</small>
                    </div>
                    
                    <div style="display:flex; flex-direction:column; gap:8px; overflow-y:auto; flex: 1; max-height:300px; padding-right:4px;">
                        <label v-for="sch in batchCheckGroup.Schedules" :key="sch.Id" style="display:flex; align-items:start; gap:10px; padding:10px; border:1px solid var(--cl-border); border-radius:8px; cursor:pointer; background:#fff; margin:0; transition:var(--cl-tr);" :style="selectedBatchScheduleIds.includes(sch.Id) ? 'border-color:var(--cl-primary); background:var(--cl-primary-light);' : ''">
                            <input type="checkbox" :value="sch.Id" v-model="selectedBatchScheduleIds" style="margin-top:3px; accent-color:var(--cl-primary);" />
                            <div style="font-size:12.5px;">
                                <strong style="color:#0f172a;">${ sch.AssetCode }</strong> - <small style="font-weight:600;">${ sch.SerialNumber || 'No Serial' }</small>
                                <div style="color:var(--cl-text-muted); font-size:11.5px; margin-top:2px;">
                                    Tên: ${ sch.ItemName } | Hạn: ${ sch.DueDate }
                                </div>
                                <span class="cl-badge" :style="sch.Criticality === 'High' || sch.Criticality === 'Critical' ? 'background:var(--cl-danger-light); color:var(--cl-danger-dark); border-color:transparent; font-size:9.5px;' : 'font-size:9.5px;'" style="margin-top:4px; padding:1px 6px;">
                                    Độ quan trọng: ${ sch.Criticality }
                                </span>
                            </div>
                        </label>
                    </div>
                    
                    <!-- Statistics & Savings -->
                    <div style="background:var(--cl-neutral-light); border:1px solid var(--cl-border); border-radius:8px; padding:12px; display:flex; flex-direction:column; gap:6px;">
                        <div style="display:flex; justify-content:space-between; font-size:12.5px;">
                            <span>Đã chọn:</span>
                            <strong style="color:var(--cl-primary-dark);">${ selectedBatchScheduleIds.length } / ${ batchCheckGroup.Schedules.length } thiết bị</strong>
                        </div>
                        <div style="display:flex; justify-content:space-between; font-size:12.5px;" v-if="estimatedBatchSavings > 0">
                            <span>Thời gian tiết kiệm:</span>
                            <strong style="color:var(--cl-success-dark);"><i class="fa-solid fa-gauge mr-1"></i>~${ estimatedBatchSavings } phút</strong>
                        </div>
                    </div>
                </div>
                
                <!-- RIGHT PANEL: Checklist Form -->
                <div style="flex: 3; display:flex; flex-direction:column; gap:16px; overflow-y:auto; max-height:480px; padding-left:4px;">
                    <div>
                        <h4 style="font-size:13.5px; font-weight:700; color:var(--cl-text); margin: 0;">Biểu mẫu kiểm tra đại diện</h4>
                        <small style="color:var(--cl-text-muted); display:block; margin-top:2px;">Nhập đánh giá chung cho tất cả các thiết bị đã chọn.</small>
                    </div>
                    
                    <div class="cl-exec-grid">
                        <div class="cl-exec-item" v-for="(item, idx) in batchCheckItems" :key="item.DefinitionId" style="padding:12px; grid-template-columns: 1fr;">
                            <div>
                                <div class="cl-exec-name" style="font-size:13px;">${ item.CheckName }</div>
                            </div>
                            <div style="display:flex; align-items:center; gap:8px; margin-top:6px;">
                                <button type="button" class="cl-toggle-btn pass" style="height:32px; padding:0 12px; font-size:12px;" :class="{active: item.IsPassed === true}" v-on:click="item.IsPassed = true">
                                    <i class="fa-solid fa-circle-check"></i> Đạt
                                </button>
                                <button type="button" class="cl-toggle-btn fail" style="height:32px; padding:0 12px; font-size:12px;" :class="{active: item.IsPassed === false}" v-on:click="item.IsPassed = false">
                                    <i class="fa-solid fa-circle-xmark"></i> Lỗi
                                </button>
                                <input type="text" class="cl-input" placeholder="Ghi chú lỗi..." style="height:32px; font-size:12px; flex: 1;" v-model="item.Note" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="cl-input-group">
                        <label>Ghi chú chung cho đợt kiểm tra hàng loạt</label>
                        <textarea class="cl-input" style="height:60px; padding:8px 12px; resize:none;" placeholder="Nhập tình trạng tổng quát..." v-model="batchCheckNote"></textarea>
                    </div>
                </div>
            </div>
            
            <div class="cl-modal-footer" v-if="!performForm.submitted">
                <button class="cl-btn cl-btn-outline" v-on:click="showBatchCheckModal=false">Hủy bỏ</button>
                <button class="cl-btn cl-btn-success" v-on:click="submitBatchCheck" :disabled="selectedBatchScheduleIds.length === 0 || isBatchSubmitting">
                    <span v-if="isBatchSubmitting"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang xử lý...</span>
                    <span v-else><i class="fa-solid fa-check-double mr-1"></i> Áp dụng kết quả cho ${ selectedBatchScheduleIds.length } thiết bị</span>
                </button>
            </div>
            
            <!-- Batch check success card -->
            <div class="cl-modal-body" v-if="performForm.submitted" style="text-align:center; padding:40px 24px; display:flex; flex-direction:column; align-items:center; gap:20px;">
                <div style="width:72px; height:72px; border-radius:50%; background:var(--cl-success-light); display:flex; align-items:center; justify-content:center; color:var(--cl-success); font-size:36px; border: 2px solid var(--cl-success);">
                    <i class="fa-solid fa-check"></i>
                </div>
                <div>
                    <h3 style="font-size:18px; font-weight:700; color:var(--cl-success-dark); margin:0;">Kiểm tra hàng loạt hoàn thành!</h3>
                    <p style="font-size:13.5px; color:var(--cl-text-muted); margin-top:8px; max-width:450px;">
                        Đã cập nhật kết quả kiểm tra thành công cho các thiết bị được chọn trong nhóm.
                    </p>
                </div>
                
                <!-- If there was a failure in batch check, suggest redirecting to repair ticket creation -->
                <div v-if="lastSubmitResult !== 'pass' && lastSubmitLogId" style="background:var(--cl-danger-light); border:1px solid rgba(239,68,68,0.2); border-radius:var(--cl-radius-md); padding:16px; width:100%; max-width:480px; text-align:left;">
                    <strong style="color:var(--cl-danger-dark); font-size:13px; display:block;">Phát hiện lỗi/hỏng trong đợt kiểm tra</strong>
                    <span style="font-size:12.5px; color:var(--cl-text-muted); display:block; margin-top:4px;">
                        Một hoặc nhiều thiết bị không đạt chuẩn. Hệ thống khuyên bạn nên tạo Ticket sửa chữa để khắc phục sự cố.
                    </span>
                    <button class="cl-btn cl-btn-neutral" style="margin-top:12px; height:32px; padding:0 12px; font-size:12px; color:var(--cl-danger); border-color:var(--cl-danger);" v-on:click="createRepairTicket({ Id: lastSubmitLogId, InventoryId: batchCheckGroup.Schedules[0].InventoryId, Note: batchCheckNote })">
                        <i class="fa-solid fa-wrench mr-1"></i> Tạo Ticket Sửa Chữa Ngay
                    </button>
                </div>
            </div>
            
            <div class="cl-modal-footer" v-if="performForm.submitted">
                <button class="cl-btn cl-btn-primary" v-on:click="showBatchCheckModal=false; loadSchedules(); loadLogs();">
                    <i class="fa-solid fa-circle-check mr-1"></i> Xác nhận và Đóng
                </button>
            </div>
        </div>
    </div>


    <!-- ===== MODAL: CHI TIẾT NHẬT KÝ ===== -->
    <div class="cl-modal-overlay" v-if="showDetailsModal" @@click.self="showDetailsModal=false">
        <div class="cl-modal-card lg" v-if="logDetails">
            <div class="cl-modal-header">
                <h3>Chi tiết nhật ký kiểm tra thiết bị</h3>
                <button class="cl-modal-close" @@click="showDetailsModal=false">×</button>
            </div>
            <div class="cl-modal-body">
                <!-- General Log Info -->
                <div class="cl-device-info-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-file-signature text-primary mr-1"></i> Thiết bị</span>
                        <strong class="cl-info-chip-val" style="color: var(--cl-primary-dark); font-size: 14px;">${ logDetails.ItemName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-barcode text-primary mr-1"></i> Mã Tài Sản / Serial</span>
                        <strong class="cl-info-chip-val">${ logDetails.AssetCode } / ${ logDetails.SerialNumber || '—' }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-hospital-user text-primary mr-1"></i> Khoa phòng thực hiện</span>
                        <strong class="cl-info-chip-val">${ logDetails.DepartmentName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-user-gear text-primary mr-1"></i> Kỹ thuật viên</span>
                        <strong class="cl-info-chip-val">${ logDetails.CheckedByName }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-clock text-primary mr-1"></i> Thời gian kiểm tra</span>
                        <strong class="cl-info-chip-val">${ logDetails.CheckedAt }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-arrows-spin text-primary mr-1"></i> Chu kỳ kiểm tra</span>
                        <strong class="cl-info-chip-val">${ cycleLabel(logDetails.CycleType) }</strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-square-poll-vertical text-primary mr-1"></i> Kết quả chung</span>
                        <strong class="cl-info-chip-val">
                            <span class="cl-badge" :class="'cl-badge-' + logDetails.OverallResult">${ resultLabel(logDetails.OverallResult) }</span>
                        </strong>
                    </div>
                    <div>
                        <span class="cl-info-chip-label"><i class="fa-solid fa-qrcode text-primary mr-1"></i> Xác thực mã QR</span>
                        <strong class="cl-info-chip-val">
                            <span style="color:var(--cl-success)" v-if="logDetails.QrScannedAt"><i class="fa-solid fa-square-check"></i> Đã quét mã tại vị trí</span>
                            <span style="color:var(--cl-neutral)" v-else><i class="fa-solid fa-ban"></i> Không quét QR</span>
                        </strong>
                    </div>
                </div>

                <!-- Log Details Checklist Items -->
                <div style="display:flex; flex-direction:column; gap:12px;">
                    <div style="display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--cl-border); padding-bottom:8px; margin: 0; flex-wrap:wrap; gap:12px;">
                        <h4 style="font-size:14px; font-weight:700; color:var(--cl-text); margin: 0;"><i class="fa-solid fa-circle-list mr-1 text-primary"></i> Chi tiết kết quả từng hạng mục</h4>
                        <!-- Pass rate & Progress -->
                        <div style="display:flex; align-items:center; gap:16px; background:var(--cl-neutral-light); padding:6px 12px; border-radius:6px; border:1px solid var(--cl-border);">
                            <div style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--cl-text); font-weight:500;">
                                <span>Tiến độ: <strong>${ detailLogProgress.total }/${ detailLogProgress.total }</strong></span>
                                <span style="color:var(--cl-border)">|</span>
                                <span style="display:inline-flex; align-items:center; gap:4px;">
                                    Đạt: <strong style="color:var(--cl-success-dark);">${ detailLogProgress.passed }/${ detailLogProgress.total } (${ detailLogProgress.percentage }%)</strong>
                                </span>
                            </div>
                            <div style="width:120px; height:8px; background:#e2e8f0; border-radius:99px; overflow:hidden;">
                                <div :style="'width: ' + detailLogProgress.percentage + '%; height:100%; background:var(--cl-success)'"></div>
                            </div>
                        </div>
                    </div>
                    <div style="border:1px solid var(--cl-border); border-radius:10px; overflow:hidden;">
                        <table class="cl-table">
                            <thead>
                                <tr style="background:#f8fafc;">
                                    <th style="width: 60px;">STT</th>
                                    <th>Hạng mục kiểm tra</th>
                                    <th style="width: 140px;">Đánh giá</th>
                                    <th>Ghi chú lỗi / Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="(item, idx) in logDetails.Items" :key="item.Id">
                                    <td>${ idx + 1 }</td>
                                    <td><strong>${ item.CheckName }</strong></td>
                                    <td>
                                        <span class="cl-badge" :class="item.IsPassed ? 'cl-badge-pass' : 'cl-badge-fail'">
                                            ${ item.IsPassed ? 'Đạt' : 'Lỗi / Hỏng' }
                                        </span>
                                    </td>
                                    <td>
                                        <span v-if="item.Note" style="color:var(--cl-danger); font-weight:600;">${ item.Note }</span>
                                        <span v-else style="color:var(--cl-text-muted); font-style:italic;">Bình thường</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- General Note -->
                <div v-if="logDetails.Note" style="background:#f1f5f9; border-radius:10px; padding:16px;">
                    <small style="color:var(--cl-text-muted); font-weight:600; text-transform:uppercase; font-size:10px; display:block; margin-bottom:4px;">Ghi chú chung</small>
                    <p style="margin:0; font-size:13.5px; line-height:1.5; color:var(--cl-text);">${ logDetails.Note }</p>
                </div>
            </div>
            <div class="cl-modal-footer">
                <button class="cl-btn cl-btn-primary" @@click="showDetailsModal=false">Đóng cửa sổ</button>
            </div>
        </div>
    </div>

</div>

@section scripts {
    <script src="~/Scripts/app/checklists.js?v=@DateTime.Now.Ticks.ToString()"></script>
}
