@{
    ViewBag.Title = "Location";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/location/location.css" rel="stylesheet" />


<div id="app-loc">

    <div class="main-wrap">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-search">
                    <span class="search-icon">⌕</span>
                    <input type="text"
                           placeholder="Tìm vị trí..."
                           v-model="searchQuery">
                </div>
            </div>
            <div class="user-chip">Admin</div>
        </header>

        <!-- CONTENT -->
        <main class="page-content">

            <div class="page-header">
                <div>
                    <h2>Quản lý vị trí</h2>
                    <p>Danh sách phòng / tầng / tòa nhà trong bệnh viện</p>
                </div>
                <button class="btn-primary" @@click="openAdd">
                    ＋ Thêm vị trí
                </button>
            </div>

            <!-- STATS -->
            <div class="stats-strip">
                <div class="stat-card">
                    <div class="stat-icon blue">📍</div>
                    <div>
                        <div class="stat-num">${ locations.length }</div>
                        <div class="stat-label">Tổng các phòng</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green">🏢</div>
                    <div>
                        <div class="stat-num">${ uniqueBuildings }</div>
                        <div class="stat-label">Tòa nhà</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon orange">🏥</div>
                    <div>
                        <div class="stat-num">${ uniqueFloors }</div>
                        <div class="stat-label">Tầng</div>
                    </div>
                </div>
            </div>

            <!-- FILTER -->
            <div class="filter-bar">
                <select v-model="filterBuilding">
                    <option value="">Tất cả tòa nhà</option>
                    <option v-for="b in buildings" :key="b" :value="b">${ b }</option>
                </select>

                <select v-model="filterFloor">
                    <option value="">Tất cả tầng</option>
                    <option v-for="f in floors" :key="f" :value="f">${ f }</option>
                </select>
            </div>

            <!-- TABLE -->
            <div class="table-card">
                <table>
                    <thead>
                        <tr>
                            <th class="sortable" @@click="sortBy('Id')">
                                ID ${ sortIcon('Id') }
                            </th>
                            <th class="sortable" @@click="sortBy('Name')">
                                Tên vị trí ${ sortIcon('Name') }
                            </th>
                            <th class="sortable" @@click="sortBy('Building')">
                                Tòa nhà ${ sortIcon('Building') }
                            </th>
                            <th class="sortable" @@click="sortBy('Floor')">
                                Tầng ${ sortIcon('Floor') }
                            </th>
                            <th>Trạng Thái</th>
                            @*<th>Ghi chú</th>*@
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr v-if="paginatedLocations.length === 0">
                            <td colspan="6">
                                <div class="empty-state">
                                    <div class="empty-icon">📭</div>
                                    <p>Không tìm thấy vị trí nào</p>
                                </div>
                            </td>
                        </tr>

                        @*<tr v-for="item in paginatedLocations"
                            :key="item.Id"
                            class="table-row">*@
                        <tr v-for="item in paginatedLocations"
                            :key="item.Id"
                            class="table-row"
                            @@click="openDetail(item)">

                            <td><span class="mono">#${ item.Id }</span></td>
                            <td><strong>${ item.Name }</strong></td>
                            <td>
                                <span class="badge badge-floor">${ item.Building || '—' }</span>
                            </td>
                            <td>${ item.Floor || '—' }</td>
                            <td>
                                <span :class="item.IsActive ? 'st-active' : 'st-inactive'">
                                    ${ item.IsActive ? 'Đang hoạt động ' : 'Ngưng hoạt động' }
                                </span>
                            </td>
                            @*<td style="color:#94a3b8;font-size:13px">
                                    ${ item.Description || '—' }
                                </td>*@
                            <td>
                                <div class="action-btns" @@click.stop>

                                    <button class="btn-icon"
                                            @@click="openEdit(item)"
                                            title="Sửa">

                                        ✏️
                                    </button>

                                    <button class="btn-icon lock"
                                            @*@@click="toggleStatus(item)"*@
                                            @@click="openToggleStatus(item)"
                                            :title="item.IsActive ? 'Ngưng sử dụng' : 'Kích hoạt'">

                                        ${ item.IsActive ? '🔒' : '🔓' }
                                    </button>

                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            <div class="pagination">
                <button @@click="prevPage" :disabled="currentPage == 1">← Prev</button>
                <button v-for="page in pages"
                        :key="page"
                        @@click="changePage(page)"
                        :class="{ active: currentPage == page }">
                    ${ page }
                </button>
                <button @@click="nextPage" :disabled="currentPage == totalPages">Next →</button>
            </div>

        </main>
    </div>

    <!-- ── MODAL THÊM / SỬA ── -->
    <div class="modal-overlay"
         v-if="showModal"
         @@click.self="showModal = false">

        <div class="loc-modal">

            <div class="modal-header">
                <div>
                    <h3>${ isEdit ? 'Chỉnh sửa vị trí' : 'Thêm vị trí mới' }</h3>
                    <div class="modal-subtitle" v-if="isEdit">#${ form.Id }</div>
                </div>
                <button class="close-btn" @@click="showModal = false">×</button>
            </div>

            <div class="modal-body">
                <div class="form-grid">

                    <div class="form-group full">
                        <label>Tên vị trí *</label>
                        <input type="text"
                               placeholder="VD: Phòng X-Quang 1"
                               v-model="form.Name">
                    </div>

                    <div class="form-group">
                        <label>Tòa nhà</label>
                        <input type="text"
                               placeholder="VD: Nhà A"
                               v-model="form.Building">
                    </div>

                    <div class="form-group">
                        <label>Tầng</label>
                        <input type="text"
                               placeholder="VD: Tầng 2"
                               v-model="form.Floor">
                    </div>

                    @*<div class="form-group full">
                            <label>Ghi chú</label>
                            <textarea placeholder="Mô tả thêm nếu cần..."
                                      v-model="form.Description"></textarea>
                        </div>*@

                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" @@click="showModal = false">Huỷ</button>
                <button class="btn-save" @@click="saveLocation">
                    ${ isEdit ? '💾 Lưu thay đổi' : '＋ Thêm vị trí' }
                </button>
            </div>

        </div>
    </div>

    <!-- ── MODAL TOGGLE STATUS ── -->
    <div class="modal-overlay"
         v-if="showStatusModal"
         @@click.self="showStatusModal = false">

        <div class="confirm-modal">

            <div class="confirm-body">

                <div class="confirm-icon">

                    ${ statusTarget?.IsActive ? '🔒' : '🔓' }

                </div>

                <h3>
                    ${ statusTarget?.IsActive
                    ? 'Ngưng sử dụng vị trí'
                    : 'Kích hoạt vị trí'
                    }
                </h3>

                <p>

                    Bạn có chắc muốn

                    <strong>
                        ${ statusTarget?.IsActive
                        ? 'ngưng sử dụng'
                        : 'kích hoạt lại'
                        }
                    </strong>

                    vị trí

                    <strong>
                        ${ statusTarget?.Name }
                        ${ statusTarget?.Floor }
                    </strong>

                    không?

                </p>

            </div>

            <div class="confirm-footer">

                <button class="btn-cancel"
                        @@click="showStatusModal = false">

                    Huỷ
                </button>

                <button class="btn-danger"
                        @@click="confirmToggleStatus">

                    ${ statusTarget?.IsActive
                    ? '🔒 Ngưng sử dụng'
                    : '🔓 Kích hoạt'
                    }

                </button>

            </div>

        </div>

    </div>

    <!-- DETAIL MODAL -->
    <div class="modal-overlay"
         v-if="showDetailModal"
         @@click.self="showDetailModal = false">

        <div class="detail-modal">

            <div class="modal-header">

                <div>

                    <h3>
                        ${ locationDetail?.Name }
                    </h3>

                    <div class="modal-subtitle">

                        ${ locationDetail?.Code }

                    </div>

                </div>

                <button class="close-btn"
                        @@click="showDetailModal = false">

                    ×

                </button>

            </div>

            <div class="modal-body">

                <!-- INFO -->
                <div class="detail-grid">

                    <div>
                        <label>Tầng</label>
                        <p>${ locationDetail?.Floor || '—' }</p>
                    </div>

                    <div>
                        <label>Tòa nhà</label>
                        <p>${ locationDetail?.Building || '—' }</p>
                    </div>

                    <div>
                        <label>Khoa phòng</label>
                        <p>${ locationDetail?.DepartmentName || '—' }</p>
                    </div>

                </div>

                <hr>

                <h4>Tài sản thuộc ${ locationDetail?.DepartmentName }</h4>

                <table class="asset-table">

                    <thead>

                        <tr>
                            <th>Asset Code</th>
                            <th>Tài sản</th>
                            <th>Nhóm</th>
                            <th>Brand</th>
                            <th>Model</th>
                            <th>SL</th>
                            <th>Trạng thái</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr v-if="locationInventories.length == 0">

                            <td colspan="7">

                                Không có tài sản

                            </td>

                        </tr>

                        <tr v-for="inv in locationInventories"
                            :key="inv.InventoryId">

                            <td>
                                ${ inv.AssetCode }
                            </td>

                            <td>

                                <strong>
                                    ${ inv.ItemName }
                                </strong>

                            </td>

                            <td>

                                ${ inv.GroupName }

                            </td>

                            <td>

                                ${ inv.Brand || '—' }

                            </td>

                            <td>

                                ${ inv.Model || '—' }

                            </td>

                            <td>

                                ${ inv.Quantity }

                            </td>

                            <td>

                                ${ inv.LifeStatus }

                            </td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <!-- ── TOAST ── -->
    <div class="toast" :class="toast.type" v-if="toast.show">
        ${ toast.msg }
    </div>

</div>
<script src="~/Scripts/app/location.js" ></script>
