                    </div>
                    <div class="fg">
                        <label>Thứ tự hiển thị</label>
                        <input type="number" placeholder="0" v-model.number="groupForm.SortOrder">
                    </div>
                    <div class="fg">
                        <label>Trạng thái</label>
                        <select v-model="groupForm.IsActive">
                            <option :value="true">Đang hoạt động</option>
                            <option :value="false">Ngưng hoạt động</option>
                        </select>
                    </div>
                    <div class="fg full">
                        <label>Mô tả</label>
                        <textarea placeholder="Mô tả nhóm thiết bị..." v-model="groupForm.Description"></textarea>
                    </div>
                </div>
            </div>
            <div class="form-footer">
                <button class="btn-cancel" v-on:click="showGroupForm = false">Huỷ</button>
                <button class="btn-save" v-on:click="saveGroup">${ isEditGroup ? '💾 Lưu' : '+ Thêm' }</button>
            </div>
        </div>
    </div>

    <!-- ══ FORM ITEM ══ -->
    <div class="modal-overlay" v-if="showItemForm" v-on:click.self="showItemForm = false">
        <div class="form-modal">
            <div class="modal-header">
                <div>
                    <h3>${ isEditItem ? 'Sửa mẫu thiết bị' : 'Thêm mẫu thiết bị' }</h3>
                    <div class="modal-header-sub" v-if="activeGroup">Nhóm: ${ activeGroup.Name }</div>
                </div>
                <button class="close-btn" v-on:click="showItemForm = false">×</button>
            </div>
            <div class="form-body">
                <div class="form-grid">
                    <div class="fg">
                        <label>Mã model *</label>
                        <input type="text" placeholder="VD: MODEL-MRI-001" v-model="itemForm.Code">
                    </div>
                    <div class="fg">
                        <label>Đơn vị *</label>
                        <input type="text" placeholder="VD: Bộ" v-model="itemForm.Unit">
                    </div>
                    <div class="fg full">
                        <label>Tên mẫu *</label>
                        <input type="text" placeholder="VD: Máy MRI Magnetom Lumina" v-model="itemForm.Name">
                    </div>
                    <div class="fg">
                        <label>Hãng sản xuất</label>
                        <input type="text" placeholder="VD: Siemens" v-model="itemForm.Brand">
                    </div>
                    <div class="fg">
                        <label>Model</label>
                        <input type="text" placeholder="VD: Magnetom Lumina" v-model="itemForm.Model">
                    </div>
                    <div class="fg">
                        <label>Trạng thái</label>
                        <select v-model="itemForm.IsActive">
                            <option :value="true">Đang dùng</option>
                            <option :value="false">Ngưng</option>
                        </select>
                    </div>
                    <div class="fg full">
                        <label>Mô tả</label>
                        <textarea placeholder="Mô tả thiết bị..." v-model="itemForm.Description"></textarea>
                    </div>
                </div>
            </div>
            <div class="form-footer">
                <button class="btn-cancel" v-on:click="showItemForm = false">Huỷ</button>
                <button class="btn-save" v-on:click="saveItem">${ isEditItem ? '💾 Lưu' : '+ Thêm' }</button>
            </div>
        </div>
    </div>

    <!-- ══ CONFIRM XOÁ ══ -->
    <div class="modal-overlay" v-if="showDeleteModal" v-on:click.self="showDeleteModal = false">
        <div class="confirm-modal">
            <div class="confirm-body">
                <div class="ci">⚠️</div>
                <h3>Xác nhận xoá</h3>
                <p>Bạn chắc muốn xoá <strong>${ deleteTarget.Name }</strong>?<br>Hành động này không thể hoàn tác.</p>
            </div>
            <div class="confirm-footer">
                <button class="btn-cancel" v-on:click="showDeleteModal = false">Không</button>
                <button class="btn-danger" v-on:click="confirmDelete">Xoá luôn</button>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════
         MODAL: HẠNG MỤC CHECKLIST FORM
    ══════════════════════════════════════ -->
    <div class="modal-overlay" v-if="showDefinitionForm" v-on:click.self="showDefinitionForm = false">
        <div class="form-modal" style="width: 550px;">
            <div class="modal-header">
                <div>
                    <h3>${ isEditDefinition ? 'Cập nhật hạng mục kiểm tra' : 'Thêm hạng mục kiểm tra mới' }</h3>
                    <div class="modal-header-sub" v-if="activeGroup">Nhóm: ${ activeGroup.Name }</div>
                </div>
                <button class="close-btn" v-on:click="showDefinitionForm = false">×</button>
            </div>

            <div class="form-body">
                <div class="form-grid">
                    <div class="fg full">
                        <label>Tên hạng mục kiểm tra <span style="color:red">*</span></label>
                        <input type="text" v-model="definitionForm.CheckName" placeholder="VD: Kiểm tra nguồn, Kiểm tra màn hình...">
                    </div>

                    <div class="fg">
                        <label>Phạm vi áp dụng</label>
                        <select v-model="definitionForm.Scope" v-on:change="onDefinitionScopeChange" :disabled="isLockScope">
                            <option value="group">Cả nhóm</option>
                            <option value="item">Loại thiết bị cụ thể</option>
                            <option value="inventory">Thiết bị riêng biệt (Tài sản)</option>
                        </select>
                    </div>

                    <div class="fg" v-if="definitionForm.Scope === 'item' || definitionForm.Scope === 'inventory'">
                        <label>Chọn loại thiết bị <span style="color:red">*</span></label>
                        <div class="searchable-select searchable-select-items-container">
                            <div class="searchable-select-trigger" :class="{ disabled: isLockScope }" v-on:click="!isLockScope && (showItemDropdown = !showItemDropdown)">
                                <span>${ getItemName(definitionForm.ItemId) || '-- Chọn loại thiết bị --' }</span>
                                <span>▼</span>
                            </div>
                            <div class="searchable-select-dropdown" v-if="showItemDropdown">
                                <input type="text" class="searchable-select-search-input" v-model="itemDropdownSearch" placeholder="🔍 Gõ để tìm nhanh..." v-on:click.stop />
                                <ul class="searchable-select-options">
                                    <li class="searchable-select-option"
                                        :class="{ selected: definitionForm.ItemId === '' }"
                                        v-on:click="selectDropdownItem({ Id: '' })">
                                        -- Chọn loại thiết bị --
                                    </li>
                                    <li class="searchable-select-option"
                                        v-for="it in filteredDropdownItems"
                                        :key="it.Id"
                                        :class="{ selected: definitionForm.ItemId === it.Id }"
                                        v-on:click="selectDropdownItem(it)">
                                        ${ it.Name }
                                    </li>
                                    <li class="searchable-select-empty" v-if="filteredDropdownItems.length === 0">
                                        Không có kết quả phù hợp
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="fg" v-if="definitionForm.Scope === 'inventory'">
                        <label>Chọn thiết bị cụ thể <span style="color:red">*</span></label>
                        <div class="searchable-select searchable-select-inventory-container">
                            <div class="searchable-select-trigger" :class="{ disabled: isLockScope }" v-on:click="!isLockScope && (showInventoryDropdown = !showInventoryDropdown)">
                                <span>${ getInventoryAssetCode(definitionForm.InventoryId) !== ('ID: ' + definitionForm.InventoryId) ? getInventoryAssetCode(definitionForm.InventoryId) : '-- Chọn thiết bị cụ thể --' }</span>
                                <span>▼</span>
                            </div>
                            <div class="searchable-select-dropdown" v-if="showInventoryDropdown">
                                <input type="text" class="searchable-select-search-input" v-model="inventoryDropdownSearch" placeholder="🔍 Nhập mã, S/N hoặc vị trí..." v-on:click.stop />
                                <ul class="searchable-select-options">
                                    <li class="searchable-select-option"
                                        :class="{ selected: definitionForm.InventoryId === '' }"
                                        v-on:click="selectDropdownInventory({ Id: '' })">
                                        -- Chọn thiết bị cụ thể --
                                    </li>
                                    <li class="searchable-select-option"
                                        v-for="inv in filteredDropdownInventories"
                                        :key="inv.Id"
                                        :class="{ selected: definitionForm.InventoryId === inv.Id }"
                                        v-on:click="selectDropdownInventory(inv)">
                                        ${ inv.AssetCode } - ${ inv.LocationName || 'Chưa phân vị trí' } (${ inv.SerialNumber || 'Không S/N' })
                                    </li>
                                    <li class="searchable-select-empty" v-if="filteredDropdownInventories.length === 0">
                                        Không có kết quả phù hợp
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="fg">
                        <label>Chu kỳ áp dụng</label>
                        <select v-model="definitionForm.CycleType">
                            <option value="">Mọi chu kỳ</option>
                            <option value="daily">Hàng ngày</option>
                            <option value="weekly">Hàng tuần</option>
                            <option value="monthly">Hàng tháng</option>
                            <option value="yearly">Hàng năm</option>
                        </select>
                    </div>

                    <div class="fg">
                        <label>Thứ tự hiển thị</label>
                        <input type="number" v-model.number="definitionForm.SortOrder">
                    </div>

                    <div class="fg full">
                        <label>Mô tả chi tiết cách kiểm tra</label>
                        <textarea v-model="definitionForm.Description" placeholder="Mô tả các bước kiểm tra (nếu có)..."></textarea>
                    </div>

                    <div class="fg" style="flex-direction:row; align-items:center; gap:8px; margin-top:10px;">
                        <input type="checkbox" id="chk-req" v-model="definitionForm.IsRequired" style="width:auto; margin:0;">
                        <label for="chk-req" style="cursor:pointer; margin:0;">Bắt buộc phải check</label>
                    </div>

                    <div class="fg" style="flex-direction:row; align-items:center; gap:8px; margin-top:10px;">
                        <input type="checkbox" id="chk-act" v-model="definitionForm.IsActive" style="width:auto; margin:0;">
                        <label for="chk-act" style="cursor:pointer; margin:0;">Kích hoạt sử dụng</label>
                    </div>
                </div>
            </div>

            <div class="form-footer">
                <button class="btn-cancel" v-on:click="showDefinitionForm = false">Hủy</button>
                <button class="btn-save" v-on:click="saveDefinition" :disabled="isSavingDefinition">
                    ${ isSavingDefinition ? 'Đang lưu...' : (isEditDefinition ? 'Lưu thay đổi' : 'Thêm mới') }
                </button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" v-if="showDeleteDefModal" v-on:click.self="showDeleteDefModal = false">
        <div class="confirm-modal">
            <div class="confirm-body">
                <div class="ci">⚠️</div>
                <h3>Are you sure you want to delete this checklist?</h3>
                <p>Bạn có chắc chắn muốn xoá hạng mục checklist này?<br>Hành động này không thể hoàn tác.</p>
            </div>
            <div class="confirm-footer">
                <button class="btn-cancel" v-on:click="showDeleteDefModal = false">Không</button>
                <button class="btn-danger" v-on:click="confirmDeleteDefinition">Xoá luôn</button>
            </div>
        </div>
    </div>

    <!-- ══ FORM KHOA PHÒNG ══ -->
    <div class="modal-overlay" v-if="showLocForm" v-on:click.self="showLocForm = false">
        <div class="form-modal">
            <div class="modal-header">
                <div><h3>${ isEditLoc ? 'Sửa khoa phòng' : 'Thêm khoa phòng mới' }</h3></div>
                <button class="close-btn" v-on:click="showLocForm = false">×</button>
            </div>
            <div class="form-body">
                <div class="form-grid">
                    <div class="fg">
                        <label>Mã khoa phòng *</label>
                        <input type="text" placeholder="VD: KHOA-01" v-model="locForm.Code">
                    </div>
                    <div class="fg">
                        <label>Tên khoa phòng *</label>
                        <input type="text" placeholder="VD: Khoa Nội tổng quát" v-model="locForm.Name">
                    </div>
                    <div class="fg full">
                        <label>Ghi chú</label>
                        <textarea placeholder="Mô tả thêm nếu cần..." v-model="locForm.Description"></textarea>
                    </div>
                </div>
            </div>
            <div class="form-footer">
                <button class="btn-cancel" v-on:click="showLocForm = false">Huỷ</button>
                <button class="btn-save" v-on:click="saveLoc">${ isEditLoc ? '💾 Lưu' : '+ Thêm' }</button>
            </div>
        </div>
    </div>

    <!-- ══ CONFIRM TOGGLE TRẠNG THÁI KHOA PHÒNG ══ -->
    <div class="modal-overlay" v-if="showLocStatusModal" v-on:click.self="showLocStatusModal = false">
        <div class="confirm-modal">
            <div class="confirm-body">
                <div class="ci">${ locStatusTarget && locStatusTarget.IsActive ? '🔒' : '🔓' }</div>
                <h3>${ locStatusTarget && locStatusTarget.IsActive ? 'Ngưng sử dụng khoa phòng' : 'Kích hoạt khoa phòng' }</h3>
                <p>
                    Bạn có chắc muốn
                    <strong>${ locStatusTarget && locStatusTarget.IsActive ? 'ngưng sử dụng' : 'kích hoạt lại' }</strong>
                    khoa phòng <strong>${ locStatusTarget ? locStatusTarget.Name : '' }</strong> không?
                </p>
            </div>
            <div class="confirm-footer">
                <button class="btn-cancel" v-on:click="showLocStatusModal = false">Huỷ</button>
                <button class="btn-danger" v-on:click="confirmToggleLocStatus">
                    ${ locStatusTarget && locStatusTarget.IsActive ? '🔒 Ngưng sử dụng' : '🔓 Kích hoạt' }
                </button>
            </div>
        </div>
    </div>

    <!-- TOAST -->
    <div class="toast" v-if="toast.show">${ toast.msg }</div>

</div>

<script src="~/Scripts/app/category.js?v=@DateTime.Now.Ticks"></script>

