                            <div class="inv-accordion-header" v-on:click="toggleExpandInventory(inv.Id)">
                                <span class="inv-accordion-icon">${ expandedInventoryMap[inv.Id] ? '▼' : '▶' }</span>
                                <div class="inv-accordion-meta">
                                    <div class="inv-meta-col code">${ inv.AssetCode }</div>
