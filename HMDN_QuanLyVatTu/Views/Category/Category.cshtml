                                                           v-on:keydown.enter="saveInlineAddChecklist(inv.Id)"
                                                           v-on:keydown.esc="cancelInlineAdd(inv.Id)">
                                                </div>
                                                <div class="inline-add-fg">
                                                    <label>Chu kỳ</label>
                                                    <select class="inline-add-select" v-model="inlineAddForm[inv.Id].CycleType">
                                                        <option value="">Tất cả</option>
                                                        <option value="daily">Hàng ngày</option>
                                                        <option value="weekly">Hàng tuần</option>
                                                        <option value="monthly">Hàng tháng</option>
                                                        <option value="yearly">Hàng năm</option>
                                                    </select>
                                                </div>
                                                <div class="inline-add-fg inline-add-req">
                                                    <label>&nbsp;</label>
                                                    <label class="chk-req-label">
                                                        <input type="checkbox" v-model="inlineAddForm[inv.Id].IsRequired">
                                                        Bắt buộc
                                                    </label>
                                                </div>
                                                <div class="inline-add-fg" style="justify-content: flex-end;">
                                                    <label>&nbsp;</label>
                                                    <div style="display: flex; gap: 6px;">
                                                        <button class="chk-btn-cancel" v-on:click="cancelInlineAdd(inv.Id)">Hủy</button>
                                                        <button class="chk-btn-save"
                                                                v-on:click="saveInlineAddChecklist(inv.Id)"
                                                                :disabled="savingChecklist['add_' + inv.Id]">
                                                            ${ savingChecklist['add_' + inv.Id] ? 'Đang lưu...' : 'Lưu' }
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Action Buttons Row -->
                                        <div class="chk-actions-row">
                                            <button v-if="!inlineAddForm[inv.Id] || !inlineAddForm[inv.Id].show"
