                                            ${ getLifeStatusMeta(inv.LifeStatus).text }
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Accordion Body -->
                            <div class="inv-accordion-body" v-if="expandedInventoryMap[inv.Id]">
                                <!-- Loading -->
                                <div v-if="loadingChecklist[inv.Id]" class="chk-loading">
                                    <span class="chk-spinner"></span> Đang tải checklist...
                                </div>

                                <div v-else>
                                    <!-- Checklist Table -->
                                    <table class="inline-checklist-table" v-if="(inventoryChecklistCache[inv.Id] || []).length > 0">
                                        <thead>
                                            <tr>
                                                <th>Tên hạng mục</th>
                                                <th style="width: 130px;">Chu kỳ</th>
                                                <th style="width: 80px; text-align: center;">Bắt buộc</th>
                                                <th style="width: 80px; text-align: center;">Kích hoạt</th>
                                                <th style="width: 60px; text-align: center;">Xóa</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr v-for="def in (inventoryChecklistCache[inv.Id] || [])"
                                                :key="def.Id"
                                                :class="{ 'row-saving': savingChecklist[def.Id] }">
                                                <td>
                                                    <input v-if="editingChecklistId === def.Id"
                                                           type="text"
                                                           class="inline-edit-input"
                                                           :ref="'editInput_' + def.Id"
                                                           v-model="def.CheckName"
                                                           v-on:keydown.enter="saveInlineChecklist(def)"
                                                           v-on:keydown.esc="cancelInlineEdit(def)"
                                                           v-on:blur="cancelInlineEdit(def)"
                                                           :disabled="savingChecklist[def.Id]">
                                                    <span v-else
                                                          class="inline-edit-name"
                                                          v-on:click="startInlineEdit(def)"
                                                          title="Click để sửa">
                                                        ${ def.CheckName }
                                                        <span v-if="savingChecklist[def.Id]" class="saving-dot">●</span>
                                                    </span>
                                                </td>
                                                <td>
                                                    <select v-model="def.CycleType"
