@{
    ViewBag.Title = "Tạo phiếu mới (Yêu cầu)";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

    :root {
        --hm-navy: #0F2C59;
        --hm-navy-light: #1E4A8A;
        --hm-navy-dark: #071731;
        --hm-bg: #f4f7fb;
        --hm-border: #e2e8f0;
        --hm-text: #1e293b;
        --hm-text-sec: #64748b;
        --hm-success: #10b981;
        --hm-danger: #ef4444;
        --hm-chat-bg: #f8fafc;
        --hm-shadow: 0 4px 20px -2px rgba(15,44,89,.04), 0 2px 8px -1px rgba(0,0,0,.02);
        --hm-tr: all .25s cubic-bezier(.4,0,.2,1);
    }

    .ct-container, 
    .ct-container input, 
    .ct-container select, 
    .ct-container textarea, 
    .ct-container button,
    .ct-container table {
        font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    .ct-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
        padding-bottom: 160px;
        max-width: 1440px;
        width: 100%;
        margin: 0 auto;
        animation: fadeIn .4s ease-out;
    }
    @@media(min-width:992px) {
        .ct-container { grid-template-columns: 2.2fr 1fr; }
    }
    .dev-add-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        align-items: flex-end;
        margin-bottom: 20px;
    }
    @@media(min-width:768px) {
        .dev-add-grid {
            grid-template-columns: 1.8fr 1.2fr 0.8fr 1.5fr auto;
        }
    }
    .col-left, .col-right { display: flex; flex-direction: column; gap: 24px; }

    /* ── CARD ── */
    .p-card {
        background: #fff;
        border: 1px solid var(--hm-border);
        border-radius: 16px;
        box-shadow: var(--hm-shadow);
        overflow: hidden;
        transition: var(--hm-tr);
    }
    .p-card:hover { 
        box-shadow: 0 10px 30px -4px rgba(15,44,89,.08), 0 4px 16px -2px rgba(0,0,0,.03);
        transform: translateY(-2px);
    }
    .c-head {
        display: flex; align-items: center; gap: 12px;
        padding: 20px 24px;
        border-bottom: 1px solid var(--hm-border);
        flex-wrap: wrap;
    }
    .c-icon {
        display: flex; align-items: center; justify-content: center;
        width: 40px; height: 40px; border-radius: 10px;
        background: rgba(15,44,89,.06); color: var(--hm-navy);
        font-size: 17px; font-weight: bold;
    }
    .c-title { font-size: 17px; font-weight: 700; color: var(--hm-navy); }
    .c-body { padding: 24px; }

    /* ── PAGE HEADER ── */
    .pg-head { display: flex; align-items: center; gap: 16px; margin-bottom: 8px; }
    .back-btn {
        display: flex; align-items: center; justify-content: center;
        width: 40px; height: 40px; border-radius: 50%;
        background: #fff; border: 1px solid var(--hm-border);
        color: var(--hm-text-sec); cursor: pointer; transition: var(--hm-tr);
    }
    .back-btn:hover { background: var(--hm-navy); color: #fff; border-color: var(--hm-navy); transform: translateX(-3px); }
    .pg-title { font-size: 22px; font-weight: 700; color: var(--hm-navy); }

    /* ── FORM GRID ── */
    .f-grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
    @@media(min-width:576px) { .f-grid { grid-template-columns: 1fr 1fr; } }
    @@media(min-width:992px) { .f-grid { grid-template-columns: repeat(3, 1fr); } }
    @@media(min-width:1400px) { .f-grid { grid-template-columns: repeat(4, 1fr); } }
    .f-group { display: flex; flex-direction: column; gap: 8px; }
    .f-label {
        font-size: 12.5px; font-weight: 600; text-transform: none;
        letter-spacing: .5px; color: #475569;
    }
    .f-input {
        width: 100%; height: 48px; padding: 0 18px; border-radius: 10px;
        border: 1.5px solid var(--hm-border); background: #fff;
        font-size: 14.5px; color: var(--hm-text); font-weight: 500;
        outline: none; transition: var(--hm-tr);
    }
    .f-input:focus { border-color: var(--hm-navy); box-shadow: 0 0 0 3px rgba(15,44,89,.12); }
    .f-input:disabled { background: #f8fafc; color: #94a3b8; cursor: not-allowed; border-style: dashed; border-color: #cbd5e1; }
    .icon-wrap { position: relative; display: flex; align-items: center; }
    .icon-wrap i { position: absolute; left: 14px; color: var(--hm-navy); font-size: 14px; }
    .icon-wrap input { padding-left: 40px; }

    /* ── REASON TEXTAREA (EXPORT/TRANSFER) ── */
    .reason-textarea {
        width: 100%; min-height: 160px; border: 1.5px solid var(--hm-border);
        border-radius: 12px; padding: 16px; font-size: 14.5px;
        color: var(--hm-text); outline: none; resize: vertical;
        transition: var(--hm-tr); background: #fff; line-height: 1.6;
    }
    .reason-textarea:focus { border-color: var(--hm-navy); box-shadow: 0 0 0 3px rgba(15,44,89,.12); }
    .reason-hint { display: flex; gap: 8px; margin-top: 12px; color: var(--hm-text-sec); font-size: 12px; line-height: 1.4; }
    .reason-hint i { color: var(--hm-navy); margin-top: 2px; }

    /* ── Reason & Proposal columns grid ── */
    .reason-proposal-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
    }
    @@media(min-width:768px) {
        .reason-proposal-grid {
            grid-template-columns: 1fr 1fr;
        }
    }


    /* ── PURCHASE REQUEST FORM (IMPORT/EXPORT/TRANSFER) ── */
    .pr-form-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 0.8fr 1.5fr auto;
        gap: 12px;
        align-items: flex-end;
        margin-bottom: 20px;
    }
    @@media(max-width:768px) { .pr-form-grid { grid-template-columns: 1fr; } }
    .pr-table {
        width: 100%; border-collapse: collapse; font-size: 13.5px;
    }
    .pr-table th {
        padding: 12px 14px; background: #f8fafc;
        font-weight: 700; color: var(--hm-navy);
        border-bottom: 2px solid var(--hm-border);
        text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: .5px;
    }
    .pr-table td {
        padding: 10px 14px; border-bottom: 1px solid var(--hm-border);
        vertical-align: middle; color: var(--hm-text);
    }
    .pr-table tbody tr:hover { background: #f8fafc; }
    .pr-table tbody tr:last-child td { border-bottom: none; }
    .pr-inline-input {
        width: 100%; padding: 6px 10px; border: 1px solid var(--hm-border);
        border-radius: 8px; font-size: 13px; color: var(--hm-text);
        outline: none; background: #fff; transition: border-color .2s;
    }
    .pr-inline-input:focus { border-color: var(--hm-navy); }
    .pr-table-wrap {
        border: 1px solid var(--hm-border); border-radius: 12px; overflow: hidden;
        background: #fff; box-shadow: 0 1px 3px rgba(0,0,0,.02);
    }
    .pr-info-box {
        background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 10px;
        padding: 12px 16px; margin-bottom: 18px; display: flex; gap: 10px; align-items: flex-start;
        font-size: 13px; color: #1e40af;
    }
    .pr-info-box i { color: #3b82f6; margin-top: 2px; }

    /* ── CHAT CONTAINER ── */
    .chat-wrap {
        display: flex; flex-direction: column; height: 420px; background: var(--hm-chat-bg);
        position: relative;
    }
    .chat-msgs {
        flex: 1; overflow-y: auto; padding: 24px; display: flex;
        flex-direction: column; gap: 20px; scrollbar-width: thin;
    }
    .chat-msgs::-webkit-scrollbar { width: 6px; }
    .chat-msgs::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .msg-item { display: flex; gap: 12px; align-items: flex-start; max-width: 85%; }
    .msg-self { align-self: flex-start; }
    .msg-peer { align-self: flex-end; flex-direction: row-reverse; }
    .av-circle {
        display: flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border-radius: 50%;
        font-weight: 700; font-size: 13px; flex-shrink: 0;
        box-shadow: 0 2px 6px rgba(0,0,0,.06);
    }
    .av-self { background: #e2e8f0; color: #475569; }
    .av-peer { background: var(--hm-navy); color: #fff; }
    .msg-cw { display: flex; flex-direction: column; gap: 4px; }
    .msg-self .msg-cw { align-items: flex-start; }
    .msg-peer .msg-cw { align-items: flex-end; }
    .sender-txt { font-size: 11px; font-weight: 600; color: var(--hm-text-sec); }
    .msg-bubble {
        padding: 12px 16px; border-radius: 14px; font-size: 13px;
        line-height: 1.5; box-shadow: 0 1px 3px rgba(0,0,0,.02); word-break: break-word;
    }
    .msg-self .msg-bubble { background: #fff; color: var(--hm-text); border: 1px solid var(--hm-border); border-top-left-radius: 2px; }
    .msg-peer .msg-bubble { background: #eff6ff; color: #0d284f; border: 1px solid rgba(15,44,89,.1); border-top-right-radius: 2px; }
    .msg-time { font-size: 10px; color: #94a3b8; margin-top: 2px; }
    .peer-tag {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 2px 8px; border-radius: 12px;
        background: rgba(15,44,89,.08); color: var(--hm-navy);
        font-size: 10px; font-weight: 700; margin-bottom: 4px;
        text-transform: uppercase; letter-spacing: .5px;
    }

    /* Attachment */
    .att-box {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 18px; border-radius: 12px; background: #fff;
        border: 1px dashed #cbd5e1; cursor: pointer; transition: var(--hm-tr);
    }
    .att-box:hover { border-color: var(--hm-navy); background: rgba(15,44,89,.02); transform: translateY(-1px); }
    .att-icon { font-size: 24px; color: #10b981; }
    .att-info { display: flex; flex-direction: column; }
    .att-name { font-size: 12px; font-weight: 600; color: var(--hm-text); }
    .att-act { font-size: 10px; color: var(--hm-navy); font-weight: 500; }

    /* System message */
    .sys-row { align-self: center; margin: 8px 0; }
    .sys-pill {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 16px; border-radius: 20px;
        background: #f1f5f9; border: 1px solid var(--hm-border);
        color: var(--hm-text-sec); font-size: 11.5px; font-weight: 500;
    }

    /* Chat input */
    .chat-input-bar {
        display: flex; align-items: center; gap: 12px;
        padding: 16px 24px; background: #fff; border-top: 1px solid var(--hm-border);
    }
    .chat-add {
        display: flex; align-items: center; justify-content: center;
        width: 38px; height: 38px; border-radius: 50%;
        background: #f1f5f9; border: none; color: var(--hm-text-sec);
        font-size: 16px; cursor: pointer; transition: var(--hm-tr);
    }
    .chat-add:hover { background: #e2e8f0; color: var(--hm-text); transform: scale(1.05); }
    .chat-inp {
        flex: 1; height: 40px; border-radius: 20px;
        border: 1.5px solid var(--hm-border); padding: 0 18px;
        font-size: 13.5px; outline: none; transition: var(--hm-tr); background: #f8fafc;
    }
    .chat-inp:focus { border-color: var(--hm-navy); background: #fff; box-shadow: 0 0 0 2px rgba(15,44,89,.05); }
    .chat-send {
        display: flex; align-items: center; justify-content: center;
        width: 38px; height: 38px; border-radius: 50%;
        background: var(--hm-navy); border: none; color: #fff;
        font-size: 14px; cursor: pointer; transition: var(--hm-tr);
        box-shadow: 0 2px 8px rgba(15,44,89,.2);
    }
    .chat-send:hover { background: var(--hm-navy-light); transform: translate(1px,-1px); box-shadow: 0 4px 12px rgba(15,44,89,.3); }
    .chat-send:active { transform: scale(.95); }

    /* ── LOCKED CHAT OVERLAY (EXPORT/TRANSFER) ── */
    .chat-locked-wrapper { position: relative; }
    .chat-locked-wrapper .chat-wrap { filter: opacity(.55); pointer-events: none; }
    .chat-locked-wrapper .chat-input-bar { pointer-events: none; opacity: .35; }
    .chat-lock-overlay {
        position: absolute; inset: 0; z-index: 10;
        display: flex; align-items: center; justify-content: center;
        cursor: not-allowed; border-radius: 0 0 16px 16px;
        transition: var(--hm-tr);
    }
    .chat-lock-badge {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 28px; border-radius: 14px;
        background: rgba(255,255,255,.75); backdrop-filter: blur(6px);
        border: 1px solid var(--hm-border);
        color: var(--hm-text-sec); font-size: 14px; font-weight: 600;
        opacity: 0; transform: scale(.9);
        transition: opacity .25s ease, transform .25s ease;
        box-shadow: 0 4px 20px rgba(0,0,0,.08);
    }
    .chat-lock-overlay:hover .chat-lock-badge {
        opacity: 1; transform: scale(1);
    }
    .chat-lock-badge i { color: var(--hm-danger); font-size: 16px; }

    /* ── RIGHT COLUMN: ATTACHMENT BOX ── */
    .attach-tabs { display: flex; border-bottom: 1px solid var(--hm-border); }
    .attach-tab {
        flex: 1; padding: 12px 0; text-align: center;
        font-size: 12.5px; font-weight: 600; color: var(--hm-text-sec);
        cursor: pointer; border-bottom: 2px solid transparent; transition: var(--hm-tr);
    }
    .attach-tab:hover { color: var(--hm-navy); }
    .attach-tab.active { color: var(--hm-navy); border-bottom-color: var(--hm-navy); }
    .attach-tab i { margin-right: 6px; }
    .drop-zone {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 12px; padding: 36px 24px; margin: 20px;
        border: 2px dashed var(--hm-border); border-radius: 14px;
        color: var(--hm-text-sec); cursor: pointer; transition: var(--hm-tr);
        min-height: 160px;
    }
    .drop-zone:hover, .drop-zone.drag-over {
        border-color: var(--hm-navy); background: rgba(15,44,89,.02);
    }
    .drop-zone.drag-over { border-color: var(--hm-navy-light); background: rgba(15,44,89,.04); }
    .drop-icon { font-size: 36px; color: #94a3b8; }
    .drop-text { font-size: 13px; font-weight: 600; color: var(--hm-text); }
    .drop-hint { font-size: 11px; color: #94a3b8; }
    .file-list { padding: 0 20px 16px; display: flex; flex-direction: column; gap: 8px; }
    .file-item {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px; border-radius: 10px;
        background: #f8fafc; border: 1px solid var(--hm-border); font-size: 12px;
    }
    .file-item i { color: var(--hm-success); font-size: 16px; }
    .file-item .fname { flex: 1; font-weight: 600; color: var(--hm-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .file-item .fsize { color: var(--hm-text-sec); font-size: 10px; }
    .file-item .fremove {
        background: none; border: none; color: #94a3b8; cursor: pointer;
        font-size: 13px; transition: var(--hm-tr);
    }
    .file-item .fremove:hover { color: var(--hm-danger); }

    /* ── NOTES AREA ── */
    .notes-ta {
        width: 100%; height: 120px; border: 1.5px solid var(--hm-border);
        border-radius: 12px; padding: 16px; font-size: 13.5px;
        color: var(--hm-text); outline: none; resize: none; transition: var(--hm-tr); background: #fff;
    }
    .notes-ta:focus { border-color: var(--hm-navy); box-shadow: 0 0 0 3px rgba(15,44,89,.1); }

    /* ── BOTTOM BAR ── */
    .bottom-bar {
        position: fixed; bottom: 0; left: 0; right: 0; height: 72px;
        background: #fff; border-top: 1px solid var(--hm-border);
        display: flex; align-items: center; justify-content: flex-end;
        gap: 24px; padding: 0 32px; z-index: 999;
        box-shadow: 0 -4px 12px rgba(0,0,0,.03);
    }
    @@media(min-width:769px) { .bottom-bar { left: 230px; } }
    .btn-cancel {
        font-size: 13.5px; font-weight: 600; color: var(--hm-text-sec);
        background: none; border: none; cursor: pointer; transition: var(--hm-tr);
        padding: 8px 16px; border-radius: 8px;
    }
    .btn-cancel:hover { color: var(--hm-text); background: #f1f5f9; }
    .btn-submit {
        display: inline-flex; align-items: center; gap: 10px;
        height: 44px; padding: 0 26px; border-radius: 22px;
        background: var(--hm-navy); color: #fff; font-size: 13.5px;
        font-weight: 600; border: none; cursor: pointer;
        box-shadow: 0 4px 14px rgba(15,44,89,.25); transition: var(--hm-tr);
    }
    .btn-submit:hover { background: var(--hm-navy-light); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(15,44,89,.35); }
    .btn-submit:active { transform: translateY(0); }
    .btn-submit i { font-size: 12px; transition: var(--hm-tr); }
    @@keyframes fadeIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }

    /* Custom Multi-Column Dropdown Styles */
    .custom-select-container {
        position: relative;
        width: 100%;
    }

    .custom-select-trigger {
        background: #ffffff;
        border: 1.5px solid var(--hm-border);
        border-radius: 10px;
        height: 44px;
        padding: 0 16px;
        font-size: 13.5px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: var(--hm-tr);
    }

    .custom-select-trigger:hover {
        border-color: var(--hm-navy);
    }

    .custom-select-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        width: 780px; /* Expand wider to fit all columns nicely */
        background: #ffffff;
        border: 1px solid var(--hm-border);
        border-radius: 12px;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        z-index: 9999;
        margin-top: 6px;
        padding: 8px;
    }

    /* Responsive adjustment */
    @@media (max-width: 992px) {
        .custom-select-dropdown {
            width: 100%;
            left: 0;
        }
    }

    .dropdown-table-container {
        max-height: 280px;
        overflow-y: auto;
        border: 1px solid var(--hm-border);
        border-radius: 8px;
    }

    .dropdown-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        text-align: left;
    }

    .dropdown-table th {
        position: sticky;
        top: 0;
        background: #f8fafc;
        color: var(--hm-navy);
        font-weight: 700;
        padding: 10px 12px;
        border-bottom: 2px solid var(--hm-border);
        z-index: 2;
        font-size: 12px;
        text-transform: uppercase;
    }

    .dropdown-table td {
        padding: 10px 12px;
        border-bottom: 1px solid var(--hm-border);
        color: #334155;
        transition: background-color 0.15s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dropdown-table tbody tr {
        cursor: pointer;
    }

    .dropdown-table tbody tr:hover td {
        background-color: #f1f5f9;
    }

    .dropdown-table .col-code {
        font-weight: 600;
        color: var(--hm-navy);
        width: 18%;
        max-width: 120px;
    }

    .dropdown-table .col-name {
        width: 35%;
        max-width: 250px;
    }

    .dropdown-table .col-model {
        width: 15%;
        max-width: 120px;
    }

    .dropdown-table .col-serial {
        width: 15%;
        max-width: 120px;
    }

    .dropdown-table .col-dept {
        width: 17%;
        color: var(--hm-text-sec);
        max-width: 150px;
    }

    .dropdown-table .no-result {
        text-align: center;
        padding: 24px;
        color: var(--hm-text-sec);
        font-style: italic;
    }

    /* Column-specific search input styles */
    .search-col-input {
        height: 28px !important;
        padding: 0 8px !important;
        font-size: 11.5px !important;
        border-radius: 6px !important;
        border: 1px solid var(--hm-border) !important;
        width: 100% !important;
        box-sizing: border-box !important;
        font-weight: 500 !important;
        outline: none !important;
        transition: var(--hm-tr) !important;
        background: #ffffff !important;
    }
    .search-col-input:focus {
        border-color: var(--hm-navy) !important;
        box-shadow: 0 0 0 2px rgba(15,44,89,.08) !important;
    }
    .dropdown-search-row th {
        position: static !important;
        background: #f8fafc !important;
        padding: 4px 6px !important;
        border-bottom: 2px solid var(--hm-border) !important;
        box-shadow: none !important;
    }
</style>

<div id="app" v-cloak>
    <!-- HEADER -->
    <div class="pg-head">
        <button class="back-btn" @@click="goBack" title="Quay lại"><i class="fa-solid fa-arrow-left"></i></button>
        <div>
            <h1 class="pg-title">Tạo phiếu mới (Yêu cầu)</h1>
            <p style="font-size:12.5px;color:var(--hm-text-sec);margin-top:2px;">Tạo phiếu yêu cầu nghiệp vụ nhập kho, xuất kho hoặc điều chuyển vật tư y tế.</p>
        </div>
    </div>

    <!-- MAIN GRID -->
    <div class="ct-container" style="margin-top:20px;">
        <!-- ===== COLUMN LEFT ===== -->
        <div class="col-left">

            <!-- 1. GENERAL INFO -->
            <div class="p-card">
                <div class="c-head">
                    <div class="c-icon"><i class="fa-solid fa-circle-info"></i></div>
                    <span class="c-title">Thông tin chung</span>
                </div>
                <div class="c-body">
                    <div class="f-grid">
                        <div class="f-group">
                            <label class="f-label">Loại yêu cầu</label>
