                        <img v-if="f.type.startsWith('image/')" :src="f.url" style="width: 100%; height: 100%; object-fit: cover;" />
                        <div v-else-if="f.type.startsWith('video/')" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #0f172a; color: #ffffff; position: relative;">
                            <video :src="f.url" style="width: 100%; height: 100%; object-fit: cover;"></video>
                            <i class="fa-solid fa-circle-play" style="position: absolute; font-size: 20px; color: rgba(255,255,255,0.8); z-index: 1;"></i>
                        </div>
                        <button type="button" class="fremove" @@click.stop="removeImage(i)" title="Xóa" style="position: absolute; top: 4px; right: 4px; background: rgba(15, 23, 42, 0.65); border: none; color: #ffffff; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 10px; z-index: 2; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#ef4444'" onmouseout="this.style.backgroundColor='rgba(15, 23, 42, 0.65)'">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                </div>
                <!-- File list -->
                <div class="file-list" v-if="attachTab === 'file' && attachedFiles.length > 0">
                    <div class="file-item" v-for="(f, i) in attachedFiles" :key="i">
                        <i class="fa-regular fa-file" style="color: var(--hm-navy); font-size: 16px;"></i>
                        <span class="fname">${ f.name }</span>
                        <span class="fsize">${ formatSize(f.size) }</span>
                        <button class="fremove" @@click="removeFile(i)" title="Xóa"><i class="fa-solid fa-xmark"></i></button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- BOTTOM BAR -->
    <div class="bottom-bar">
        <button class="btn-cancel" @@click="goBack">Hủy bỏ</button>
        <button class="btn-submit" @@click="submitTicket" :disabled="isSubmitting">
            <span v-if="isSubmitting">Đang gửi...</span>
            <span v-else>Gửi yêu cầu</span>
            <i class="fa-solid fa-play" v-if="!isSubmitting"></i>
        </button>
    </div>
</div>

@section scripts {
    <script>
        new Vue({
            el: '#app',
            delimiters: ['${', '}'],
            data: {
                // Dropdown mapping: nhãn Tiếng Việt -> chuỗi lưu CSDL SQL Server
                listLoaiYeuCau: [
                    { text: 'Nhập kho', value: 'IMPORT' },
                    { text: 'Xuất kho', value: 'EXPORT' },
                    { text: 'Điều chuyển', value: 'TRANSFER' },
                    { text: 'Hỗ trợ', value: 'SUPPORT' },
                    { text: 'Sửa chữa', value: 'REPAIR' }
                ],
                listLoaiVatTu: ['Thiết bị y tế', 'Vật tư tiêu hao', 'Linh kiện thay thế', 'Khác'],

                dbItems: [], // Danh sách mẫu thiết bị từ CSDL
                inventoryAssets: [], // Danh sách mã tài sản từ bảng Inventory
                searchQuery: '',
                newDevice: {
                    itemName: '',
                    serialNumber: '',
                    quantity: 1,
                    note: ''
                },
                newPrItem: {
                    tenHang: '',
                    donVi: '',
                    soLuong: 1,
                    ghiChu: ''
                },

                // Form data: khởi tạo động từ Razor ViewBag hoặc LocalStorage
                form: {
                    ticketType: 'IMPORT',
                    creator: 'Đang tải...',
                    department: 'Đang tải...',
                    userId: 1,
                    assetType: '',
                    targetDepartmentId: '',
                    note: '',
                    reasonDetails: '',
                    proposal: '',
                    devices: [],      // Dùng cho SUPPORT / REPAIR
                    prItems: []       // Dùng cho IMPORT / EXPORT / TRANSFER
                },
                listDepartments: [],

                isSubmitting: false,

                // Attachment panel
                attachTab: 'image',
                isDragging: false,
                attachedImages: [],
                attachedFiles: [],

                // Custom Select Dropdown
                isDropdownOpen: false,
                searchCol: {
                    code: '',
                    name: '',
                    model: '',
                    serial: '',
                    dept: ''
                }
            },
            computed: {
                isDeviceForm() {
                    // SUPPORT (HoTro) và REPAIR (SuaChua) → hiện form thiết bị + lý do
                    return this.form.ticketType === 'SUPPORT' || this.form.ticketType === 'REPAIR';
                },
                ticketTypeLabel() {
                    var map = { 'IMPORT': 'Nhập kho', 'EXPORT': 'Xuất kho', 'TRANSFER': 'Điều chuyển', 'SUPPORT': 'Hỗ trợ', 'REPAIR': 'Sửa chữa' };
                    return map[this.form.ticketType] || this.form.ticketType;
                },
                filteredInventoryAssets() {
                    var vm = this;
                    var q = (vm.searchQuery || '').trim().toLowerCase();
                    
                    var colCode = (vm.searchCol.code || '').trim().toLowerCase();
                    var colName = (vm.searchCol.name || '').trim().toLowerCase();
                    var colModel = (vm.searchCol.model || '').trim().toLowerCase();
                    var colSerial = (vm.searchCol.serial || '').trim().toLowerCase();
                    var colDept = (vm.searchCol.dept || '').trim().toLowerCase();

                    return vm.inventoryAssets.filter(function (x) {
                        // 1. Tìm kiếm tổng thể (Global Search)
                        if (q) {
                            var code = (x.AssetCode || '').toLowerCase();
                            var name = (x.AssetName || '').toLowerCase();
                            var model = (x.Model || '').toLowerCase();
                            var serial = (x.SerialNumber || '').toLowerCase();
                            var dept = (x.DepartmentName || '').toLowerCase();
                            
                            var matchGlobal = code.indexOf(q) > -1 || 
                                              name.indexOf(q) > -1 || 
                                              model.indexOf(q) > -1 || 
                                              serial.indexOf(q) > -1 || 
                                              dept.indexOf(q) > -1;
                            if (!matchGlobal) return false;
                        }

                        // 2. Tìm kiếm theo từng cột cụ thể (Column-specific Search)
                        if (colCode && (x.AssetCode || '').toLowerCase().indexOf(colCode) === -1) return false;
                        if (colName && (x.AssetName || '').toLowerCase().indexOf(colName) === -1) return false;
                        if (colModel && (x.Model || '').toLowerCase().indexOf(colModel) === -1) return false;
                        if (colSerial && (x.SerialNumber || '').toLowerCase().indexOf(colSerial) === -1) return false;
                        if (colDept && (x.DepartmentName || '').toLowerCase().indexOf(colDept) === -1) return false;

                        return true;
                    });
                }
            },

            methods: {
                // ── Load dữ liệu từ server ──
                loadUserInfo(userId) {
                    var vm = this;
                    fetch('/CreateTicket/GetUserInfo?userId=' + userId)
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.success) {
                                vm.form.creator = res.fullName;
                                vm.form.department = res.departmentName;
                            } else {
                                vm.form.creator = 'Lỗi tải thông tin';
                                vm.form.department = 'Lỗi tải phòng ban';
                            }
                        })
                        .catch(function () {
                            vm.form.creator = 'Lỗi kết nối';
                            vm.form.department = 'Lỗi kết nối';
                        });
                },
                loadDepartments() {
                    var vm = this;
                    fetch('/CreateTicket/GetActiveDepartments')
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.error) {
                                console.error(res.error);
                            } else {
                                vm.listDepartments = res;
                            }
                        })
                        .catch(function (err) {
                            console.error('Không thể kết nối lấy danh sách phòng ban:', err);
                        });
                },
                loadDbItems() {
                    var vm = this;
                    fetch('/CreateTicket/GetAllItems')
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.error) {
                                console.error(res.error);
                            } else {
                                vm.dbItems = res;
                            }
                        })
                        .catch(function (err) {
                            console.error('Không thể kết nối lấy danh mục thiết bị:', err);
                        });
                },

                loadInventoryAssets() {
                    var vm = this;
                    fetch('/CreateTicket/GetAllInventoryAssets')
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.error) {
                                console.error(res.error);
                            } else {
                                vm.inventoryAssets = res;

                                // just added
                                vm.addDeviceFromUrlParams();

                            }
                        })
                        .catch(function (err) {
                            console.error('Không thể kết nối lấy danh mục mã tài sản:', err);
                        });
                },

                // ── Sinh Serial tự động ──
                generateSerial(itemName) {
                    var prefix = 'SN';
                    if (itemName) {
                        // Lấy 2-3 ký tự đầu của tên thiết bị (không dấu, viết hoa)
                        var normalized = itemName.trim()
                            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
                            .replace(/[^a-zA-Z0-9]/g, '')
                            .toUpperCase()
                            .substring(0, 3);
                        if (normalized) prefix = normalized;
                    }
                    var now = new Date();
                    var yy = String(now.getFullYear()).slice(-2);
                    var mm = ('0' + (now.getMonth() + 1)).slice(-2);
                    var dd = ('0' + now.getDate()).slice(-2);
                    var rand = Math.random().toString(36).toUpperCase().substring(2, 6);
                    return prefix + '-' + yy + mm + dd + '-' + rand;
                },

                // ── Quản lý danh sách thiết bị yêu cầu ──
                addDeviceToList() {
                    if (!this.newDevice.itemName) {
                        this.toast('Cảnh báo', 'Vui lòng chọn Mã Tài Sản!', 'warning');
                        return;
                    }
                    if (this.newDevice.quantity <= 0) {
                        this.toast('Cảnh báo', 'Số lượng yêu cầu phải lớn hơn 0!', 'warning');
                        return;
                    }

                    var vm = this;
                    var selectedAssetCode = this.newDevice.itemName;
                    var serialNum = this.newDevice.serialNumber;

                    var exists = this.form.devices.find(function (d) {
                        return d.itemName.toLowerCase() === selectedAssetCode.toLowerCase();
                    });

                    if (exists) {
                        exists.quantity += vm.newDevice.quantity;
                    } else {
                        this.form.devices.push({
                            itemName: selectedAssetCode,
                            serialNumber: serialNum,
                            quantity: this.newDevice.quantity,
                            unit: 'Cái',
                            note: this.newDevice.note
                        });
                    }

                    this.searchQuery = '';
                    this.newDevice = {
                        itemName: '',
                        serialNumber: '',
                        quantity: 1,
                        note: ''
                    };
                },

                removeDeviceFromList(idx) {
                    this.form.devices.splice(idx, 1);
                },

                // ── Quản lý danh sách hàng hóa (IMPORT/EXPORT/TRANSFER) ──
                addPrItem() {
                    if (!this.newPrItem.tenHang || !this.newPrItem.tenHang.trim()) {
                        this.toast('Cảnh báo', 'Vui lòng nhập tên hàng hóa!', 'warning');
                        return;
                    }
                    if (!this.newPrItem.soLuong || this.newPrItem.soLuong <= 0) {
                        this.toast('Cảnh báo', 'Số lượng phải lớn hơn 0!', 'warning');
                        return;
                    }
                    this.form.prItems.push({
                        tenHang: this.newPrItem.tenHang.trim(),
                        donVi: this.newPrItem.donVi.trim() || 'Cái',
                        soLuong: this.newPrItem.soLuong,
                        ghiChu: this.newPrItem.ghiChu.trim()
                    });
                    this.newPrItem = { tenHang: '', donVi: '', soLuong: 1, ghiChu: '' };
                },
                removePrItem(idx) {
                    this.form.prItems.splice(idx, 1);
                },

                // ── Attachment Panel (Right) ──
                handleDrop(e) {
                    this.isDragging = false;
                    var files = e.dataTransfer.files;
                    this.processFiles(files);
                },
                handleDropInput(e) {
                    var files = e.target.files;
                    this.processFiles(files);
                    e.target.value = '';
                },
                processFiles(fileList) {
                    var skippedCount = 0;
                    for (var i = 0; i < fileList.length; i++) {
                        var file = fileList[i];
                        var isImageOrVideo = file.type.startsWith('image/') || file.type.startsWith('video/');

                        if (this.attachTab === 'image') {
                            if (isImageOrVideo) {
                                this.attachedImages.push({
                                    file: file,
                                    name: file.name,
                                    size: file.size,
                                    type: file.type,
                                    url: URL.createObjectURL(file)
                                });
                            } else {
                                skippedCount++;
                            }
                        } else if (this.attachTab === 'file') {
                            if (!isImageOrVideo) {
                                this.attachedFiles.push({
                                    file: file,
                                    name: file.name,
                                    size: file.size,
                                    type: file.type,
                                    url: URL.createObjectURL(file)
                                });
                            } else {
                                skippedCount++;
                            }
                        }
                    }

                    if (skippedCount > 0) {
                        if (this.attachTab === 'image') {
                            this.toast('Cảnh báo', 'Đã bỏ qua ' + skippedCount + ' tệp không phải là hình ảnh/video.', 'warning');
                        } else {
                            this.toast('Cảnh báo', 'Đã bỏ qua ' + skippedCount + ' tệp hình ảnh/video. Vui lòng tải chúng lên ở tab Ảnh/Video.', 'warning');
                        }
                    }
                },
                removeImage(idx) {
                    var wrapper = this.attachedImages[idx];
                    if (wrapper && wrapper.url) {
                        URL.revokeObjectURL(wrapper.url);
                    }
                    this.attachedImages.splice(idx, 1);
                },
                removeFile(idx) {
                    var wrapper = this.attachedFiles[idx];
                    if (wrapper && wrapper.url) {
                        URL.revokeObjectURL(wrapper.url);
                    }
                    this.attachedFiles.splice(idx, 1);
                },
                formatSize(bytes) {
                    if (bytes < 1024) return bytes + ' B';
                    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
                    return (bytes / 1048576).toFixed(1) + ' MB';
                },

                // ── Submit ──
                submitTicket() {
                    // Đọc lại userId từ localStorage trước khi submit (phòng trường hợp chưa load xong)
                    var userStr = localStorage.getItem('current_user');
                    if (userStr) {
                        try {
                            var cu = JSON.parse(userStr);
                            if (cu && cu.Id) this.form.userId = cu.Id;
                            if (cu && cu.FullName) this.form.creator = cu.FullName;
                        } catch (e) { /* ignore */ }
                    }

                    // RÀNG BUỘC BẮT BUỘC
                    if (!this.form.targetDepartmentId) {
                        this.toast('Cảnh báo', 'Vui lòng chọn phòng ban nhận phiếu!', 'warning');
                        return;
                    }
                    if (!this.form.reasonDetails || !this.form.reasonDetails.trim()) {
                        this.toast('Cảnh báo', 'Vui lòng nhập lý do / mục đích yêu cầu!', 'warning');
                        return;
                    }
                    if (!this.form.proposal || !this.form.proposal.trim()) {
                        this.toast('Cảnh báo', 'Vui lòng nhập đề nghị!', 'warning');
                        return;
                    }
                    // Với IMPORT/EXPORT/TRANSFER: bắt buộc ít nhất 1 dòng hàng hóa
                    if (!this.isDeviceForm && this.form.prItems.length === 0) {
                        this.toast('Cảnh báo', 'Vui lòng thêm ít nhất 1 hàng hóa vào danh sách!', 'warning');
                        return;
                    }

                    this.isSubmitting = true;
                    var senderName = this.form.creator || 'Người yêu cầu';

                    // Build note tổng hợp cho IMPORT/EXPORT/TRANSFER từ prItems
                    var prNote = this.form.reasonDetails;
                    if (!this.isDeviceForm && this.form.prItems.length > 0) {
                        var lines = this.form.prItems.map(function (it, i) {
                            return (i+1) + '. ' + it.tenHang + ' | ' + it.donVi + ' | SL: ' + it.soLuong + (it.ghiChu ? ' | ' + it.ghiChu : '');
                        });
                        prNote = '[Danh sách hàng hóa]\n' + lines.join('\n') + '\n\n[Lý do/Mục đích]\n' + this.form.reasonDetails;
                    }

                    var payload = {
                        TicketType: this.form.ticketType,
                        AssetType: this.isDeviceForm ? null : this.form.assetType,
                        Note: prNote,
                        ReasonDetails: this.form.reasonDetails,
                        Proposal: this.form.proposal,
                        UserId: this.form.userId,
                        SenderName: senderName,
                        TargetDepartmentId: this.form.targetDepartmentId,
                        Devices: this.isDeviceForm ? this.form.devices.map(function (d) {
                            return {
                                ItemName: d.itemName,
                                SerialNumber: d.serialNumber,
                                Quantity: d.quantity,
                                Note: d.note
                            };
                        }) : this.form.prItems.map(function (it) {
                            return {
                                ItemName: it.tenHang,
                                SerialNumber: '',
                                Quantity: it.soLuong,
                                Unit: it.donVi,
                                Note: it.ghiChu
                            };
                        })
                    };

                    var formData = new FormData();
                    formData.append('payload', JSON.stringify(payload));
                    // Đính kèm tất cả file (ảnh/video/tài liệu)
                    this.attachedImages.forEach(function (w) {
                        formData.append('files', w.file);
                    });
                    this.attachedFiles.forEach(function (w) {
                        formData.append('files', w.file);
                    });

                    var vm = this;
                    fetch('/CreateTicket/CreateNewTicket', {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: formData
                    })
                    .then(function (r) {
                        if (!r.ok) throw new Error('HTTP ' + r.status);
                        return r.json();
                    })
                    .then(function (res) {
                        vm.isSubmitting = false;
                        if (res.success) {
                            vm.toast('Thành công', 'Tạo phiếu ' + res.ticketCode + ' thành công!', 'success');
                            setTimeout(function () { window.location.href = '/Approvals/Index'; }, 1800);
                        } else {
                            vm.toast('Lỗi', res.message || 'Có lỗi xảy ra, vui lòng thử lại.', 'danger');
                        }
                    })
                    .catch(function (err) {
                        vm.isSubmitting = false;
                        console.error('Submit error:', err);
                        vm.toast('Lỗi mạng', 'Không thể kết nối máy chủ. Vui lòng kiểm tra lại.', 'danger');
                    });
                },

                goBack() {
                    if (confirm('Bạn có chắc chắn muốn hủy bỏ?')) window.location.href = '/Approvals/Index';
                },

                toast(title, msg, type) {
                    if (window.MedEquip && typeof window.MedEquip.toast === 'function') {
                        window.MedEquip.toast(title, msg, type);
                    } else {
                        alert(title + ': ' + msg);
                    }
                },
                toggleDropdown(e) {
                    e.stopPropagation();
                    this.isDropdownOpen = !this.isDropdownOpen;
                },
                selectAsset(item) {
                    this.newDevice.itemName = item.AssetCode;
                    this.newDevice.serialNumber = item.SerialNumber || '';
                    this.isDropdownOpen = false;
                },
                handleOutsideClick(e) {
                    if (this.isDropdownOpen) {
                        var container = this.$el.querySelector('.custom-select-container');
                        if (container && !container.contains(e.target)) {
                            this.isDropdownOpen = false;
                        }
                    }

                    // just added
                },
                parseEarlyParams() {
                    var params = new URLSearchParams(window.location.search);
                    var tType = params.get('ticketType');
                    var aType = params.get('assetType');
                    if (tType) {
                        var matchType = this.listLoaiYeuCau.find(function (x) {
                            return x.value === tType;
                        });
                        if (matchType) {
                            this.form.ticketType = matchType.value;
                        }
                    }
                    if (aType) {
                        var matchAsset = this.listLoaiVatTu.find(function (x) {
                            return x.toLowerCase() === aType.toLowerCase();
                        });
                        if (matchAsset) {
                            this.form.assetType = matchAsset;
                        }
                    }
                },
                addDeviceFromUrlParams() {
                    var params = new URLSearchParams(window.location.search);
                    var aCode = params.get('assetCode');
                    if (aCode && (this.form.ticketType === 'REPAIR' || this.form.ticketType === 'SUPPORT')) {
                        var asset = this.inventoryAssets.find(function (x) {
                            return x.AssetCode && x.AssetCode.toLowerCase() === aCode.trim().toLowerCase();
                        });
                        if (asset) {
                            var exists = this.form.devices.find(function (d) {
                                return d.itemName.toLowerCase() === asset.AssetCode.toLowerCase();
                            });
                            if (!exists) {
                                this.form.devices.push({
                                    itemName: asset.AssetCode,
                                    serialNumber: asset.SerialNumber || '',
                                    quantity: 1,
                                    unit: 'Cái',
                                    note: 'Thêm từ QR Code'
                                });
                            }
                        }
                    }

                }
            },
            watch: {
                'form.ticketType': function (newVal) {
                    // Reset form khi đổi loại yêu cầu
                    this.form.assetType = '';
                    this.form.reasonDetails = '';
                    this.form.proposal = '';
                    if (newVal === 'SUPPORT' || newVal === 'REPAIR') {
                        this.form.prItems = [];
                    } else {
                        this.form.devices = [];
                    }
                },
                'newDevice.itemName': function (newVal) {
                    if (!newVal) {
                        this.newDevice.serialNumber = '';
                        return;
                    }
                    var match = this.inventoryAssets.find(function (x) {
                        return x.AssetCode === newVal;
                    });
                    if (match) {
                        this.newDevice.serialNumber = match.SerialNumber || '';
                    } else {
                        this.newDevice.serialNumber = '';
                    }
                },
                'searchQuery': function (newVal) {
                    if (!newVal) {
                        return;
                    }
                    var query = newVal.trim().toLowerCase();
                    var match = this.inventoryAssets.find(function (x) {
                        return x.AssetCode && x.AssetCode.toLowerCase() === query;
                    });
                    if (match) {
                        this.newDevice.itemName = match.AssetCode;
                    } else {
                        var filtered = this.filteredInventoryAssets;
                        if (filtered && filtered.length === 1) {
                            this.newDevice.itemName = filtered[0].AssetCode;
                        }
                    }
                }
            },

            mounted() {
                // Đọc thông tin người dùng đăng nhập từ localStorage
                var userStr = localStorage.getItem('current_user');
                if (userStr) {
                    try {
                        var currentUser = JSON.parse(userStr);
                        if (currentUser && currentUser.Id) {
                            this.form.userId = currentUser.Id;
                            this.loadUserInfo(currentUser.Id);
                        } else {
                            this.loadUserInfo(1); // Mặc định nếu không có Id
                        }
                    } catch (e) {
                        this.loadUserInfo(1);
                    }
                } else {
                    this.loadUserInfo(1); // Mặc định
                }

                // Tải danh mục thiết bị
                this.loadDepartments();
                this.loadDbItems();
                this.loadInventoryAssets();
                document.addEventListener('click', this.handleOutsideClick);

                //just added
                this.parseEarlyParams();
            },
            beforeDestroy() {
                document.removeEventListener('click', this.handleOutsideClick);
                this.attachedImages.forEach(function (w) { if (w.url) URL.revokeObjectURL(w.url); });
                this.attachedFiles.forEach(function (w) { if (w.url) URL.revokeObjectURL(w.url); });
            }
        });
    </script>
}
