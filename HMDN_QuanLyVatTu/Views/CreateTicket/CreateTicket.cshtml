                    <span class="c-title" style="white-space: nowrap;">Đính kèm <span style="color: var(--hm-text-sec); font-size: 13px; font-weight: normal;">(Không bắt buộc)</span></span>
                </div>
                <!-- Tabs -->
                <div class="attach-tabs">
                    <div :class="['attach-tab', attachTab === 'image' ? 'active' : '']" @@click="attachTab='image'">
                        <i class="fa-regular fa-image"></i>Ảnh/Video
                    </div>
                    <div :class="['attach-tab', attachTab === 'file' ? 'active' : '']" @@click="attachTab='file'">
                        <i class="fa-regular fa-file"></i>File
                    </div>
                </div>
                <!-- Drop Zone -->
                <div class="drop-zone"
                     :class="{ 'drag-over': isDragging }"
                     @@click="$refs.dropInput.click()"
                     @@dragover.prevent="isDragging = true"
                     @@dragleave.prevent="isDragging = false"
                     @@drop.prevent="handleDrop">
                    <i class="fa-solid fa-cloud-arrow-up drop-icon"></i>
                    <span class="drop-text">Tải tệp lên hoặc kéo thả</span>
                    <span class="drop-hint" v-if="attachTab === 'image'">Chỉ tải lên Ảnh, Video (PNG, JPG, MP4)</span>
                    <span class="drop-hint" v-else>Chỉ tải lên Tài liệu (PDF, DOCX, XLSX, TXT, ZIP)</span>
