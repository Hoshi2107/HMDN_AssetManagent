                <!-- File lists filtered by active tab -->
                <!-- Image list (Grid Preview) -->
                <div class="preview-grid" v-if="attachTab === 'image' && attachedImages.length > 0" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 12px; margin-top: 15px;">
