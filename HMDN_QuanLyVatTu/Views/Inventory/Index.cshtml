@{
    ViewBag.Title = "Inventory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/inventory/inventory.css" rel="stylesheet" />

<div id="app">


    <!-- MAIN -->
    <div class="main-wrap">

        <!-- TOPBAR -->
        <header class="topbar">

            <div class="topbar-search">
                <input type="text"
                       placeholder="Tìm thiết bị..."
                       v-model="searchQuery">
            </div>

            <div class="topbar-actions">

                <button class="btn-secondary"
                        @@click="openQrModal()">
                    Check QR

                    @*<div class="icon">📷</div>

                <h4>Quét QR</h4>

                <p>Check nhanh bằng mã QR</p>*@

                </button>

                <button class="btn-primary"
                        v-if="hasPermission('Inventory', 'CREATE')"
                        @@click="showAddOptionModal = true">

                    Thêm thiết bị

                </button>

            </div>

        </header>

        <!-- CONTENT -->
        <main class="page-content">

            <div class="page-header">

                @*<div>
                <h2>Danh sách thiết bị</h2>
                <p>Quản lý kho thiết bị y tế</p>
            </div>*@


            </div>

            <!-- FILTER -->
            <div class="filter-bar">

                <!-- Filter theo vị trí -->
                <select v-model="filterLoca">
                    <option value="">Tất cả vị trí</option>

                    <option v-for="loc in locations" :key="loc" :value="loc">
                        ${ loc }
                    </option>
                </select>

                <!-- Filter theo loại tài sản -->
                <select v-model="filterGroup">

                    <option value="">
                        Tất cả loại tài sản
                    </option>

                    <option v-for="g in groups"
                            :key="g"
                            :value="g">

                        ${ g }

                    </option>

                </select>

                <!-- Filter theo trạng thái -->
                <select v-model="filterStatus">
                    <option value="">Tất cả trạng thái</option>

                    <option v-for="stat in status" :key="stat" :value="stat">
                        @*${ stat }*@
                        ${ statusLabel(stat) }
                    </option>
                </select>

                <!-- Filter theo record -->
                <select v-model="pageSize">
                    <option :value="10">10</option>
                    <option :value="15">15</option>
                    <option :value="20">20</option>
                    <option :value="50">50</option>
                </select>

            </div>

            <!-- TABLE -->
            <div class="table-card">

                <table>

                    <thead>
                        <tr>
                            <th @@click="sortBy('id')">Mã</th>
                            <th>Tên</th>
                            <th>Model</th>
                            <th>Serial</th>
                            <th>Khoa</th>
                            <th>Phiếu</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr v-for="item in paginatedDevices"
                            :key="item.Id"
                            @@click="openDetail(item.Id)"
                            class="table-row">

                            <td>${ item.Id }</td>

                            <td>${ item.ItemName  || '—' }</td>

                            <td>${ item.Model || '—' }</td>

                            <td>${ item.SerialNumber  || '—' }</td>

                            <td>${ item.DepartmentName  || 'Chưa được xếp' }</td>

                            <td>${ item.TicketCode || '—' }</td>

                            <td @@click.stop>

                                <select class="status-dropdown"
                                        :disabled="!hasPermission('Inventory', 'EDIT')"
                                        v-model="item.LifeStatus"
                                        @@change="changeStatus(item)">

                                    <option value="active">
                                        Đang hoạt động
                                    </option>

                                    @*<option value="maintenance_bv">
                                        BV bảo trì
                                    </option>

                                    <option value="maintenance_hang">
                                        Hãng bảo hành
                                    </option>

                                    <option value="Send_for_warranty">
                                        Gửi về bảo hành
                                    </option>*@

                                    <!-- suspended KHÔNG CHO CHỌN -->
                                    <option v-if="item.LifeStatus == 'suspended'"
                                            value="suspended">

                                        Tạm ngưng

                                    </option>

                                </select>

                            </td>

                        </tr>

                    </tbody>

                </table>

                <!-- Modal -->
                <div class="modal-overlay"
                     v-if="showModal"
                     @@click.self="showModal = false">

                    <div class="device-modal">

                        <div class="modal-header">

                            @*<h3>
                    Chi tiết thiết bị
                </h3>

                <button class="close-btn"
                        @@click="showModal = false">

                    ×
                </button>*@

                            <div class="detail-tabs">

                                <button :class="{active: activeTab === 'detail'}"
                                        @@click="activeTab='detail'">

                                    Chi tiết thiết bị

                                </button>

                                <button :class="{active: activeTab === 'history'}"
                                        @@click="loadMaintenanceHistory(selectedDevice.Id)">

                                    Hồ sơ bệnh án

                                </button>

                                <div class="tab-indicator"
                                     :class="activeTab">
                                </div>

                            </div>

                        </div>

                        <div class="modal-body"
                             v-if="selectedDevice">

                            <div v-if="activeTab==='detail'">
                                <div class="detail-grid">

                                    <div>
                                        <label>Mã tài sản</label>
                                        <p>${ selectedDevice.AssetCode }</p>
                                    </div>

                                    <div>
                                        <label>Tên thiết bị</label>
                                        <p>${ selectedDevice.ItemName }</p>
                                    </div>

                                    <div>
                                        <label>Serial</label>
                                        <p>${ selectedDevice.SerialNumber }</p>
                                    </div>

                                    <div>
                                        <label>Hãng</label>
                                        <p>${ selectedDevice.Brand }</p>
                                    </div>

                                    <div>
                                        <label>Model</label>
                                        <p>${ selectedDevice.Model }</p>
                                    </div>

                                    <div>
                                        <label>Khoa</label>
                                        <p>${ selectedDevice.DepartmentName }</p>
                                    </div>

                                    <div>
                                        <label>Vị trí</label>
                                        <p>${ selectedDevice.LocationName }</p>
                                    </div>

                                    <div>
                                        <label>Tầng</label>
                                        <p>${ selectedDevice.Floor }</p>
                                    </div>

                                    <div>
                                        <label>Tòa nhà</label>
                                        <p>${ selectedDevice.Building }</p>
                                    </div>

                                    <div>
                                        <label>Trạng thái</label>

                                        @*<span :class="statusClass(selectedDevice.LifeStatus)">
                                ${ statusLabel(selectedDevice.LifeStatus) }
                            </span>*@

                                        <span style="padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;display:inline-flex;align-items:center;gap:6px"
                                              :style="{background:getLifeStatusMeta(selectedDevice.LifeStatus).bg,color:getLifeStatusMeta(selectedDevice.LifeStatus).color}">

                                            ${ getLifeStatusMeta(selectedDevice.LifeStatus).icon }

                                            ${ getLifeStatusMeta(selectedDevice.LifeStatus).text }

                                        </span>
                                    </div>

                                    <div>
                                        <label>Giá trị</label>
                                        <p>
                                            ${ selectedDevice.TotalPrice }
                                        </p>
                                    </div>

                                    <div>
                                        <label>Phiếu</label>
                                        <p>${ selectedDevice.TicketCode }</p>
                                    </div>

                                    <div>
                                        <label>Năm sản xuất</label>
                                        <p>${ selectedDevice.YearManufactured || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Năm hoạt động</label>
                                        <p>${ selectedDevice.YearInUse || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Năm sử dụng</label>
                                        <p>${ selectedDevice.UsageYears || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Phân loại</label>
                                        <p>${ selectedDevice.AssetCategory || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Mã tập đoàn</label>
                                        <p>${ selectedDevice.GroupAssetCode || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Mã kế toán</label>
                                        <p>${ selectedDevice.AccountingCode || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Mã bảo hiểm</label>
                                        <p>${ selectedDevice.InsuranceCode || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Nước sản xuất</label>
                                        <p>${ selectedDevice.CountryManufactured || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Nhà sản xuất</label>
                                        <p>${ selectedDevice.Manufacturer || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Nhà cung cấp</label>
                                        <p>${ selectedDevice.SupplierName || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Ngày nhập</label>
                                        <p>${ selectedDevice.ImportDate || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Hết bảo hành</label>
                                        <p>${ selectedDevice.WarrantyExpiry || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Khấu hao (%)</label>
                                        <p>${ selectedDevice.DepreciationRate || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Số năm khấu hao</label>
                                        <p>${ selectedDevice.DepreciationYears || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Giá trị còn lại</label>
                                        <p>${ selectedDevice.ResidualValue || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Người tạo</label>
                                        <p>${ selectedDevice.CreatedByName || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Người duyệt</label>
                                        <p>${ selectedDevice.ApprovedByName || '—' }</p>
                                    </div>

                                    <div>
                                        <label>Ngày tạo</label>
                                        <p>${ selectedDevice.CreatedAt || '—' }</p>
                                    </div>

                                </div>

                                <div class="note-box">

                                    <label>Ghi chú</label>

                                    <p>
                                        ${ selectedDevice.Note || 'Không có ghi chú' }
                                    </p>

                                </div>

                                <div class="action-group">

                                    <div class="action-group">

                                        <button class="btn-primary"
                                                v-if="hasPermission('Inventory', 'EDIT')"
                                                @@click="openEditModal(selectedDevice.Id)">
                                            Sửa
                                        </button>

                                        <button class="btn-danger"
                                                v-if="hasPermission('Inventory', 'EDIT')"
                                                :disabled="selectedDevice.LifeStatus == 'suspended'"
                                                @@click="openSuspendModal(selectedDevice)">
                                            Check có lỗi
                                        </button>

                                    </div>

                                </div>
                            </div>

                            <!-- History -->
                            <div v-if="activeTab==='history'"
                                 class="medical-history">

                                <div v-if="maintenanceHistory.length == 0"
                                     class="empty-state">

                                    Chưa có lịch sử sửa chữa

                                </div>

                                <div v-for="record in maintenanceHistory"
                                     :key="record.Id"
                                     class="history-card">

                                    <h4>
                                        ${ record.Title || 'Không có dữ liệu' }
                                    </h4>

                                    <div class="history-info">

                                        <div>
                                            <span>Loại sửa chữa</span>
                                            <strong>
                                                ${ record.MaintenanceType || 'Không có dữ liệu' }
                                            </strong>
                                        </div>

                                        <hr>

                                        <div>
                                            <span>Ngày bắt đầu</span>
                                            <strong>
                                                ${ record.StartDate || 'Không có dữ liệu' }
                                            </strong>
                                        </div>

                                        <hr>

                                        <div>
                                            <span>Ngày kết thúc</span>
                                            <strong>
                                                ${ record.EndDate || 'Không có dữ liệu' }
                                            </strong>
                                        </div>

                                        <hr>

                                        <div>
                                            <span>Chi phí</span>
                                            <strong>
                                                ${ record.Cost || 'Không có dữ liệu' }
                                            </strong>
                                        </div>

                                        <hr>

                                        <div>
                                            <span>Đơn vị sửa</span>
                                            <strong>
                                                ${ record.Vendor || 'Không có dữ liệu' }
                                            </strong>
                                        </div>

                                    </div>

                                    <div class="history-actions">

                                        <button class="btn-primary"
                                                @@click="openHistoryDetail(record)">
                                            Chi tiết
                                        </button>

                                    </div>

                                </div>

                            </div>
                        </div>

                    </div>


                    <!-- History Detail -->
                    <div class="modal-overlay"
                         v-if="showHistoryDetail"
                         @@click.self="showHistoryDetail=false">

                        <div class="device-modal large-modal">

                            <div class="modal-header">

                                <h3>Chi tiết hồ sơ bệnh án</h3>

                                <button class="close-btn"
                                        @@click="showHistoryDetail=false">
                                    ×
                                </button>

                            </div>

                            <div class="modal-body"
                                 v-if="selectedHistory">

                                <table class="history-detail-table">

                                    <tr>
                                        <th>ID</th>
                                        <td>${ selectedHistory.Id ?? 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Loại sửa chữa</th>
                                        <td>${ selectedHistory.MaintenanceType || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Tiêu đề</th>
                                        <td>${ selectedHistory.Title || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Mô tả</th>
                                        <td>${ selectedHistory.Description || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Mô tả lỗi</th>
                                        <td>${ selectedHistory.ErrorDescription || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Biện pháp xử lý</th>
                                        <td>${ selectedHistory.ActionTaken || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Linh kiện thay thế</th>
                                        <td>${ selectedHistory.PartReplaced || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Chi phí</th>
                                        <td>${ selectedHistory.Cost || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Đơn vị sửa chữa</th>
                                        <td>${ selectedHistory.Vendor || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Ngày bắt đầu</th>
                                        <td>${ selectedHistory.StartDate || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Ngày kết thúc</th>
                                        <td>${ selectedHistory.EndDate || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Trạng thái</th>
                                        <td>${ selectedHistory.Status || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Mức độ ưu tiên</th>
                                        <td>${ selectedHistory.Priority || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Người báo lỗi</th>
                                        <td>${ selectedHistory.ReportedBy || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Người xử lý</th>
                                        <td>${ selectedHistory.AssignedTo || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Người đóng</th>
                                        <td>${ selectedHistory.ClosedBy || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Ngày đóng</th>
                                        <td>${ selectedHistory.ClosedAt || 'Không có dữ liệu' }</td>
                                    </tr>

                                    <tr>
                                        <th>Repair Status</th>
                                        <td>${ selectedHistory.RepairStatus || 'Không có dữ liệu' }</td>
                                    </tr>

                                </table>

                            </div>

                        </div>

                    </div>

                    <!-- MODAL CHECK LỖI -->
                    <div class="modal-overlay"
                         v-if="showSuspendModal"
                         @@click.self="showSuspendModal = false">

                        <div class="device-modal small-modal">

                            <div class="modal-header">
                                <h3>Check lỗi thiết bị</h3>

                                <button class="close-btn"
                                        @@click="showSuspendModal = false">
                                    ×
                                </button>
                            </div>

                            <div class="modal-body">

                                <div class="form-group">
                                    <label>Lý do lỗi</label>

                                    <textarea v-model="suspendReason"
                                              rows="5"
                                              placeholder="Nhập lý do lỗi thiết bị..."
                                              class="form-textarea">
                                    </textarea>
                                </div>

                                <div class="modal-actions">

                                    <button class="btn-secondary"
                                            @@click="showSuspendModal = false">
                                        Hủy
                                    </button>

                                    <button class="btn-danger"
                                            @@click="submitSuspend()">
                                        Xác nhận tạm ngưng
                                    </button>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>


            </div>
            <div class="pagination">

                <button @@click="prevPage"
                        :disabled="currentPage == 1">

                    Prev
                </button>

                <button v-for="page in pages"
                        :key="page"
                        @@click="changePage(page)"
                        :class="{ active: currentPage == page }">

                    ${ page }
                </button>

                <button @@click="nextPage"
                        :disabled="currentPage == totalPages">

                    Next
                </button>

            </div>

            <!-- MODAL CHỌN KIỂU THÊM -->
            <div class="modal-overlay"
                 v-if="showAddOptionModal"
                 @@click.self="showAddOptionModal = false">

                <div class="device-modal small-modal">

                    <div class="modal-header">

                        <h3>Chọn cách thêm thiết bị</h3>

                        <button class="close-btn"
                                @@click="showAddOptionModal = false">

                            ×

                        </button>

                    </div>

                    <div class="modal-body">

                        <div class="add-option-grid">

                            <button class="add-option-card"
                                    @@click="openAddWithExcelModal()">

                                <div class="icon">📁</div>

                                <h4>Thêm bằng excel</h4>

                                <p>Thêm nhanh bằng excel</p>

                            </button>

                            <button class="add-option-card"
                                    @@click="openManualModal()">

                                <div class="icon">⌨️</div>

                                <h4>Manual</h4>

                                <p>Nhập thông tin thủ công</p>

                            </button>

                        </div>

                    </div>

                </div>

            </div>

            <!-- MODAL QR -->
            <div class="modal-overlay"
                 v-if="showQrModal"
                 @@click.self="showQrModal = false">

                <div class="device-modal">

                    <div class="modal-header">

                        <h3>Quét QR thiết bị</h3>

                        <button class="close-btn"
                                @@click="showQrModal = false">

                            ×

                        </button>

                    </div>

                    <div class="modal-body">

                        <div class="qr-box">

                            Camera scan QR ở đây

                        </div>

                    </div>

                </div>

            </div>

            <!-- MODAL MANUAL -->
            <div class="modal-overlay"
                 v-if="showManualModal"
                 @@click.self="showManualModal = false">

                <div class="device-modal large-modal">

                    <!-- HEADER -->
                    <div class="modal-header">

                        <h3>Thêm thiết bị thủ công</h3>

                        <button class="close-btn"
                                @@click="showManualModal = false">
                            ×
                        </button>

                    </div>

                    <!-- BODY -->
                    <div class="modal-body">

                        <div class="detail-grid">

                            <!-- Asset Code -->
                            <div class="form-group">

                                <label>Mã tài sản</label>

                                <input type="text"
                                       class="form-control"
                                       v-model="createForm.AssetCode">

                            </div>

                            <!-- Item -->
                            <div class="form-group">

                                <label>Thiết bị</label>

                                <select class="form-control"
                                        v-model="createForm.ItemId">

                                    <option value="">
                                        Chọn thiết bị
                                    </option>

                                    <option v-for="item in items"
                                            :key="item.Id"
                                            :value="item.Id">

                                        ${ item.Name }

                                    </option>

                                </select>

                            </div>

                            <!-- Serial -->
                            <div class="form-group">

                                <label>Serial Number</label>

                                <input type="text"
                                       class="form-control"
                                       v-model="createForm.SerialNumber">

                            </div>

                            <!-- Quantity -->
                            <div class="form-group">

                                <label>Số lượng</label>

                                <input type="number"
                                       class="form-control"
                                       v-model="createForm.Quantity">

                            </div>

                            <!-- Department -->
                            <div class="form-group">

                                <label>Khoa</label>

                                <select class="form-control"
                                        v-model="createForm.DepartmentId">

                                    <option value="">
                                        Chọn khoa
                                    </option>

                                    <option v-for="dep in departments"
                                            :key="dep.Id"
                                            :value="dep.Id">

                                        ${ dep.Name }

                                    </option>

                                </select>

                            </div>

                            <!-- Location -->
                            <div class="form-group">

                                <label>Vị trí</label>

                                <select class="form-control"
                                        v-model="createForm.LocationId">

                                    <option value="">
                                        Chọn vị trí
                                    </option>

                                    <option v-for="loc in locationsData"
                                            :key="loc.Id"
                                            :value="loc.Id">

                                        ${ loc.Name }

                                    </option>

                                </select>

                            </div>

                            <!-- Import Date -->
                            <div class="form-group">

                                <label>Ngày nhập</label>

                                <input type="date"
                                       class="form-control"
                                       v-model="createForm.ImportDate">

                            </div>

                            <!-- Expiry -->
                            <div class="form-group">

                                <label>Ngày hết hạn</label>

                                <input type="date"
                                       class="form-control"
                                       v-model="createForm.ExpiryDate">

                            </div>

                            <!-- Warranty -->
                            <div class="form-group">

                                <label>Hết bảo hành</label>

                                <input type="date"
                                       class="form-control"
                                       v-model="createForm.WarrantyExpiry">

                            </div>

                            <!-- Unit Price -->
                            <div class="form-group">

                                <label>Đơn giá</label>

                                <input type="number"
                                       class="form-control"
                                       v-model="createForm.UnitPrice">

                            </div>

                            <!-- Ticket -->
                            <div class="form-group">

                                <label>Phiếu</label>

                                <select class="form-control"
                                        v-model="createForm.IdTicket">

                                    <option :value="null">
                                        Không có
                                    </option>

                                    <option v-for="ticket in tickets"
                                            :key="ticket.Id"
                                            :value="ticket.Id">

                                        ${ ticket.TicketCode }

                                    </option>

                                </select>

                            </div>

                            <!-- Check Cycle -->
                            @*<div class="form-group">

                            <label>Chu kỳ kiểm tra</label>

                            <input type="number"
                                   class="form-control"
                                   v-model="createForm.CheckCycleId">

