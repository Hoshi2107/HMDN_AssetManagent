                            <label>Chu kỳ (tháng)</label>
                            <input type="number" class="form-control" min="1"
                                   v-model="scheduleForm.RecurringMonths">
                        </div>

                    </div>

                    <div class="modal-actions" style="margin-top:12px">
                        <button class="btn-primary" @@click="saveSchedule()">
                            Lưu lịch
                        </button>
                    </div>
                </div>

                <!-- ─── DANH SÁCH LỊCH HIỆN TẠI ──────────── -->
                <h4 style="font-size:14px;color:#334155;margin-bottom:12px">
                    📋 Danh sách lịch bảo trì (${ maintenanceSchedules.length })
                </h4>

                <div v-if="maintenanceSchedules.length === 0"
                     style="text-align:center;color:#94a3b8;padding:30px">
                    Chưa có lịch bảo trì nào
                </div>

                <div v-for="s in maintenanceSchedules"
                     :key="s.Id"
                     style="border:1px solid #e2e8f0;border-radius:8px;padding:14px;
                        margin-bottom:10px;display:flex;justify-content:space-between;
                        align-items:flex-start;gap:12px">

                    <!-- Thông tin -->
                    <div style="flex:1">
                        <div style="font-weight:600;font-size:14px;color:#1e293b;margin-bottom:4px">
                            ${ s.ScheduleName }
                        </div>
                        <div style="font-size:12px;color:#64748b">
                            Loại: <strong>${ s.MaintenanceType }</strong> &nbsp;|&nbsp;
                            Ngày BT: <strong>${ s.NextMaintenanceDate ? s.NextMaintenanceDate.substring(0,10) : '—' }</strong> &nbsp;|&nbsp;
                            Nhắc trước: <strong>${ s.ReminderDays } ngày</strong>
                            <span v-if="s.IsRecurring">
                                &nbsp;|&nbsp; Lặp mỗi <strong>${ s.RecurringMonths } tháng</strong>
                            </span>
                        </div>
                    </div>

                    <!-- Badge ngày còn lại -->
                    <div style="text-align:center;white-space:nowrap">
                        <span style="padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600"
                              :style="{
                            background: getUrgencyMeta(s.DaysUntilDue).bg,
                            color:      getUrgencyMeta(s.DaysUntilDue).color
                          }">
                            ${ getUrgencyMeta(s.DaysUntilDue).text }
                        </span>
                        <div style="font-size:11px;color:#94a3b8;margin-top:4px">còn lại</div>
                    </div>

                    <!-- Xóa -->
                    <button class="btn-danger"
                            style="padding:4px 10px;font-size:12px"
                            @@click="deleteSchedule(s.Id)">
                        Xóa
                    </button>

                </div>

            </div>
        </div>
    </div>

    <!-- MODAL THAY THẾ TÀI SẢN (Replace Device Modal) -->
    <div class="modal-overlay replace-modal-overlay"
         v-if="showReplaceModal"
         @@click.self="showReplaceModal = false">
        <div class="device-modal replace-modal">
            <div class="modal-header replace-modal-header">
                <div>
                    <h3>🔁 Thay thế tài sản</h3>
                    <p style="margin:4px 0 0;font-size:13px;color:#94a3b8">
                        Thay thế cho: <strong style="color:#f59e0b">${ selectedDevice ? selectedDevice.AssetCode : '' }</strong>
                        <span style="padding:2px 8px;border-radius:12px;font-size:11px;background:#fee2e2;color:#dc2626;margin-left:8px">
                            ${ selectedDevice ? getLifeStatusMeta(selectedDevice.LifeStatus).text : '' }
                        </span>
                    </p>
                </div>
                <button class="close-btn" @@click="showReplaceModal = false">×</button>
            </div>
            <div class="modal-body">
                <!-- Loading state -->
                <div v-if="replaceLoading"
                     style="text-align:center;padding:40px;color:#94a3b8">
                    ⏳ Đang tải danh sách...
                </div>
                <div v-else>
                    <!-- Empty state -->
                    <div v-if="replaceableDevices.length === 0"
                         class="replace-empty-state">
                        <div style="font-size:48px;margin-bottom:12px">📦</div>
                        <p style="color:#64748b;font-size:14px">Không có tài sản cùng loại nào đang hoạt động và chưa được xếp phòng ban.</p>
                    </div>
                    <div v-else>
                        <p style="font-size:13px;color:#475569;margin-bottom:14px">
                            Chọn tài sản thay thế: (đang active, chưa có phòng ban)
                        </p>
                        <!-- Danh sách tài sản thay thế -->
                        <div class="replace-device-list">
                            <div v-for="dev in replaceableDevices"
                                 :key="dev.Id"
                                 class="replace-device-card"
                                 :class="{ selected: selectedReplaceId === dev.Id }"
                                 @@click="selectedReplaceId = dev.Id">
                                <div class="replace-card-radio">
                                    <input type="radio"
                                           :value="dev.Id"
                                           v-model="selectedReplaceId"
                                           @@click.stop>
                                </div>
                                <div class="replace-card-info">
                                    <div class="replace-card-name">
                                        ${ dev.ItemName }
                                    </div>
                                    <div class="replace-card-meta">
                                        <span>🏷️ ${ dev.AssetCode }</span>
                                        <span v-if="dev.SerialNumber"> | Serial: ${ dev.SerialNumber }</span>
                                        <span v-if="dev.Model"> | ${ dev.Model }</span>
                                    </div>
                                </div>
                                <span class="replace-status-badge">
                                    🟢 Đang hoạt động
                                </span>
                            </div>
                        </div>
                        <!-- Ghi chú thay thế -->
                        <div class="form-group" style="margin-top:18px">
                            <label style="font-size:13px;font-weight:600;color:#374151">Ghi chú lý do thay thế</label>
                            <textarea class="form-control"
                                      rows="3"
                                      placeholder="VD: Thay thế do tài sản cũ hư hỏng nặng, không sửa được..."
                                      v-model="replaceNote">
                        </textarea>
                        </div>
                        <!-- Actions -->
                        <div class="modal-actions" style="margin-top:16px">
                            <button class="btn-secondary" @@click="showReplaceModal = false">
                                Hủy
                            </button>
                            <button class="btn-replace-confirm"
                                    :disabled="!selectedReplaceId"
                                    @@click="confirmReplace()">
                                ✅ Xác nhận thay thế
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>


<script src="~/Scripts/app/inventory.js"></script>