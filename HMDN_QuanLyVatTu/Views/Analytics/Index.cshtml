@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="@Url.Content("~/Content/analytics/analytics-module.css")" />

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>

<div id="analytics-module-hub" class="container-fluid" v-cloak>

    <!-- Hệ thống Grid KPI 5 cột tự động căn chỉnh và responsive -->
    <div class="kpi-grid">
        <!-- KPI 1: Tổng tài sản -->
        <div class="card p-3 border-0 d-flex flex-row align-items-center justify-content-between bg-kpi-total kpi-card-clickable" v-on:click="showDevicesByStatus('all')">
            <div>
                <small class="text-uppercase text-white-muted card-kpi-title">Tổng tài sản thiết bị</small>
                <h2 class="mt-1 mb-0 font-weight-bold text-white" v-text="dashboardMetrics.total || 0"></h2>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center kpi-icon-box">
                <i class="fa-solid fa-boxes-stacked text-white"></i>
            </div>
        </div>

        <!-- KPI 2: Đang hoạt động tốt -->
        <div class="card p-3 border-0 d-flex flex-row align-items-center justify-content-between bg-kpi-active kpi-card-clickable" v-on:click="showDevicesByStatus('active')">
            <div>
                <small class="text-uppercase text-white-muted card-kpi-title">Đang chạy tốt</small>
                <h2 class="mt-1 mb-0 font-weight-bold text-white">
                    {{ dashboardMetrics.active || 0 }}
                    <span class="kpi-percentage" v-if="dashboardMetrics.activePercent !== undefined">({{ formatPercent(dashboardMetrics.activePercent) }}%)</span>
                </h2>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center kpi-icon-box">
                <i class="fa-solid fa-square-check text-white"></i>
            </div>
        </div>

        <!-- KPI 3: Thiết bị báo hỏng -->
        <div class="card p-3 border-0 d-flex flex-row align-items-center justify-content-between bg-kpi-broken kpi-card-clickable" v-on:click="showDevicesByStatus('suspended')">
            <div>
                <small class="text-uppercase text-white-muted card-kpi-title">Thiết bị báo hỏng</small>
                <h2 class="mt-1 mb-0 font-weight-bold text-white">
                    {{ dashboardMetrics.broken || 0 }}
                    <span class="kpi-percentage" v-if="dashboardMetrics.brokenPercent !== undefined">({{ formatPercent(dashboardMetrics.brokenPercent) }}%)</span>
                </h2>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center kpi-icon-box">
                <i class="fa-solid fa-circle-exclamation text-white"></i>
            </div>
        </div>

        <!-- KPI 4: Đang bảo trì -->
        <div class="card p-3 border-0 d-flex flex-row align-items-center justify-content-between bg-kpi-maint kpi-card-clickable" v-on:click="showDevicesByStatus('maintenance')">
            <div>
                <small class="text-uppercase text-white-muted card-kpi-title">Thiết bị bảo trì</small>
                <h2 class="mt-1 mb-0 font-weight-bold text-white">
                    {{ dashboardMetrics.totalMaint || 0 }}
                    <small style="font-size: 13px;" class="text-white">máy</small>
                </h2>
                <div class="mt-1 text-white-muted" style="font-size: 11px; line-height: 1.3;">
                    <span v-on:click.stop="showDevicesByStatus('maintenance_bv')" class="kpi-sub-link">BV tự sửa: <strong>{{ dashboardMetrics.maintBv || 0 }}</strong></span> | 
                    <span v-on:click.stop="showDevicesByStatus('maintenance_hang')" class="kpi-sub-link">Hãng sửa: <strong>{{ dashboardMetrics.maintHang || 0 }}</strong></span>
                </div>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center kpi-icon-box">
                <i class="fa-solid fa-screwdriver-wrench text-white"></i>
            </div>
        </div>

        <!-- KPI 5: Tổng giá trị tài sản y tế (Mới bổ sung) -->
        <div class="card p-3 border-0 d-flex flex-row align-items-center justify-content-between bg-kpi-value">
            <div>
                <small class="text-uppercase text-white-muted card-kpi-title">Tổng giá trị tài sản</small>
                <h3 class="mt-2 mb-0 font-weight-bold text-white" style="font-size: 17px; letter-spacing: -0.2px;">
                    {{ formatMoney(dashboardMetrics.totalValue) }}
                    <small style="font-size: 11.5px;" class="text-white-muted">VNĐ</small>
                </h3>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center kpi-icon-box">
                <i class="fa-solid fa-money-bill-wave text-white"></i>
            </div>
        </div>

        <!-- KPI 6: Tỷ lệ tuân thủ Checklist (Mới bổ sung tiện ích) -->
        <div class="card p-3 border-0 d-flex flex-row align-items-center justify-content-between bg-kpi-compliance kpi-card-clickable" v-on:click="goToChecklists()">
            <div>
                <small class="text-uppercase text-white-muted card-kpi-title">Tuân thủ Checklist ({{ checklistRangeText }})</small>
                <h2 class="mt-1 mb-0 font-weight-bold text-white">
                    {{ checklistCompliance }}%
                </h2>
                <div class="mt-1 text-white-muted" style="font-size: 11px; line-height: 1.3;">
                    Xong: <strong>{{ checklistProgress.done }}</strong> / Tổng: <strong>{{ checklistProgress.total }}</strong>
                </div>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center kpi-icon-box">
                <i class="fa-solid fa-clipboard-check text-white"></i>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <!-- Đồ thị 1: Tỉ lệ thiết bị hoạt động -->
        <div class="col-12 col-md-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm bg-white h-100">
                <h6 class="font-weight-bold text-dark mb-3"><i class="fa-solid fa-chart-pie mr-2 text-info"></i>Tỉ lệ thiết bị hoạt động</h6>
                <div class="position-relative d-flex align-items-center justify-content-center chart-container">
                    <canvas id="statusPieChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Đồ thị 2: Tiến độ Checklist -->
        <div class="col-12 col-md-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm bg-white h-100">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="font-weight-bold text-dark m-0"><i class="fa-solid fa-list-check mr-2 text-success"></i>Tiến độ Checklist</h6>
                    <select class="form-control form-control-sm border" v-model="checklistRange" v-on:change="fetchTodayChecklistData" style="width: auto; height: 28px; padding: 2px 8px; font-size: 11.5px; font-weight: 600; border-radius: 6px; color: #475569;">
                        <option value="today">Hôm nay</option>
                        <option value="week">Tuần này</option>
                        <option value="month">Tháng này</option>
                        <option value="quarter">Quý này</option>
                        <option value="year">Năm nay</option>
                    </select>
                </div>
                <div class="position-relative d-flex align-items-center justify-content-center chart-container">
                    <canvas id="todayChecklistChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Đồ thị 3: Tần suất bảo trì -->
        <div class="col-12 col-xl-6 mb-3">
            <div class="card p-3 border-0 shadow-sm bg-white h-100">
                <h6 class="font-weight-bold text-dark mb-3"><i class="fa-solid fa-chart-line mr-2 text-warning"></i>Tần suất bảo trì theo tháng</h6>
                <div class="position-relative chart-container">
                    <canvas id="maintenanceMonthlyChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Đồ thị 4: Chi phí sửa chữa bảo trì & Cảnh báo chưa xử lý -->
    <div class="row mb-4">
        <!-- Cột 1: Chi phí bảo trì (col-xl-8) -->
        <div class="col-12 col-xl-8 mb-3 mb-xl-0">
            <div class="card p-3 border-0 shadow-sm bg-white h-100">
                <div class="d-flex align-items-center justify-content-between" v-on:click="toggleCostChart" style="cursor: pointer;">
                    <h6 class="font-weight-bold text-dark m-0"><i class="fa-solid fa-money-bill-trend-up mr-2 text-primary"></i>Tổng chi phí bảo trì theo loại thiết bị</h6>
                    <div class="d-flex align-items-center gap-2" v-on:click.stop>
                        <select class="form-control form-control-sm font-weight-bold border mr-2" v-model="selectedYear" v-on:change="fetchCostData" v-show="showCostChart" style="width: auto;">
                            <option v-for="y in availableYears" :value="y">Năm {{ y }}</option>
                        </select>
                        <button class="btn btn-sm btn-light border font-weight-bold text-secondary">
                            <i class="fa-solid mr-1" :class="showCostChart ? 'fa-chevron-up' : 'fa-chevron-down'"></i>
                            {{ showCostChart ? 'Ẩn bớt' : 'Xem chi tiết' }}
                        </button>
                    </div>
                </div>
                <div v-show="showCostChart" class="mt-3">
                    <div class="position-relative chart-container" style="height: 300px;">
                        <canvas id="costBarChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột 2: Cảnh báo chưa xử lý (col-xl-4) -->
        <div class="col-12 col-xl-4">
            <div class="card p-3 border-0 shadow-sm bg-white h-100" style="display: flex; flex-direction: column;">
                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
                    <h6 class="font-weight-bold text-dark m-0">
                        <i class="fa-solid fa-bell text-danger mr-2"></i>Cảnh báo chưa xử lý
                    </h6>
                    <a href="/Alerts/Index" class="btn btn-xs btn-link font-weight-bold p-0 text-primary">Xem tất cả</a>
                </div>
                
                <div class="alerts-sidebar-list" style="max-height: 290px; overflow-y: auto; flex: 1;">
                    <div v-for="alert in criticalAlerts" :key="alert.Id" class="sidebar-alert-item mb-2" :class="'border-' + alert.Severity">
                        <div class="d-flex justify-content-between align-items-start">
                            <strong class="text-dark" style="font-size: 12.5px;">{{ alert.ItemName }}</strong>
                            <span class="badge" :class="'badge-' + alert.Severity" style="font-size: 9px; padding: 2px 5px; border-radius: 4px;">{{ severityLabel(alert.Severity) }}</span>
                        </div>
                        <p class="m-0 text-secondary mt-1" style="font-size: 11.5px; line-height: 1.3;">{{ alert.Body }}</p>
                        <div class="d-flex justify-content-between align-items-center mt-2 border-top pt-1" style="font-size: 11px;">
                            <span class="text-muted"><i class="fa-regular fa-clock mr-1"></i>{{ alert.CreatedAtFriendly }} ({{ alert.CreatedTimeStr }})</span>
                            <button class="btn btn-xs btn-outline-success font-weight-bold py-0 px-2" style="height: 20px; font-size: 10px; border-radius: 4px;" v-on:click="resolveDashboardAlert(alert.Id)">Giải quyết nhanh</button>
                        </div>
                    </div>
                    
                    <div v-if="criticalAlerts.length === 0" class="text-center py-5 text-muted font-italic" style="font-size: 12.5px;">
                        <i class="fa-solid fa-bell-slash text-muted mb-2 d-block" style="font-size: 20px;"></i>
                        Không có cảnh báo chưa xử lý.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Danh sách thiết bị theo trạng thái -->
    <div class="modal fade" id="statusDevicesModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header p-3 d-flex align-items-center justify-content-between text-white" 
                     :class="{
                          'bg-kpi-active': statusModal.status === 'active',
                          'bg-kpi-broken': statusModal.status === 'suspended',
                          'bg-kpi-maint': statusModal.status === 'maintenance',
                          'bg-kpi-total': statusModal.status === 'all'
                     }">
                    <h6 class="modal-title font-weight-bold m-0 text-white">
                        <i class="fa-solid fa-circle-info mr-2"></i>
                        {{ statusModal.title }}
                    </h6>
                    <button type="button" class="close outline-none border-0 bg-transparent text-white" style="font-size: 20px; line-height: 1;" v-on:click="closeStatusDevicesModal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body p-4">
                    <!-- VIEW 1: DANH SÁCH THIẾT BỊ -->
                    <div v-if="statusModal.viewMode === 'list'">
                        <!-- Thanh tìm kiếm nhanh & Tiêu đề số lượng -->
                        <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mb-3 pb-2 border-bottom">
                            <h6 class="m-0 font-weight-bold text-dark" style="font-size: 14px;">
                                <i class="fa-solid fa-list mr-1 text-secondary"></i>
                                Danh sách chi tiết thiết bị
                                <span class="text-secondary font-weight-normal" style="font-size: 12px;" v-if="filteredPopupDevices.length > 0">
                                    (Đang tìm thấy {{ filteredPopupDevices.length }} thiết bị)
                                </span>
                            </h6>
                            <div class="position-relative" style="min-width: 220px;">
                                <input type="text" class="form-control form-control-sm border outline-none pl-3 pr-4" style="border-radius: 6px;" placeholder="Tìm theo mã, tên..." v-model="statusModal.searchQuery" v-on:input="statusModal.currentPage = 1">
                                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="right: 10px; top: 9px; pointer-events: none; font-size: 11px;"></i>
                            </div>
                        </div>

                        <!-- Bộ lọc nhanh theo Khoa phòng & Nhóm thiết bị -->
                        <div class="filter-panel p-3 mb-3 border rounded">
                            <div class="row align-items-end">
                                <div class="col-12 col-md-5 mb-2 mb-md-0">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="fa-solid fa-hospital text-primary mr-1" style="font-size: 11px;"></i>
                                        <span class="filter-label">Khoa phòng ban</span>
                                    </div>
                                    <select class="form-control form-control-sm filter-select" v-model="statusModal.filterDept">
                                        <option :value="null">-- Tất cả khoa phòng --</option>
                                        <option v-for="dept in lookups.Departments" :key="dept.Id" :value="dept.Id">{{ dept.Name }}</option>
                                    </select>
                                </div>
                                <div class="col-12 col-md-5 mb-2 mb-md-0">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="fa-solid fa-tags text-primary mr-1" style="font-size: 11px;"></i>
                                        <span class="filter-label">Nhóm thiết bị y tế</span>
                                    </div>
                                    <select class="form-control form-control-sm filter-select" v-model="statusModal.filterGroup">
                                        <option :value="null">-- Tất cả nhóm thiết bị --</option>
                                        <option v-for="grp in lookups.Groups" :key="grp.Id" :value="grp.Id">{{ grp.Name }}</option>
                                    </select>
                                </div>
                                <div class="col-12 col-md-2 text-right">
                                    <button type="button" class="btn btn-sm btn-reset-filters w-100 font-weight-bold" 
                                            v-on:click="statusModal.filterDept = null; statusModal.filterGroup = null; statusModal.searchQuery = '';"
                                            title="Xóa bộ lọc">
                                        <i class="fa-solid fa-rotate mr-1"></i>Reset
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Bảng danh sách thiết bị -->
                        <div class="table-responsive" style="min-height: 250px;">
                            <table class="table table-hover align-middle border-0 table-analytics">
                                <thead class="bg-light text-secondary font-weight-bold">
                                    <tr>
                                        <th class="border-0">Mã tài sản</th>
                                        <th class="border-0">Tên thiết bị y tế</th>
                                        <th class="border-0">Khoa / Phòng ban</th>
                                        <th class="border-0 text-center">Trạng thái</th>
                                        <th class="border-0 text-center" style="width: 80px;">Chi tiết</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr v-for="item in paginatedPopupDevices" :key="item.Id" v-on:click="viewPopupDeviceDetails(item)" title="Click để xem thông tin chi tiết thiết bị">
                                        <td class="font-weight-bold text-primary">{{ item.AssetCode }}</td>
                                        <td class="font-weight-bold text-dark">{{ item.ItemName }}</td>
                                        <td>{{ item.DepartmentName }}</td>
                                        <td class="text-center">
                                            <span v-if="item.LifeStatus === 'active'" class="badge-status-custom badge-status-active" style="min-width: auto; padding: 2px 6px; font-size: 10px;">Đang chạy tốt</span>
                                            <span v-else-if="item.LifeStatus === 'suspended'" class="badge-status-custom badge-status-suspended" style="min-width: auto; padding: 2px 6px; font-size: 10px;">Đang báo hỏng</span>
                                            <span v-else-if="item.LifeStatus === 'maintenance_bv'" class="badge-status-custom badge-status-maintenance-bv" style="min-width: auto; padding: 2px 6px; font-size: 10px;">BV tự bảo trì</span>
                                            <span v-else-if="item.LifeStatus === 'maintenance_hang'" class="badge-status-custom badge-status-maintenance-hang" style="min-width: auto; padding: 2px 6px; font-size: 10px;">Hãng bảo trì</span>
                                            <span v-else class="badge-status-custom badge-status-neutral" style="min-width: auto; padding: 2px 6px; font-size: 10px;">{{ item.LifeStatus }}</span>
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-xs btn-outline-primary border-0" v-on:click.stop="viewPopupDeviceDetails(item)">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr v-if="statusModal.loading">
                                        <td colspan="5" class="text-center py-5">
                                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                            <span class="ml-2 text-muted">Đang tải danh sách thiết bị...</span>
                                        </td>
                                    </tr>
                                    <tr v-else-if="filteredPopupDevices.length === 0">
                                        <td colspan="5" class="text-center py-5 text-muted font-italic">Không tìm thấy thiết bị phù hợp với trạng thái này.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Phân trang danh sách popup -->
                        <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-2" style="font-size: 12.5px;" v-if="filteredPopupDevices.length > 0">
                            <div class="text-muted font-weight-bold">
                                Hiển thị từ {{ (statusModal.currentPage - 1) * statusModal.pageSize + 1 }} đến {{ Math.min(statusModal.currentPage * statusModal.pageSize, filteredPopupDevices.length) }} trong số {{ filteredPopupDevices.length }} thiết bị
                            </div>
                            <div class="pagination d-flex gap-2">
                                <button class="btn btn-sm btn-pagination" v-on:click="prevPopupPage" :disabled="statusModal.currentPage === 1">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>
                                <span class="align-self-center font-weight-bold text-secondary px-2" style="font-size: 12px;">Trang {{ statusModal.currentPage }} / {{ popupTotalPages }}</span>
                                <button class="btn btn-sm btn-pagination" v-on:click="nextPopupPage" :disabled="statusModal.currentPage === popupTotalPages || popupTotalPages === 0">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- VIEW 2: CHI TIẾT THIẾT BỊ -->
                    <div v-else-if="statusModal.viewMode === 'details' && statusModal.selectedDevice">
                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <button type="button" class="btn btn-sm btn-light border font-weight-bold text-secondary" v-on:click="statusModal.viewMode = 'list'">
                                <i class="fa-solid fa-arrow-left mr-1"></i> Quay lại danh sách
                            </button>
                            <button type="button" class="btn btn-sm btn-secondary font-weight-bold px-3" v-on:click="closeStatusDevicesModal">
                                <i class="fa-solid fa-xmark mr-1"></i> Đóng
                            </button>
                        </div>
                        <div class="card border-0 bg-light p-3 mb-0">
                            <div class="row">
                                <!-- Dòng 1: Mã tài sản & Tên thiết bị -->
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-barcode mr-1 text-primary"></i> Mã tài sản</div>
                                    <div class="modal-readonly-value text-primary font-weight-bold bg-white" v-text="statusModal.selectedDevice.AssetCode"></div>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-prescription-bottle-medical mr-1 text-primary"></i> Tên thiết bị y tế</div>
                                    <div class="modal-readonly-value font-weight-bold text-dark bg-white" v-text="statusModal.selectedDevice.ItemName"></div>
                                </div>

                                <!-- Dòng 2: Nhóm phân loại & Khoa phòng -->
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-layer-group mr-1 text-primary"></i> Nhóm phân loại</div>
                                    <div class="modal-readonly-value bg-white" v-text="statusModal.selectedDevice.GroupName || 'Chưa phân loại'"></div>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-hospital mr-1 text-primary"></i> Khoa / Phòng ban</div>
                                    <div class="modal-readonly-value bg-white" v-text="statusModal.selectedDevice.DepartmentName"></div>
                                </div>

                                <!-- Dòng 3: Vị trí phòng cụ thể & Số lượng -->
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-location-dot mr-1 text-primary"></i> Vị trí phòng cụ thể</div>
                                    <div class="modal-readonly-value bg-white">
                                        <i class="fa-solid fa-map-location-dot text-muted mr-2"></i>
                                        {{ statusModal.selectedDevice.LocationName || 'Chưa chỉ định' }}
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-cubes mr-1 text-primary"></i> Số lượng tồn</div>
                                    <div class="modal-readonly-value font-weight-bold bg-white" v-text="statusModal.selectedDevice.Quantity"></div>
                                </div>

                                <!-- Dòng 4: Đơn giá & Thành tiền -->
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-tag mr-1 text-primary"></i> Đơn giá đầu tư</div>
                                    <div class="modal-readonly-value bg-white" v-text="formatMoney(statusModal.selectedDevice.UnitPrice) + ' VNĐ'"></div>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-coins mr-1 text-primary"></i> Thành tiền tổng</div>
                                    <div class="modal-readonly-value font-weight-bold text-dark bg-white" v-text="formatMoney(statusModal.selectedDevice.TotalPrice) + ' VNĐ'"></div>
                                </div>

                                <!-- Dòng 5: Trạng thái vận hành -->
                                <div class="col-12">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-signal mr-1 text-primary"></i> Trạng thái vận hành</div>
                                    <div class="mt-1 bg-white p-2 border rounded-lg d-inline-block">
                                        <span v-if="statusModal.selectedDevice.LifeStatus === 'active'" class="badge-status-custom badge-status-active">Đang chạy tốt</span>
                                        <span v-else-if="statusModal.selectedDevice.LifeStatus === 'suspended'" class="badge-status-custom badge-status-suspended">Đang báo hỏng</span>
                                        <span v-else-if="statusModal.selectedDevice.LifeStatus === 'maintenance_bv'" class="badge-status-custom badge-status-maintenance-bv">BV tự bảo trì</span>
                                        <span v-else-if="statusModal.selectedDevice.LifeStatus === 'maintenance_hang'" class="badge-status-custom badge-status-maintenance-hang">Hãng bảo trì</span>
                                        <span v-else class="badge-status-custom badge-status-neutral" v-text="statusModal.selectedDevice.LifeStatus"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2 border-0">
                    <button type="button" class="btn btn-sm btn-secondary font-weight-bold px-3" v-on:click="closeStatusDevicesModal">Đóng</button>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    window.AnalyticsEndpoints = {
        getSummary: '/api/analytics/dashboard-summary',
        getCosts: '/api/analytics/maintenance-costs',
        getLookups: '/api/analytics/filter-lookups',
        getReport: '/api/analytics/inventory-report',
        getChecklist: '/api/analytics/checklist-today-progress',
        getFrequency: '/api/analytics/maintenance-frequency',
        socketServer: ''
    };
</script>

<script src="@Url.Content("~/Scripts/app/analytics-module.js?v=" + DateTime.Now.Ticks.ToString())"></script>