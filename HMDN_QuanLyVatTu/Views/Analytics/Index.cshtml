                                    <div class="modal-readonly-value bg-white" v-text="checklistModal.selectedLog.CheckedByName"></div>
                                </div>
                                <div class="col-12 col-md-6 mb-2">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-clock mr-1 text-primary"></i> Thời gian kiểm tra</div>
                                    <div class="modal-readonly-value bg-white" v-text="checklistModal.selectedLog.CheckedAt"></div>
                                </div>

                                <!-- Dòng 3: Tần suất & Kết quả tổng quan -->
                                <div class="col-12 col-md-6 mb-2">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-rotate mr-1 text-primary"></i> Tần suất kiểm tra</div>
                                    <div class="modal-readonly-value bg-white" v-text="cycleLabel(checklistModal.selectedLog.CycleType)"></div>
                                </div>
                                <div class="col-12 col-md-6 mb-2">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-square-poll-vertical mr-1 text-primary"></i> Kết quả tổng quan</div>
                                    <div class="modal-readonly-value bg-white">
                                        <span v-if="checklistModal.selectedLog.OverallResult === 'pass'" class="badge-status-custom badge-status-active">ĐẠT (PASS)</span>
                                        <span v-else class="badge-status-custom badge-status-suspended">KHÔNG ĐẠT (FAIL)</span>
                                    </div>
                                </div>

                                <!-- Dòng 4: Ghi chú -->
                                <div class="col-12">
                                    <div class="modal-readonly-label"><i class="fa-solid fa-note-sticky mr-1 text-primary"></i> Ghi chú chung</div>
                                    <div class="modal-readonly-value bg-white" v-text="checklistModal.selectedLog.Note || 'Không có ghi chú'"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Danh sách chi tiết tiêu chí -->
                        <h6 class="font-weight-bold text-dark mb-2"><i class="fa-solid fa-list-ol mr-2 text-info"></i>Chi tiết các tiêu chí kiểm tra</h6>
                        <div class="table-responsive border rounded-lg bg-white mb-0" style="max-height: 250px; overflow-y: auto;">
                            <table class="table table-hover table-striped align-middle mb-0" style="font-size: 13px;">
                                <thead style="background-color: #f1f5f9; color: #0f172a; font-weight: 700;" class="sticky-top">
                                    <tr>
                                        <th class="py-2">Tiêu chí kiểm tra</th>
                                        <th class="py-2 text-center" style="width: 120px;">Trạng thái</th>
                                        <th class="py-2">Ghi chú riêng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                     <tr v-for="detail in checklistModal.selectedLog.Items" :key="detail.Id" style="color: #0f172a; font-weight: 500;">
                                         <td>{{ detail.CheckName }}</td>
                                         <td class="text-center">
                                             <span v-if="detail.IsPassed" class="badge-status-custom badge-status-active" style="min-width: auto; padding: 3px 8px; font-size: 11px;"><i class="fa-solid fa-circle-check mr-1"></i>Đạt</span>
                                             <span v-else class="badge-status-custom badge-status-suspended" style="min-width: auto; padding: 3px 8px; font-size: 11px; animation: none !important;"><i class="fa-solid fa-circle-xmark mr-1"></i>Lỗi</span>
                                         </td>
                                         <td style="color: #475569; font-style: italic;">{{ detail.Note || '-' }}</td>
                                     </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light p-2 border-0">
                    <button type="button" class="btn btn-sm btn-secondary font-weight-bold px-3" v-on:click="closeChecklistLogsModal">Đóng</button>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    window.AnalyticsEndpoints = {
        getSummary: '/api/analytics/dashboard-summary',
        getCosts: '/api/analytics/maintenance-costs',
        getLookups: '/api/analytics/filter-lookups',
        getReport: '/api/analytics/inventory-report',
        getChecklist: '/api/analytics/checklist-today-progress',
        getFrequency: '/api/analytics/maintenance-frequency',
        getLogs: '/api/checklists/logs',
        getLogDetails: '/api/checklists/log-details',
        socketServer: ''
    };
</script>

<script src="~/Scripts/app/analytics-module.js?v=@DateTime.Now.Ticks" charset="utf-8"></script>