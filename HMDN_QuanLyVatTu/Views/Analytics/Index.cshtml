@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="@Url.Content("~/Content/analytics/analytics-module.css")" />

<script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>

<div id="analytics-module-hub" class="container-fluid" v-cloak>

    <div class="row mb-4">
        <div class="col-12 col-sm-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm d-flex flex-row align-items-center justify-content-between bg-white h-100">
                <div>
                    <small class="text-uppercase text-muted font-weight-bold card-kpi-title">Tổng tài sản thiết bị</small>
                    <h2 class="mt-1 mb-0 font-weight-bold text-dark">{{ kpi.TotalAssets }}</h2>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-primary kpi-icon-box bg-blue-light">
                    <i class="fa-solid fa-hospital-user"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm d-flex flex-row align-items-center justify-content-between bg-white h-100">
                <div>
                    <small class="text-uppercase text-muted font-weight-bold card-kpi-title">Đang hoạt động tốt</small>
                    <h2 class="mt-1 mb-0 font-weight-bold text-success">
                        {{ kpi.OperatingWell }}
                        <span class="kpi-percentage">({{ formatPercent(kpi.ActivePercentage) }}%)</span>
                    </h2>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-success kpi-icon-box bg-green-light">
                    <i class="fa-solid fa-square-check"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm d-flex flex-row align-items-center justify-content-between bg-white h-100">
                <div>
                    <small class="text-uppercase text-muted font-weight-bold card-kpi-title">Thiết bị hỏng</small>
                    <h2 class="mt-1 mb-0 font-weight-bold text-danger">
                        {{ kpi.BrokenAssets }}
                        <span class="kpi-percentage">({{ formatPercent(kpi.BrokenPercentage) }}%)</span>
                    </h2>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-danger kpi-icon-box bg-red-light">
                    <i class="fa-solid fa-circle-exclamation"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm d-flex flex-row align-items-center justify-content-between bg-white h-100">
                <div>
                    <small class="text-uppercase text-muted font-weight-bold card-kpi-title">Thiết bị đang bảo trì</small>
                    <h2 class="mt-1 mb-0 font-weight-bold text-warning">
                        {{ kpi.HospitalMaintenanceCount + kpi.VendorMaintenanceCount }}
                        <small style="font-size: 14px;" class="text-muted">máy</small>
                    </h2>
                    <div class="mt-1" style="font-size: 11.5px; line-height: 1.4;">
                        <span class="text-secondary mr-2">● BV bảo trì: <strong>{{ kpi.HospitalMaintenanceCount }}</strong></span> <br />
                        <span class="text-secondary">● Hãng bảo trì: <strong>{{ kpi.VendorMaintenanceCount }}</strong></span>
                    </div>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-warning kpi-icon-box bg-yellow-light">
                    <i class="fa-solid fa-screwdriver-wrench"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12 col-md-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm bg-white h-100">
                <h6 class="font-weight-bold text-dark mb-3"><i class="fa-solid fa-chart-pie mr-2 text-info"></i>Tỉ lệ thiết bị hoạt động</h6>
                <div class="position-relative d-flex align-items-center justify-content-center chart-container">
                    <canvas id="statusPieChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3 mb-3">
            <div class="card p-3 border-0 shadow-sm bg-white h-100">
                <h6 class="font-weight-bold text-dark mb-3"><i class="fa-solid fa-list-check mr-2 text-success"></i>Tiến độ Checklist hôm nay</h6>
                <div class="position-relative d-flex align-items-center justify-content-center chart-container">
                    <canvas id="todayChecklistChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6 mb-3">
            <div class="card p-3 border-0 shadow-sm bg-white h-100">
                <h6 class="font-weight-bold text-dark mb-3"><i class="fa-solid fa-chart-line mr-2 text-warning"></i>Tần suất bảo trì theo tháng</h6>
                <div class="position-relative chart-container">
                    <canvas id="maintenanceMonthlyChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card p-3 border-0 shadow-sm bg-white">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="font-weight-bold text-dark m-0"><i class="fa-solid fa-money-bill-trend-up mr-2 text-primary"></i>Tổng chi phí bảo trì theo loại thiết bị</h6>
                    <div>
                        <select class="form-control form-control-sm font-weight-bold border" v-model="selectedYear" v-on:change="fetchCostData">
                            <option v-for="y in availableYears" :value="y">Năm {{ y }}</option>
                        </select>
                    </div>
                </div>
                <div class="position-relative chart-container" style="height: 300px;">
                    <canvas id="costBarChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div id="target-inventory-table" class="card p-4 border-0 shadow-sm bg-white">
                <div class="d-flex flex-column flex-xl-row align-items-xl-center justify-content-between border-bottom pb-3 mb-3">
                    <h6 class="font-weight-bold text-dark m-0"><i class="fa-solid fa-boxes-stacked mr-2 text-warning"></i>Báo cáo chi tiết tồn kho tài sản y tế</h6>

                    <div class="d-flex flex-wrap align-items-center gap-2 mt-2 mt-xl-0">
                        <div class="form-group mb-0 mr-2">
                            <select class="form-control form-control-sm font-weight-bold border" v-model="filterYear" v-on:change="fetchInventoryReport">
                                <option v-for="y in availableYears" :value="y">Năm {{ y }}</option>
                            </select>
                        </div>
                        <div class="form-group mb-0 mr-2">
                            <select class="form-control form-control-sm font-weight-bold border" v-model="filterDept" v-on:change="fetchInventoryReport">
                                <option :value="null">── Lọc theo Khoa phòng ──</option>
                                <option v-for="d in lookups.Departments" :value="d.Id">{{ d.Name }}</option>
                            </select>
                        </div>
                        <div class="form-group mb-0 mr-2">
                            <select class="form-control form-control-sm font-weight-bold border" v-model="filterGroup" v-on:change="fetchInventoryReport">
                                <option :value="null">── Lọc theo Loại thiết bị ──</option>
                                <option v-for="g in lookups.Groups" :value="g.Id">{{ g.Name }}</option>
                            </select>
                        </div>

                        <div class="form-group mb-0 mr-2">
                            <select class="form-control form-control-sm font-weight-bold border" v-model="filterStatus" v-on:change="fetchInventoryReport">
                                <option :value="null">── Lọc theo Trạng thái ──</option>
                                <option value="active">Đang chạy tốt</option>
                                <option value="suspended">Đang báo hỏng</option>
                                <option value="maintenance_bv">Bệnh viện bảo trì</option>
                                <option value="maintenance_hang">Hãng đối tác bảo trì</option>
                            </select>
                        </div>

                        <button class="btn btn-sm btn-light border font-weight-bold text-secondary" v-on:click="resetFilters">
                            <i class="fa-solid fa-arrows-rotate mr-1"></i>Làm mới
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle border-0 table-analytics">
                        <thead class="bg-light text-secondary font-weight-bold">
                            <tr>
                                <th class="border-0">Mã tài sản</th>
                                <th class="border-0">Tên thiết bị y tế</th>
                                <th class="border-0">Loại nhóm</th>
                                <th class="border-0">Khoa / Phòng ban</th>
                                <th class="border-0">Vị trí phòng</th>
                                <th class="border-0 text-center">SL tồn</th>
                                <th class="border-0 text-right">Đơn giá (VNĐ)</th>
                                <th class="border-0 text-right">Thành tiền (VNĐ)</th>
                                <th class="border-0 text-center">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr v-for="item in paginatedInventory" :key="item.Id">
                                <td class="font-weight-bold text-primary">{{ item.AssetCode }}</td>
                                <td class="font-weight-bold text-dark">{{ item.ItemName }}</td>
                                <td><span class="badge-group-custom">{{ item.GroupName || 'Chưa phân loại' }}</span></td>
                                <td>{{ item.DepartmentName }}</td>
                                <td><i class="fa-solid fa-map-location-dot text-muted" style="margin-right: 8px;"></i>{{ item.LocationName || 'Chưa chỉ định' }}</td>
                                <td class="text-center font-weight-bold">{{ item.Quantity }}</td>
                                <td class="text-right">{{ formatMoney(item.UnitPrice) }}</td>
                                <td class="text-right font-weight-bold text-dark">{{ formatMoney(item.TotalPrice) }}</td>

                                <td class="text-center">
                                    <span v-if="item.LifeStatus === 'active'" class="badge-status-custom badge-status-active">Đang chạy tốt</span>
                                    <span v-else-if="item.LifeStatus === 'suspended'" class="badge-status-custom badge-status-suspended">Đang báo hỏng</span>
                                    <span v-else-if="item.LifeStatus === 'maintenance_bv'" class="badge-status-custom badge-status-maintenance-bv">BV bảo trì</span>
                                    <span v-else-if="item.LifeStatus === 'maintenance_hang'" class="badge-status-custom badge-status-maintenance-hang">Hãng bảo trì</span>
                                    <span v-else class="badge-status-custom badge-status-neutral">{{ item.LifeStatus }}</span>
                                </td>
                            </tr>
                            <tr v-if="filteredInventoryLength === 0">
                                <td colspan="9" class="text-center py-5 text-muted font-italic">Không tìm thấy dữ liệu thiết bị phù hợp với bộ lọc hiện tại.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="card-footer d-flex justify-content-between align-items-center bg-white border-top pt-3 mt-2" style="font-size: 13.5px;" v-if="filteredInventoryLength > 0">
                    <div class="text-muted font-weight-bold">
                        Hiển thị từ {{ (currentPage - 1) * pageSize + 1 }} đến {{ Math.min(currentPage * pageSize, filteredInventoryLength) }} trong tổng số {{ filteredInventoryLength }} thiết bị
                    </div>
                    <div class="pagination d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary font-weight-bold" v-on:click="prevPage" :disabled="currentPage === 1">
                            <i class="fa-solid fa-chevron-left mr-1"></i> Trước
                        </button>
                        <button class="btn btn-sm font-weight-bold" v-for="page in totalPages" :key="page"
                                :class="page === currentPage ? 'btn-primary' : 'btn-outline-secondary'"
                                v-on:click="currentPage = page">
                            {{ page }}
                        </button>
                        <button class="btn btn-sm btn-outline-secondary font-weight-bold" v-on:click="nextPage" :disabled="currentPage === totalPages || totalPages === 0">
                            Sau <i class="fa-solid fa-chevron-right ml-1"></i>
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    window.AnalyticsEndpoints = {
        getSummary: '/api/analytics/dashboard-summary',
        getCosts: '/api/analytics/maintenance-costs',
        getLookups: '/api/analytics/filter-lookups',
        getReport: '/api/analytics/inventory-report',
        getChecklist: '/api/analytics/checklist-today-progress',
        getFrequency: '/api/analytics/maintenance-frequency',
        socketServer: 'http://localhost:3000'
    };
</script>

<script src="@Url.Content("~/Scripts/app/analytics-module.js")"></script>