<!-- SCRIPTS FOR FILTERS, SEARCH AND PAGINATION -->
@section scripts {
    <script>
        // 1. Phản hồi gõ phím tìm kiếm
        function handleSearchKeyPress(e) {
            if (e.key === 'Enter') {
                applyFilters();
            }
        }

        // 2. Gom tất cả filter và reload lại trang
        function applyFilters(pageNumber) {
            pageNumber = pageNumber || 1;
            
            var search = $('#topbarSearchInput').val() || "";
            var deptId = $('#filterDept').val() || "0";
            
            var url = '@Url.Action("Index", "User")' 
                + '?search=' + encodeURIComponent(search)
                + '&departmentId=' + deptId
                + '&page=' + pageNumber;
                
            window.location.href = url;
        }

        // 3. Hàm phân trang nhanh
        function goToPage(page) {
            applyFilters(page);
        }

        // 4. AJAX Xử lý xóa tài khoản
        function deleteUserConfirm(userId, fullName) {
            if (confirm("Bạn có chắc chắn muốn xóa tài khoản của '" + fullName + "' không?\nHành động này không thể hoàn tác.")) {
                $.ajax({
                    url: '@Url.Action("DeleteUser", "User")',
                    type: 'POST',
                    data: { id: userId },
                    success: function (res) {
                        if (res && res.success) {
                            if (window.MedEquip && typeof window.MedEquip.toast === 'function') {
                                window.MedEquip.toast("Thành công", res.message || "Xóa người dùng thành công!", "info");
                            } else {
                                alert(res.message || "Xóa người dùng thành công!");
                            }
                            // Reload danh sách sau 1 giây
                            setTimeout(function () {
                                window.location.reload();
                            }, 1000);
                        } else {
                            if (window.MedEquip && typeof window.MedEquip.toast === 'function') {
                                window.MedEquip.toast("Lỗi thực thi", res.message || "Xóa thất bại.", "danger");
                            } else {
                                alert(res.message || "Xóa thất bại.");
                            }
                        }
                    },
                    error: function () {
                        if (window.MedEquip && typeof window.MedEquip.toast === 'function') {
                            window.MedEquip.toast("Lỗi", "Không thể kết nối đến máy chủ để thực hiện xóa.", "danger");
                        } else {
                            alert("Không thể kết nối đến máy chủ để thực hiện xóa.");
                        }
                    }
                });
            }
        }
    </script>
}
