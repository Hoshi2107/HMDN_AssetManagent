@{
    ViewBag.Title = "Nhật ký sửa chữa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/maintenance/maintenance.css?v=@DateTime.Now.Ticks.ToString()" rel="stylesheet" />

<div id="app">

    <!-- KPI CARDS -->
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-icon blue">
                <i class="fa-solid fa-boxes-stacked"></i>
            </div>
            <div class="kpi-info">
                <h4>${ kpi.totalDevices }</h4>
                <p>Bảo trì, Hỏng, Ngưng</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon amber">
                <i class="fa-solid fa-tools"></i>
            </div>
            <div class="kpi-info">
                <h4>${ kpi.devicesWithLogs }</h4>
                <p>Đang sửa chữa</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon green">
                <i class="fa-solid fa-check-circle"></i>
            </div>
            <div class="kpi-info">
                <h4>${ kpi.activeIssues }</h4>
                <p>Đã sửa chữa</p>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon purple">
                <i class="fa-solid fa-money-bill-wave"></i>
            </div>
            <div class="kpi-info">
                <h4>${ formatCurrency(kpi.totalRepairs) }</h4>
                <p>Tổng chi phí sửa</p>
            </div>
        </div>
    </div>

    <!-- HEADER -->
    <div class="maint-header">
        <div>
            <h2>Nhật ký bệnh án thiết bị</h2>
            <p>Hiển thị tất cả thiết bị — Click vào thiết bị để xem lịch sử sửa chữa</p>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="maint-filter">
        <input type="text"
               placeholder="Tìm theo tên thiết bị, serial, mã tài sản, khoa phòng..."
               v-model="searchQuery" />

        <select v-model="filterLogStatus">
            <option value="">Tất cả thiết bị</option>
            <option value="has_logs">Có lịch sử sửa chữa</option>
            <option value="no_logs">Chưa từng sửa chữa</option>
        </select>

        <select v-model="filterDepartment">
            <option value="">Tất cả khoa phòng</option>
            <option v-for="dept in departmentList" :key="dept" :value="dept">${ dept }</option>
        </select>

        <select v-model="filterLifeStatus">
            <option value="">Tất cả trạng thái</option>
            <option value="maintenance_bv">BV Bảo trì</option>
            <option value="broken">Hỏng</option>
            <option value="suspended">Tạm ngưng</option>
        </select>

        <select v-model="pageSize">
            <option :value="10">10 dòng</option>
            <option :value="15">15 dòng</option>
            <option :value="20">20 dòng</option>
            <option :value="50">50 dòng</option>
        </select>

        <button type="button" 
                class="btn-vendor" 
                style="padding: 9px 16px; margin: 0; display: inline-flex; align-items: center; gap: 8px; border-radius: 8px; font-weight: 600; font-size: 13px; cursor: pointer; transition: all 0.2s; white-space: nowrap;"
                v-on:click="showRepairedDevices = !showRepairedDevices"
                :style="showRepairedDevices ? 'background: #10b981; color: white; border: 1px solid #10b981;' : 'background: white; color: #475569; border: 1px solid #cbd5e1;'">
            <i class="fa-solid fa-check-circle" :style="showRepairedDevices ? 'color: white' : 'color: #10b981'"></i> 
            <span v-if="!showRepairedDevices">Thiết bị đã sửa chữa</span>
            <span v-else>Quay lại (Mặc định)</span>
        </button>
    </div>

    <!-- TOP SCROLLBAR -->
    <div class="top-scrollbar-wrap" ref="topScroll" @@scroll="syncTopScroll" v-show="tableScrollWidth > 0">
        <div class="top-scrollbar-inner" :style="{ width: tableScrollWidth + 'px' }"></div>
    </div>

    <!-- TABLE: DANH SÁCH THIẾT BỊ -->
    <div class="maint-table-wrap" ref="bottomScroll" @@scroll="syncBottomScroll">
        <table v-if="filteredDevices.length > 0" ref="maintTable">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Mã TS</th>
                    <th>Thiết bị</th>
                    <th>Serial</th>
                    <th>Khoa phòng</th>
                    <th>Vị trí</th>
                    <th>Nguyên giá</th>
                    <th>Tổng phí sửa</th>
                    <th>Trạng thái</th>
                    <th>Số lần sửa</th>
                    <th>Đang xử lý</th>
                    <th>Lần sửa gần nhất</th>
                </tr>
            </thead>
            <tbody>
                <tr v-for="device in paginatedDevices"
                    :key="device.Id"
                    v-on:click="openHistory(device.Id)"
                    :class="{ 'row-has-issue': device.OpenLogs > 0 || device.InProgressLogs > 0 }">

                    <td><strong>#${ device.Id }</strong></td>

                    <td>
                        <span class="asset-code">${ device.AssetCode || '—' }</span>
                    </td>

                    <td>
                        <div class="device-name">${ device.ItemName }</div>
                    </td>

                    <td>
                        <small class="serial-text">${ device.SerialNumber || '—' }</small>
                    </td>

                    <td>${ device.DepartmentName }</td>

                    <td>${ device.LocationName }</td>

                    <td>${ formatCurrency(device.UnitPrice) }</td>

                    <td>
                        <strong v-if="device.TotalMaintenanceCost > 0" style="color:#b91c1c">
                            ${ formatCurrency(device.TotalMaintenanceCost) }
                        </strong>
                        <span v-else class="no-log">0 ₫</span>
                    </td>

                    <td>
                        <span class="badge-life" :class="'life-' + (device.LifeStatus || 'active')">
                            ${ lifeStatusLabel(device.LifeStatus) }
                        </span>
                    </td>

                    <td class="text-center">
                        <span v-if="device.TotalLogs > 0" class="log-count">${ device.TotalLogs }</span>
                        <span v-else class="no-log">0</span>
                    </td>

                    <td class="text-center">
                        <span v-if="device.OpenLogs > 0 || device.InProgressLogs > 0"
                              class="active-issues">
                            ${ device.OpenLogs + device.InProgressLogs }
                        </span>
                        <span v-else class="no-issue">—</span>
                    </td>

                    <td>
                        <span v-if="device.LastLogDate">${ device.LastLogDate }</span>
                        <span v-else class="no-log">Chưa có</span>
                    </td>
                </tr>
            </tbody>
        </table>

        <!-- Empty state -->
        <div class="empty-state" v-else>
            <i class="fa-solid fa-box-open"></i>
            <p>Không tìm thấy thiết bị nào</p>
        </div>
    </div>

    <!-- PAGINATION -->
    <div class="maint-pagination" v-if="totalPages > 1">
        <button v-on:click="currentPage--" :disabled="currentPage <= 1">
            <i class="fa-solid fa-chevron-left"></i>
        </button>

        <button v-for="page in pages"
                :key="page"
                v-on:click="currentPage = page"
                :class="{ active: currentPage === page }">
            ${ page }
        </button>

        <button v-on:click="currentPage++" :disabled="currentPage >= totalPages">
            <i class="fa-solid fa-chevron-right"></i>
        </button>
    </div>


    <!-- ═══ MODAL: LỊCH SỬ SỬA CHỮA THIẾT BỊ ═══ -->
    <div class="modal-overlay"
         v-if="showHistoryModal"
         v-on:click.self="showHistoryModal = false">

        <div class="modal-panel modal-panel-fullscreen" style="background:#f8fafc">

            <div class="modal-top" style="background:#fff; border-bottom:none">
                <h3>Nhật ký bệnh án thiết bị</h3>
                <button class="modal-close" v-on:click="showHistoryModal = false">×</button>
            </div>

            <!-- Loading -->
            <div v-if="historyLoading" style="padding:100px;text-align:center;color:#94a3b8">
                <i class="fa-solid fa-spinner fa-spin" style="font-size:32px"></i>
                <p style="margin-top:16px; font-weight:500">Đang tải hồ sơ thiết bị...</p>
            </div>

            <div class="modal-body" v-if="selectedDevice && !historyLoading" style="padding:0; display:flex; flex-direction:column">

                <!-- Header (Title & Actions) -->
                <div class="profile-header" style="background:#fff">
                    <div class="profile-header-left">
                        <div class="profile-icon">
                            <i class="fa-solid fa-x-ray"></i>
                        </div>
                        <div>
                            <div class="profile-title">
                                <h2>
                                    ${ selectedDevice.ItemName }
                                    <select class="badge-status-maint" style="background:#f1f5f9; color:#334155; border: 1px solid #cbd5e1; cursor: pointer; padding: 4px 24px 4px 8px; font-weight: 600; outline: none; appearance: auto;" v-model="selectedDevice.LifeStatus" v-on:change="updateDeviceStatus(selectedDevice.Id, selectedDevice.LifeStatus)">
                                        <option value="active">Đang sử dụng</option>
                                        <option value="suspended">Tạm ngưng</option>
                                        <option value="broken">Hỏng</option>
                                        <option value="maintenance_bv">BV Bảo trì</option>
                                        <option value="disposed">Thanh lý</option>
                                    </select>
                                </h2>
                            </div>
                            <div class="profile-meta">
                                <span>
                                    <i class="fa-solid fa-barcode" style="color:#94a3b8"></i> 
                                    SN: ${ selectedDevice.SerialNumber || '—' }
                                </span>
                                <span>
                                    <i class="fa-solid fa-hospital-user" style="color:#94a3b8"></i> 
                                    Khoa: ${ selectedDevice.DepartmentName || '—' }
                                </span>
                                <span>
                                    <i class="fa-solid fa-location-dot" style="color:#94a3b8"></i> 
                                    Phòng: ${ selectedDevice.LocationName || '—' }
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="profile-header-actions">
                        <button class="btn-outline">
                            <i class="fa-solid fa-file-pdf"></i> PDF/Excel
                        </button>
                        <button class="btn-create" v-if="hasPermission('Maintenance', 'CREATE')" v-on:click="openCreateFromHistory()" style="padding:9px 20px">
                            <i class="fa-solid fa-triangle-exclamation"></i> Thêm phiếu báo hỏng
                        </button>
                    </div>
                </div>

                <!-- KPI Cards -->
                <div class="profile-kpi-grid" style="background:#fff">
                    <div class="profile-kpi-card">
                        <h5>Tổng chi phí bảo trì</h5>
                        <p>${ formatCurrency(summaryData.TotalMaintenanceCost) || '0 ₫' }</p>
                    </div>
                    <div class="profile-kpi-card">
                        <h5>Số lần sửa chữa</h5>
                        <p>${ summaryData.TotalLogs } phiếu</p>
                    </div>
                    <div class="profile-kpi-card">
                        <h5>Bảo dưỡng gần nhất</h5>
                        <p>${ summaryData.LastMaintenanceDate || 'Chưa có' }</p>
                    </div>
                </div>

                <!-- 2-Column Layout -->
                <div class="profile-layout-2col">
                    
                    <!-- LEFT COLUMN: Timeline -->
                    <div class="profile-timeline-section">
                        <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:20px; border-bottom:1px solid #e2e8f0; padding-bottom:12px">
                            <h3 style="margin:0; border:none; padding:0">Lịch sử bảo trì & Sửa chữa</h3>
                            <div style="display:flex; gap:10px">
                                <button class="btn-outline" style="padding:6px 12px; font-size:12px">Tất cả loại hình <i class="fa-solid fa-chevron-down"></i></button>
                                <button class="btn-outline" style="padding:6px 12px; font-size:12px">Tất cả trạng thái <i class="fa-solid fa-chevron-down"></i></button>
                            </div>
                        </div>

                        <div v-if="deviceLogs.length > 0">
                            <div class="timeline-card-rich" :class="'tcr-' + log.Status" v-for="log in deviceLogs" :key="log.Id">
                                <div class="tcr-header">
                                    <div>
                                        <div class="tcr-title">
                                            <h4>
                                                ${ log.Title }
                                                <span class="badge-status-maint" style="background:#f1f5f9; color:#475569; font-size:10px; border:1px solid #cbd5e1">
                                                    ${ maintenanceTypeLabel(log.MaintenanceType).toUpperCase() }
                                                </span>
                                            </h4>
                                        </div>
                                        <div class="tcr-title-meta">
                                            <span><i class="fa-regular fa-calendar"></i> ${ log.StartDate } <template v-if="log.EndDate">- ${ log.EndDate }</template></span>
                                            <span><i class="fa-solid fa-ticket"></i> #JOB-${ new Date(log.StartDate).getFullYear() }-${ log.Id }</span>
                                        </div>
                                    </div>
                                    <div class="tcr-status">
                                        <span class="badge-status-maint" :class="'badge-' + log.Status">
                                            ${ statusLabel(log.Status) }
                                        </span>
                                        <div class="text-danger" v-if="log.Priority === 'critical' || log.Priority === 'high'">
                                            <i class="fa-solid fa-circle-exclamation"></i> Khẩn cấp
                                        </div>
                                    </div>
                                </div>
                                <div class="tcr-body">
                                    <div class="tcr-col">
                                        <h6 v-if="log.ErrorDescription">Mô tả hư hỏng:</h6>
                                        <p v-if="log.ErrorDescription">${ log.ErrorDescription }</p>
                                        
                                        <h6 v-if="log.ActionTaken">Nội dung xử lý:</h6>
                                        <p v-if="log.ActionTaken">${ log.ActionTaken }</p>

                                        <p v-if="!log.ErrorDescription && !log.ActionTaken" style="color:#94a3b8; font-style:italic">Không có ghi chú</p>
                                    </div>
                                    <div class="tcr-col-right">
                                        <div class="tcr-detail-row">
                                            <span>Chi phí:</span>
                                            <strong class="text-blue">${ log.Cost ? formatCurrency(log.Cost) : '—' }</strong>
                                        </div>
                                        <div class="tcr-detail-row" style="margin-top:12px">
                                            <span>Đơn vị thực hiện:</span>
                                            <strong>${ log.Vendor || 'Bệnh viện (Nội bộ)' }</strong>
                                        </div>
                                        <div class="tcr-detail-row" style="margin-top:12px; align-items:flex-start">
                                            <span>Vật tư thay thế:</span>
                                            <strong style="text-align:right">${ log.PartReplaced || '—' }</strong>
                                        </div>
                                    </div>
                                </div>
                                <div class="tcr-footer">
                                    <div class="tcr-people">
                                        <div class="tcr-person" v-if="log.ReportedBy">
                                            <div class="tcr-avatar"><i class="fa-solid fa-user-doctor"></i></div>
                                            <div class="tcr-person-info">
                                                <span>Người báo</span>
                                                <strong>User #${ log.ReportedBy }</strong>
                                            </div>
                                        </div>
                                        <div class="tcr-person" v-if="log.AssignedTo">
                                            <div class="tcr-avatar" style="background:#dbeafe; color:#2563eb"><i class="fa-solid fa-screwdriver-wrench"></i></div>
                                            <div class="tcr-person-info">
                                                <span>Kỹ thuật viên</span>
                                                <strong>Tech #${ log.AssignedTo }</strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="tcr-action-link" v-on:click="openDetail(log.Id)">
                                        Xem chi tiết phiếu <i class="fa-solid fa-chevron-right" style="font-size:10px"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Empty history -->
                        <div class="empty-history" v-else style="background:#fff; border-radius:12px; border:1px solid #e2e8f0; margin-top:20px; padding:60px 20px">
                            <i class="fa-solid fa-shield-heart" style="font-size:48px;color:#10b981;margin-bottom:16px"></i>
                            <p style="font-size:16px; color:#1e2a3a">Thiết bị này chưa từng có lịch sử sửa chữa</p>
                            <small style="font-size:14px">Máy vẫn đang vận hành tốt</small>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: Details & Media -->
                    <div>
                        <!-- Thông tin chi tiết -->
                        <div class="widget-card">
                            <h4>Thông tin chi tiết</h4>
                            <div class="info-list">
                                <div class="info-row">
                                    <span>Model / Thương hiệu</span>
                                    <strong>${ selectedDevice.Model } / ${ selectedDevice.Brand }</strong>
                                </div>
                                <div class="info-row">
                                    <span>Năm sản xuất / Đưa vào SD</span>
                                    <strong>${ selectedDevice.ManufactureYear } / ${ selectedDevice.ImportDate ? selectedDevice.ImportDate.substring(0,4) : '—' }</strong>
                                </div>
                                <div class="info-row">
                                    <span>Xuất xứ</span>
                                    <strong>${ selectedDevice.Origin }</strong>
                                </div>
                                <div class="info-row">
                                    <span>Hết hạn bảo hành</span>
                                    <strong class="text-red">${ selectedDevice.WarrantyExpiry }</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Hình ảnh & Minh chứng -->
                        <div class="widget-card">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid #f1f5f9">
                                <h4 style="margin:0; border:none; padding:0">Hình ảnh & Minh chứng</h4>
                            </div>
                            <div style="border: 2px dashed #cbd5e1; border-radius: 8px; padding: 24px; text-align: center; background: #f8fafc; cursor: pointer; margin-bottom:16px; transition: all 0.2s" onmouseover="this.style.borderColor='#3b82f6'; this.style.background='#eff6ff'" onmouseout="this.style.borderColor='#cbd5e1'; this.style.background='#f8fafc'" onclick="document.getElementById('fileUploadInput').click()">
                                <i class="fa-solid fa-cloud-arrow-up" style="font-size: 32px; color: #94a3b8; margin-bottom: 12px"></i>
                                <p style="margin: 0; font-size: 13px; color: #475569; font-weight: 500" v-if="!uploading">Kéo thả ảnh vào đây hoặc nhấn để tải lên</p>
                                <p style="margin: 0; font-size: 13px; color: #3b82f6; font-weight: 500" v-else>Đang tải tệp lên <i class="fa-solid fa-spinner fa-spin"></i></p>
                                <p style="margin: 4px 0 0; font-size: 11px; color: #94a3b8">Hỗ trợ JPG, PNG, PDF (Tối đa 5MB)</p>
                                <input type="file" id="fileUploadInput" style="display: none" accept="image/*,application/pdf" multiple v-on:change="uploadAttachment" />
                            </div>
                            
                            <div v-if="attachments.length > 0" style="margin-bottom: 16px;">
                                <div v-for="att in attachments" :key="att.Id" style="display: flex; align-items: center; justify-content: space-between; padding: 8px; border: 1px solid #e2e8f0; border-radius: 6px; margin-bottom: 8px;">
                                    <div style="display: flex; align-items: center; gap: 8px; overflow: hidden;">
                                        <i class="fa-solid fa-file-pdf" v-if="att.FileType && att.FileType.includes('pdf')" style="color: #ef4444; font-size: 32px; padding: 0 6px;"></i>
                                        <img v-else-if="att.FileType && att.FileType.startsWith('image/')" :src="'/api/maintenance/download-attachment/' + att.Id" style="width: 44px; height: 44px; object-fit: cover; border-radius: 6px; border: 1px solid #e2e8f0; flex-shrink: 0;" alt="thumbnail" />
                                        <i class="fa-solid fa-file" v-else style="color: #94a3b8; font-size: 32px; padding: 0 6px;"></i>
                                        <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
                                            <span style="font-size: 13px; font-weight: 500; color: #1e293b;" :title="att.FileName">${ att.FileName }</span>
                                            <div style="font-size: 11px; color: #64748b;">${ formatFileSize(att.FileSize) }</div>
                                        </div>
                                    </div>
                                    <a :href="'/api/maintenance/download-attachment/' + att.Id" target="_blank" class="btn-vendor" style="padding: 4px 8px; font-size: 12px; margin: 0; display: inline-block; width: auto; border-color: #cbd5e1; color: #475569; text-decoration: none;"><i class="fa-solid fa-download"></i></a>
                                </div>
                            </div>

                            <button class="btn-vendor" style="background:#fff; border-color:#cbd5e1; color:#475569" v-if="attachments.length > 3">Xem tất cả tài liệu đính kèm</button>
                        </div>

                        <!-- Đơn vị bảo trì ủy quyền -->
                        <div class="widget-card">
                            <h4 style="display:flex; align-items:center; gap:8px">
                                <i class="fa-solid fa-shield-halved" style="color:#2563eb"></i>
                                Đơn vị bảo trì ủy quyền
                            </h4>
                            <div class="vendor-info">
                                <h5>Hãng APC Vietnam Co., Ltd</h5>
                                <p>Hotline: 1800-2023</p>
                                <button class="btn-vendor">Liên hệ hỗ trợ kỹ thuật</button>
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>


    <!-- ═══ MODAL: CHI TIẾT CA SỬA CHỮA ═══ -->
    <div class="modal-overlay"
         v-if="showDetailModal"
         v-on:click.self="showDetailModal = false">

        <div class="modal-panel modal-panel-lg">

            <div class="modal-top">
                <h3>
                    <i class="fa-solid fa-file-medical" style="color:#2563eb;margin-right:8px"></i>
                    Chi tiết ca sửa chữa #${ detail.Id }
                </h3>
                <button class="modal-close" v-on:click="showDetailModal = false">×</button>
            </div>

            <div class="modal-body" v-if="detail">

                <!-- Thông tin thiết bị -->
                <div class="detail-grid-maint">
                    <div class="field">
                        <label>Thiết bị</label>
                        <p>${ detail.DeviceName }</p>
                    </div>
                    <div class="field">
                        <label>Serial</label>
                        <p>${ detail.DeviceSerial || '—' }</p>
                    </div>
                    <div class="field">
                        <label>Khoa phòng</label>
                        <p>${ detail.DeviceDepartment || '—' }</p>
                    </div>
                    <div class="field">
                        <label>Vị trí</label>
                        <p>${ detail.DeviceLocation || '—' }</p>
                    </div>
                </div>

                <!-- Thông tin ca sửa chữa -->
                <div class="detail-section">
                    <h4><i class="fa-solid fa-stethoscope" style="margin-right:6px"></i> Thông tin sửa chữa</h4>
                    <div class="detail-grid-maint">
                        <div class="field">
                            <label>Tiêu đề</label>
                            <p>${ detail.Title }</p>
                        </div>
                        <div class="field">
                            <label>Loại bảo trì</label>
                            <p>${ maintenanceTypeLabel(detail.MaintenanceType) }</p>
                        </div>
                        <div class="field">
                            <label>Trạng thái</label>
                            <p>
                                <span class="badge-status-maint" :class="'badge-' + detail.Status">
                                    ${ statusLabel(detail.Status) }
                                </span>
                            </p>
                        </div>
                        <div class="field">
                            <label>Mức ưu tiên</label>
                            <p>
                                <span class="badge-priority" :class="'prio-' + detail.Priority">
                                    ${ priorityLabel(detail.Priority) }
                                </span>
                            </p>
                        </div>
                        <div class="field">
                            <label>Ngày bắt đầu</label>
                            <p>${ detail.StartDate }</p>
                        </div>
                        <div class="field">
                            <label>Ngày kết thúc</label>
                            <p>${ detail.EndDate || 'Chưa hoàn tất' }</p>
                        </div>
                        <div class="field">
                            <label>Ngày tạo</label>
                            <p>${ detail.CreatedAt }</p>
                        </div>
                        <div class="field field-full">
                            <label>Mô tả lỗi</label>
                            <p>${ detail.ErrorDescription || 'Không có mô tả' }</p>
                        </div>
                        <div class="field field-full">
                            <label>Mô tả chi tiết</label>
                            <p>${ detail.Description || 'Không có' }</p>
                        </div>
                    </div>
                </div>

                <!-- Xử lý & Chi phí -->
                <div class="detail-section">
                    <h4><i class="fa-solid fa-screwdriver-wrench" style="margin-right:6px"></i> Xử lý & Chi phí</h4>
                    <div class="detail-grid-maint">
                        <div class="field field-full">
                            <label>Biện pháp xử lý</label>
                            <p>${ detail.ActionTaken || 'Chưa có biện pháp' }</p>
                        </div>
                        <div class="field">
                            <label>Linh kiện thay thế</label>
                            <p>${ detail.PartReplaced || '—' }</p>
                        </div>
                        <div class="field">
                            <label>Đơn vị sửa chữa</label>
                            <p>${ detail.Vendor || 'Nội bộ' }</p>
                        </div>
                        <div class="field">
                            <label>Chi phí</label>
                            <p class="cost-cell">${ detail.Cost ? formatCurrency(detail.Cost) : 'Chưa phát sinh' }</p>
                        </div>
                        <div class="field" v-if="detail.ClosedAt">
                            <label>Ngày đóng ca</label>
                            <p>${ detail.ClosedAt }</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer actions -->
            <div class="modal-footer" v-if="detail && detail.Status !== 'closed'">
                <button class="btn-cancel" v-on:click="showDetailModal = false">Đóng</button>

                <button class="btn-progress"
                        v-if="detail.Status === 'open' && hasPermission('Maintenance', 'EDIT')"
                        v-on:click="updateStatus(detail.Id, 'in_progress')">
                    <i class="fa-solid fa-play"></i> Bắt đầu sửa
                </button>

                <button class="btn-close-log"
                        v-if="detail.Status === 'in_progress' && hasPermission('Maintenance', 'EDIT')"
                        v-on:click="showCloseForm = !showCloseForm">
                    <i class="fa-solid fa-check"></i> Đóng ca sửa chữa
                </button>
            </div>

            <!-- Form đóng ca (hiện khi click "Đóng ca") -->
            <div style="padding:0 24px 20px" v-if="showCloseForm && detail && detail.Status === 'in_progress'">
                <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:16px">
                    <h4 style="margin:0 0 12px;font-size:13px;color:#15803d">
                        <i class="fa-solid fa-clipboard-check"></i> Hoàn tất ca sửa chữa
                    </h4>
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Biện pháp đã xử lý</label>
                            <textarea v-model="closeForm.ActionTaken"
                                      placeholder="Mô tả biện pháp đã thực hiện..."></textarea>
                        </div>
                        <div class="form-group">
                            <label>Linh kiện thay thế</label>
                            <input v-model="closeForm.PartReplaced"
                                   placeholder="Ví dụ: Ổ cứng SSD 256GB" />
                        </div>
                        <div class="form-group">
                            <label>Đơn vị sửa chữa</label>
                            <input v-model="closeForm.Vendor"
                                   placeholder="Ví dụ: Nội bộ, Công ty ABC" />
                        </div>
                        <div class="form-group">
                            <label>Chi phí (VNĐ)</label>
                            <input type="text" v-model="closeForm.Cost"
                                   placeholder="Ví dụ: 1.500.000" />
                        </div>
                        <div class="form-group" style="justify-content:flex-end">
                            <button class="btn-submit" v-on:click="closeLog()">
                                <i class="fa-solid fa-check-double"></i> Xác nhận đóng ca
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- ═══ MODAL: TẠO CA MỚI ═══ -->
    <div class="modal-overlay"
         v-if="showCreateModal"
         v-on:click.self="showCreateModal = false">

        <div class="modal-panel">

            <div class="modal-top">
                <h3>
                    <i class="fa-solid fa-plus-circle" style="color:#2563eb;margin-right:8px"></i>
                    Tạo ca sửa chữa mới
                    <span v-if="createFromDevice" style="font-size:13px;color:#94a3b8;font-weight:400">
                        — ${ createFromDevice.ItemName }
                    </span>
                </h3>
                <button class="modal-close" v-on:click="showCreateModal = false">×</button>
            </div>

            <div class="modal-body">
                <div class="form-grid">

                    <div class="form-group full" v-if="!createFromDevice">
                        <label>Chọn thiết bị <span class="required">*</span></label>
                        <select v-model="newLog.InventoryId">
                            <option :value="0" disabled>— Chọn thiết bị —</option>
                            <option v-for="d in deviceList"
                                    :key="d.Id"
                                    :value="d.Id">
                                ${ d.ItemName } — ${ d.SerialNumber || 'N/A' } (${ d.DepartmentName || '' })
                            </option>
                        </select>
                    </div>

                    <div class="form-group full" v-if="createFromDevice">
                        <label>Thiết bị</label>
                        <div class="prefilled-device">
                            <i class="fa-solid fa-microchip"></i>
                            ${ createFromDevice.ItemName }
                            <small v-if="createFromDevice.SerialNumber">(${ createFromDevice.SerialNumber })</small>
                        </div>
                    </div>

                    <div class="form-group full">
                        <label>Tiêu đề <span class="required">*</span></label>
                        <input v-model="newLog.Title"
                               placeholder="Ví dụ: Máy tính không khởi động" />
                    </div>

                    <div class="form-group">
                        <label>Loại bảo trì</label>
                        <select v-model="newLog.MaintenanceType">
                            <option value="corrective">Sửa chữa đột xuất / Báo hỏng</option>
                            <option value="preventive">Bảo trì định kỳ</option>
                            <option value="replacement_part">Thay thế linh kiện</option>
                        </select>
                    </div>

                    <div class="form-group full">
                        <label>Mô tả lỗi</label>
                        <textarea v-model="newLog.ErrorDescription"
                                  placeholder="Mô tả chi tiết triệu chứng lỗi..."></textarea>
                    </div>

                    <div class="form-group full">
                        <label>Mô tả chung</label>
                        <textarea v-model="newLog.Description"
                                  placeholder="Thông tin bổ sung..."></textarea>
                    </div>

                    <div class="form-group">
                        <label>Mức ưu tiên</label>
                        <select v-model="newLog.Priority">
                            <option value="low">Thấp</option>
                            <option value="normal">Bình thường</option>
                            <option value="high">Cao</option>
                            <option value="critical">Khẩn cấp</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Ngày bắt đầu</label>
                        <input type="date" v-model="newLog.StartDate" />
                    </div>

                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" v-on:click="showCreateModal = false">Hủy</button>
                <button class="btn-submit"
                        v-on:click="createLog()"
                        :disabled="!newLog.InventoryId || !newLog.Title">
                    <i class="fa-solid fa-paper-plane"></i> Tạo ca sửa chữa
                </button>
            </div>

        </div>
    </div>

</div>

@section scripts {
    <script src="~/Scripts/app/maintenance.js?v=@DateTime.Now.Ticks.ToString()"></script>
}
