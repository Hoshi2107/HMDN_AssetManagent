@model IEnumerable<HMDN_QuanLyVatTu.Models.Approvals>

@{
    ViewBag.Title = "Approvals";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Adjust layout path if needed
}

<h2 class="mt-4 mb-3">Approvals List</h2>

<!-- Search and filter bar -->
<div class="row mb-3">
    <div class="col-md-6">
        <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm theo Asset Id, Approved By..." />
    </div>
    <div class="col-md-4">
        <select id="statusFilter" class="form-select">
            <option value="">Tất cả trạng thái</option>
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
        </select>
    </div>
    <div class="col-md-2 text-end">
        <a asp-action="Create" class="btn btn-success btn-sm">Thêm mới</a>
    </div>
</div>

<table class="table table-hover table-striped approvals-table">
    <thead class="table-primary">
        <tr>
            <th>#</th>
            <th>Asset Id</th>
            <th>Approved By</th>
            <th>Approved Date</th>
            <th>Status</th>
            <th>Comments</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            var index = 1;
            foreach (var item in Model)
            {
                <tr data-status="@item.Status" data-assetid="@item.AssetId" data-approvedby="@item.ApprovedBy">
                    <td>@index</td>
                    <td>@item.AssetId</td>
                    <td>@item.ApprovedBy</td>
                    <td>@item.ApprovedDate.ToString("g")</td>
                    <td>@item.Status</td>
                    <td>@item.Comments</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-1">Xem</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">Sửa</a>
                        <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id">Xóa</button>

                        <!-- Delete Confirmation Modal -->
                        <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1" aria-labelledby="deleteModalLabel-@item.Id" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="deleteModalLabel-@item.Id">Xác nhận xóa</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        Bạn có chắc muốn xóa phê duyệt này?
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-danger">Xóa</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
                index++;
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No approvals found.</td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination placeholder (implement with PagedList or custom logic) -->
<div class="d-flex justify-content-center">
    @* Example: @await Html.PartialAsync("_Pagination", Model) *@
</div>

@section Scripts {
    <script>
        // Simple client‑side search & filter (for demo purposes)
        const searchInput = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const rows = document.querySelectorAll('tbody tr[data-status]');

        function filterRows() {
            const searchTerm = searchInput.value.toLowerCase();
            const status = statusFilter.value;
            rows.forEach(row => {
                const matchesSearch = row.dataset.assetid.toLowerCase().includes(searchTerm) ||
                    row.dataset.approvedby.toLowerCase().includes(searchTerm);
                const matchesStatus = !status || row.dataset.status === status;
                row.style.display = (matchesSearch && matchesStatus) ? '' : 'none';
            });
        }

        searchInput.addEventListener('input', filterRows);
        statusFilter.addEventListener('change', filterRows);
    </script>
}

<style>
    .approvals-table th {
        background: linear-gradient(135deg, #4a90e2, #357ab8);
        color: #fff;
    }
    .approvals-table td {
        vertical-align: middle;
    }
</style>

@{
    ViewBag.Title = "Approvals";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Adjust layout path if needed
}

<h2>Approvals List</h2>

<table class="approvals-table">
    <thead>
        <tr>
            <th>#</th>
            <th>Asset Id</th>
            <th>Approved By</th>
            <th>Approved Date</th>
            <th>Status</th>
            <th>Comments</th>
        </tr>
    </thead>
    <tbody>
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.AssetId</td>
                <td>@item.ApprovedBy</td>
                <td>@item.ApprovedDate.ToString("g")</td>
                <td>@item.Status</td>
                <td>@item.Comments</td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="6">No approvals found.</td>
        </tr>
    }
    </tbody>
</table>

<style>
.approvals-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}
.approvals-table th, .approvals-table td {
    border: 1px solid #ddd;
    padding: 8px;
}
.approvals-table th {
    background: linear-gradient(135deg, #4a90e2, #357ab8);
    color: #fff;
    text-align: left;
}
.approvals-table tr:nth-child(even) {background-color: #f9f9f9;}
.approvals-table tr:hover {background-color: #eaeaea;}
</style>
