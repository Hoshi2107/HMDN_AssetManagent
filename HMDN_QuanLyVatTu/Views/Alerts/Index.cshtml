@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Trung tâm Cảnh báo";
}

<link rel="stylesheet" href="@Url.Content("~/Content/alerts/alerts.css")" />

<div id="app" class="alerts-container" v-cloak>
    
    <!-- ── MÀN HÌNH 1: TRUNG TÂM CẢNH BÁO ── -->
    <div v-if="activeView === 'alerts'">
        
        <!-- Header phụ & Tìm kiếm nhanh -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <p class="text-muted m-0" style="font-size: 13px;">
                    Quản lý và xử lý kịp thời các sự cố thiết bị y tế toàn hệ thống để chuyển từ quản lý bị động sang chủ động.
                </p>
            </div>
            
            <div class="position-relative" style="min-width: 280px;">
                <input type="text" 
                       class="form-control form-control-custom" 
                       placeholder="Tìm kiếm cảnh báo, thiết bị..." 
                       v-model="searchQuery"
                       style="padding-right: 36px;" />
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" 
                   style="right: 12px; top: 11px; pointer-events: none; font-size: 13px;"></i>
            </div>
        </div>

        <!-- Tabs lọc & Thao tác cấu hình -->
        <div class="alerts-tab-header">
            <div class="alerts-tabs">
                <button class="alert-tab-btn tab-all" :class="{ active: activeTab === 'all' }" v-on:click="setTab('all')">
                    Tất cả <span class="badge-pill">${ counts.All }</span>
                </button>
                <button class="alert-tab-btn tab-danger" :class="{ active: activeTab === 'danger' }" v-on:click="setTab('danger')">
                    <i class="fa-solid fa-circle text-danger" style="font-size: 8px;"></i>
                    Khẩn cấp <span class="badge-pill">${ counts.Danger }</span>
                </button>
                <button class="alert-tab-btn tab-warning" :class="{ active: activeTab === 'warning' }" v-on:click="setTab('warning')">
                    <i class="fa-solid fa-circle text-warning" style="font-size: 8px;"></i>
                    Cảnh báo <span class="badge-pill">${ counts.Warning }</span>
                </button>
                <button class="alert-tab-btn tab-info" :class="{ active: activeTab === 'info' }" v-on:click="setTab('info')">
                    <i class="fa-solid fa-circle text-info" style="font-size: 8px;"></i>
                    Thông tin <span class="badge-pill">${ counts.Info }</span>
                </button>
            </div>
            
            <div class="d-flex align-items-center gap-2">
                <button class="btn-ghost topbar-btn font-weight-bold text-success" 
                        v-if="hasPermission('Alerts', 'EDIT') && filteredAlerts.length > 0" 
                        v-on:click="resolveAllVisible" 
                        style="padding: 7px 16px; border-radius: 20px; font-size: 13px;">
                    <i class="fa-solid fa-check-double mr-1"></i> Xác nhận tất cả (${ filteredAlerts.length })
                </button>
                <button class="btn-ghost topbar-btn font-weight-bold" 
                        v-if="hasPermission('Alerts', 'EDIT')" 
                        v-on:click="setView('config')" 
                        style="padding: 7px 16px; border-radius: 20px; font-size: 13px;">
                    <i class="fa-solid fa-sliders mr-1"></i> Cấu hình quy tắc
                </button>
            </div>
        </div>

        <!-- Loading State -->
        <div v-if="loading" class="text-center py-5">
            <div class="spinner-border spinner-border-sm text-primary" role="status" style="width: 2rem; height: 2rem;"></div>
            <p class="text-muted mt-2 font-weight-bold" style="font-size: 13px;">Đang tải danh sách cảnh báo...</p>
        </div>

        <!-- Danh sách cảnh báo thực tế -->
        <div v-else class="alerts-list">
            <div v-for="alert in filteredAlerts" 
                 :key="alert.Id" 
                 class="alert-card" 
                 :class="'alert-' + alert.Severity"
                 v-on:click="onCardClick(alert, $event)">
                
                <!-- Dismiss button in top-right corner of card -->
                <button class="alert-dismiss-btn" v-if="hasPermission('Alerts', 'EDIT')" v-on:click="resolveAlert(alert.Id)" title="Xác nhận đã xử lý">
                    <i class="fa-solid fa-check"></i>
                </button>
                
                <!-- Left circular icon -->
                <div class="alert-icon-wrapper">
                    <i :class="severityIcon(alert.Severity)"></i>
                </div>
                
                <!-- Main details -->
                <div class="alert-card-content">
                    <div class="alert-card-header">
                        <div class="alert-device-title">
                            <span>${ alert.ItemName }</span>
                            <span class="alert-device-id">ID: ${ alert.AssetCode }</span>
                        </div>
                        <span class="alert-severity-badge">${ severityLabel(alert.Severity) }</span>
                    </div>
                    
                    <div class="alert-body-text" v-text="alert.Body"></div>
                    
                    <div class="alert-card-footer">
                        <div class="alert-footer-item">
                            <i class="fa-regular fa-clock"></i>
                            <span>Ghi nhận: ${ alert.CreatedTimeStr } - ${ alert.CreatedAtStr }</span>
                        </div>
                        <div class="alert-footer-item" v-if="alert.LocationName || alert.DepartmentName">
                            <i class="fa-solid fa-location-dot"></i>
                            <span>${ alert.DepartmentName } (${ alert.LocationName })</span>
                        </div>
                    </div>
                </div>
                
                <!-- Right Action buttons -->
                <div class="alert-card-actions">
                    <template v-if="hasPermission('Alerts', 'EDIT')">
                        <!-- 1. MULTI_FAULT_3X (Fault count too high) -->
                        <template v-if="alert.RuleCode === 'MULTI_FAULT_3X'">
                            <button class="btn-alert-action btn-action-danger" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="liquidateAsset(alert)">
                                <i class="fa-solid fa-dumpster mr-1" v-if="!processingAlerts[alert.Id]"></i>
                                <span v-else class="spinner-border spinner-border-sm mr-1" style="width: 12px; height: 12px;"></span>
                                Thanh lý thiết bị
                            </button>
                            <button class="btn-alert-action btn-action-secondary" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="handleAction(alert, 'repair')">
                                Sửa chữa
                            </button>
                        </template>

                        <!-- 2. WARRANTY_EXPIRY_30D (Warranty about to expire) -->
                        <template v-else-if="alert.RuleCode === 'WARRANTY_EXPIRY_30D'">
                            <button class="btn-alert-action btn-action-success" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="extendWarranty(alert)">
                                <i class="fa-solid fa-circle-plus mr-1" v-if="!processingAlerts[alert.Id]"></i>
                                <span v-else class="spinner-border spinner-border-sm mr-1" style="width: 12px; height: 12px;"></span>
                                Gia hạn nhanh
                            </button>
                            <button class="btn-alert-action btn-action-secondary" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="handleAction(alert, 'warranty')">
                                Gia hạn thủ công
                            </button>
                        </template>

                        <!-- 3. CHECKLIST_OVERDUE (Maintenance checklists) -->
                        <template v-else-if="alert.RuleCode === 'CHECKLIST_OVERDUE' || alert.RuleCode === 'CHECKLIST_DUE_3D'">
                            <button class="btn-alert-action btn-action-success" 
                                    v-on:click="goToPerformChecklist(alert.InventoryId)">
                                <i class="fa-solid fa-list-check mr-1"></i> Làm Checklist
                            </button>
                            <button class="btn-alert-action btn-action-primary" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="completeChecklist(alert, 'done')">
                                <i class="fa-solid fa-check mr-1" v-if="!processingAlerts[alert.Id]"></i>
                                <span v-else class="spinner-border spinner-border-sm mr-1" style="width: 12px; height: 12px;"></span>
                                Đã kiểm tra
                            </button>
                            <button class="btn-alert-action btn-action-secondary" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="completeChecklist(alert, 'skipped')">
                                Bỏ qua lần này
                            </button>
                        </template>

                        <!-- 4. CONSUMABLES_LOW (Consumables stock low) -->
                        <template v-else-if="alert.RuleCode === 'CONSUMABLES_LOW' || alert.Title === 'Vật tư tiêu hao sắp hết'">
                            <!-- Inline Restock controls -->
                            <div class="inline-restock-group mb-1">
                                <input type="number" 
                                       class="form-control-custom restock-input" 
                                       placeholder="SL" 
                                       min="1" 
                                       v-model.number="restockQuantities[alert.Id]"
                                       :disabled="processingAlerts[alert.Id]"
                                       style="width: 50px; height: 32px; padding: 4px 6px; font-size: 11.5px; border-radius: 8px; text-align: center; margin-right: 4px;" />
                                <button class="btn-alert-action btn-action-success restock-btn" 
                                        :disabled="processingAlerts[alert.Id]"
                                        v-on:click="restockConsumable(alert, restockQuantities[alert.Id] || 10)"
                                        style="padding: 6px 10px; font-size: 11.5px; border-radius: 8px; width: auto; height: 32px; display: inline-flex; align-items: center; justify-content: center; gap: 4px; flex: 1;">
                                    <i class="fa-solid fa-plus" v-if="!processingAlerts[alert.Id]"></i>
                                    <span v-else class="spinner-border spinner-border-sm" style="width: 10px; height: 10px;"></span>
                                    Nhập kho
                                </button>
                            </div>
                            <button class="btn-alert-action btn-action-secondary" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="handleAction(alert, 'order')">
                                Đặt hàng
                            </button>
                        </template>

                        <!-- 5. Default Fallback action -->
                        <template v-else>
                            <button class="btn-alert-action btn-action-primary" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="resolveAlert(alert.Id)">
                                <span v-if="processingAlerts[alert.Id]" class="spinner-border spinner-border-sm mr-1" style="width: 12px; height: 12px;"></span>
                                Đã xử lý
                            </button>
                            <button class="btn-alert-action btn-action-secondary" 
                                    :disabled="processingAlerts[alert.Id]"
                                    v-on:click="handleAction(alert, 'view')">
                                Xem chi tiết
                            </button>
                        </template>
                    </template>
                    <template v-else>
                        <button class="btn-alert-action btn-action-secondary" 
                                :disabled="processingAlerts[alert.Id]"
                                v-on:click="handleAction(alert, 'view')"
                                style="width: 100%;">
                            Xem chi tiết
                        </button>
                    </template>
                </div>

            </div>

            <!-- Empty State -->
            <div v-if="filteredAlerts.length === 0" class="alerts-empty-state">
                <i class="fa-solid fa-bell-slash empty-icon"></i>
                <div class="empty-title">Không có cảnh báo hoạt động</div>
                <p class="m-0 text-muted" style="font-size: 13px;">Tất cả thiết bị y tế trong hệ thống đều đang hoạt động bình thường.</p>
            </div>
        </div>

    </div>

    <!-- ── MÀN HÌNH 2: CẤU HÌNH QUY TẮC CẢNH BÁO ── -->
    <div v-if="activeView === 'config'">
        
        <!-- Header Breadcrumb & Actions -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 bg-transparent p-0" style="font-size: 12px;">
                        <li class="breadcrumb-item text-secondary font-weight-bold">Cấu hình hệ thống</li>
                        <li class="breadcrumb-item text-primary font-weight-bold active" aria-current="page">Quy tắc Cảnh báo</li>
                    </ol>
                </nav>
                <h4 class="font-weight-bold mt-1 mb-0 text-dark" style="font-size: 19px;">Cấu hình Quy tắc Cảnh báo</h4>
                <p class="text-muted m-0" style="font-size: 12.5px;">Thiết lập ngưỡng kích hoạt và phương thức thông báo cho toàn hệ thống.</p>
            </div>
            
            <div class="config-actions-bar">
                <button class="topbar-btn btn-ghost font-weight-bold" v-on:click="setView('alerts')" :disabled="saving">Hủy bỏ</button>
                <button class="topbar-btn btn-outline-success font-weight-bold mr-2" v-on:click="forceScan" :disabled="saving" style="border-radius: 20px; padding: 7px 16px; font-size: 13px;">
                    <i class="fa-solid fa-magnifying-glass-chart mr-1"></i> Quét cảnh báo ngay
                </button>
                <button class="topbar-btn btn-primary font-weight-bold" v-on:click="saveConfig" :disabled="saving">
                    <span v-if="saving" class="spinner-border spinner-border-sm mr-1"></span>
                    Lưu cấu hình
                </button>
            </div>
        </div>

        <!-- Sub-tabs Segmented Control -->
        <div class="config-tabs-nav mb-4" style="animation: fadeIn 0.2s;">
            <button class="config-tab-btn" :class="{ active: configTab === 'rules' }" v-on:click="configTab = 'rules'">
                <i class="fa-solid fa-sliders"></i>
                <span>Quy tắc chẩn đoán</span>
            </button>
            <button class="config-tab-btn" :class="{ active: configTab === 'consumables' }" v-on:click="configTab = 'consumables'">
                <i class="fa-solid fa-boxes-packing"></i>
                <span>Vật tư tiêu hao</span>
            </button>
            <button class="config-tab-btn" :class="{ active: configTab === 'routing' }" v-on:click="configTab = 'routing'">
                <i class="fa-solid fa-users-gear"></i>
                <span>Kênh & Vai trò</span>
            </button>
            <button class="config-tab-btn" :class="{ active: configTab === 'logs' }" v-on:click="configTab = 'logs'">
                <i class="fa-solid fa-clock-rotate-left"></i>
                <span>Nhật ký thay đổi</span>
            </button>
        </div>

        <div class="config-grid">
            
            <!-- 1. Quy tắc lỗi lặp lại (Multi-fault) -->
            <div class="config-card" v-show="configTab === 'rules'">
                <div>
                    <div class="config-header">
                        <div class="config-title-group">
                            <div class="config-icon-box bg-danger-light">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                            </div>
                            <div>
                                <div class="config-title">Quy tắc lỗi lặp lại (Multi-fault)</div>
                                <div class="config-desc">Đề xuất thanh lý khi thiết bị có tần suất hỏng hóc cao.</div>
                            </div>
                        </div>
                        <label class="switch-control">
                            <input type="checkbox" v-model="configForm.multiFault.isActive">
                            <span class="switch-slider"></span>
                        </label>
                    </div>

                    <div v-show="configForm.multiFault.isActive" style="animation: fadeIn 0.2s;">
                        <!-- Ngưỡng số lần hỏng hóc -->
                        <div class="slider-group">
                            <div class="slider-labels">
                                <span class="text-secondary">Ngưỡng số lần hỏng hóc chung</span>
                                <span class="slider-val-tag">${ configForm.multiFault.count } lần</span>
                            </div>
                            <input type="range" 
                                   class="custom-range-slider" 
                                   min="1" 
                                   max="10" 
                                   v-model="configForm.multiFault.count" />
                            <div class="d-flex justify-content-between text-muted mt-1" style="font-size: 10px; font-weight: 600;">
                                <span>1 lần</span>
                                <span>10 lần</span>
                            </div>
                        </div>

                        <!-- Thời gian theo dõi lỗi -->
                        <div class="slider-group mt-3">
                            <div class="slider-labels">
                                <span class="text-secondary">Thời gian theo dõi tần suất lỗi chung</span>
                                <span class="slider-val-tag">${ configForm.multiFault.period } ngày</span>
                            </div>
                            <input type="range" 
                                   class="custom-range-slider" 
                                   min="5" 
                                   max="120" 
                                   v-model="configForm.multiFault.period" />
                            <div class="d-flex justify-content-between text-muted mt-1" style="font-size: 10px; font-weight: 600;">
                                <span>5 ngày</span>
                                <span>120 ngày</span>
                            </div>
                        </div>

                        <!-- Cấu hình đắc thù nhóm thiết bị -->
                        <div class="mt-3 border-top pt-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="font-weight-bold text-secondary" style="font-size: 12px;"><i class="fa-solid fa-layer-group mr-1"></i> Ngưỡng đắc thù theo nhóm thiết bị</span>
                                <button class="btn btn-sm btn-outline-primary" style="font-size: 11px; border-radius: 12px; padding: 2px 10px;" v-on:click="addOverride('multiFault')">
                                    <i class="fa-solid fa-plus mr-1"></i> Thêm nhóm
                                </button>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <div v-for="(ov, idx) in configForm.multiFault.overrides" :key="idx" class="override-row-item">
                                    <select class="form-control-custom" v-model="ov.groupCode" v-on:change="onOverrideGroupChange('multiFault', idx, ov.groupCode)" style="width: 150px;">
                                        <option v-for="g in deviceGroups" :value="g.code">${ g.name }</option>
                                    </select>
                                    <span class="text-muted">Hỏng &ge;</span>
                                    <input type="number" class="form-control-custom text-center" v-model.number="ov.count" min="1" max="10" style="width: 45px;" />
                                    <span class="text-muted">lần trong</span>
                                    <input type="number" class="form-control-custom text-center" v-model.number="ov.period" min="5" max="120" style="width: 50px;" />
                                    <span class="text-muted">ngày</span>
                                    <button class="btn btn-sm text-danger ml-auto p-0" v-on:click="removeOverride('multiFault', idx)" title="Xóa đặc thù">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                                <div v-if="configForm.multiFault.overrides.length === 0" class="text-muted text-center py-2" style="font-size: 11px; border: 1px dashed var(--border); border-radius: 8px;">
                                    Áp dụng chung cho toàn bộ nhóm thiết bị.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. Bảo hành thiết bị -->
            <div class="config-card" v-show="configTab === 'rules'">
                <div>
                    <div class="config-header">
                        <div class="config-title-group">
                            <div class="config-icon-box bg-success-light">
                                <i class="fa-solid fa-shield-halved"></i>
                            </div>
                            <div>
                                <div class="config-title">Hạn bảo hành thiết bị</div>
                                <div class="config-desc">Cảnh báo trước khi hết hạn bảo hành để lên kế hoạch gia hạn.</div>
                            </div>
                        </div>
                        <label class="switch-control">
                            <input type="checkbox" v-model="configForm.warranty.isActive">
                            <span class="switch-slider"></span>
                        </label>
                    </div>

                    <div v-show="configForm.warranty.isActive" style="animation: fadeIn 0.2s;">
                        <div class="field-row">
                            <div class="field-col">
                                <label class="field-label">Thời gian thông báo trước chung (ngày)</label>
                                <input type="number" 
                                       class="form-control-custom" 
                                       v-model="configForm.warranty.days" 
                                       min="5" 
                                       max="180" />
                            </div>
                        </div>

                        <!-- Cấu hình đắc thù nhóm thiết bị -->
                        <div class="mt-3 border-top pt-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="font-weight-bold text-secondary" style="font-size: 12px;"><i class="fa-solid fa-layer-group mr-1"></i> Ngưỡng đắc thù theo nhóm thiết bị</span>
                                <button class="btn btn-sm btn-outline-primary" style="font-size: 11px; border-radius: 12px; padding: 2px 10px;" v-on:click="addOverride('warranty')">
                                    <i class="fa-solid fa-plus mr-1"></i> Thêm nhóm
                                </button>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <div v-for="(ov, idx) in configForm.warranty.overrides" :key="idx" class="override-row-item">
                                    <select class="form-control-custom" v-model="ov.groupCode" v-on:change="onOverrideGroupChange('warranty', idx, ov.groupCode)" style="width: 150px;">
                                        <option v-for="g in deviceGroups" :value="g.code">${ g.name }</option>
                                    </select>
                                    <span class="text-muted">Báo trước:</span>
                                    <input type="number" class="form-control-custom text-center" v-model.number="ov.days" min="5" max="180" style="width: 45px;" />
                                    <span class="text-muted">ngày</span>
                                    <button class="btn btn-sm text-danger ml-auto p-0" v-on:click="removeOverride('warranty', idx)" title="Xóa đặc thù">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </div>
                                <div v-if="configForm.warranty.overrides.length === 0" class="text-muted text-center py-2" style="font-size: 11px; border: 1px dashed var(--border); border-radius: 8px;">
                                    Áp dụng chung cho toàn bộ nhóm thiết bị.
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex align-items-center mt-3 gap-2 border-top pt-2">
                            <input type="checkbox" id="kembc" v-model="configForm.warranty.costReport" style="width: 15px; height: 15px; cursor: pointer;">
                            <label for="kembc" class="m-0 font-weight-bold text-secondary" style="font-size: 12px; cursor: pointer;">Kèm báo cáo dự toán chi phí thay thế</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. Khấu hao & Hạn sử dụng (Lifecycle) -->
            <div class="config-card" v-show="configTab === 'rules'">
                <div>
                    <div class="config-header">
                        <div class="config-title-group">
                            <div class="config-icon-box bg-info-light">
                                <i class="fa-solid fa-hourglass-half"></i>
                            </div>
                            <div>
                                <div class="config-title">Khấu hao & Hạn sử dụng</div>
                                <div class="config-desc">Giám sát hạn sử dụng hữu ích và chu kỳ khấu hao tài sản.</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-3 mt-3">
                        <!-- Expiry Rule -->
                        <div class="p-3 border rounded bg-white">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="font-weight-bold text-dark m-0" style="font-size: 12.5px;">Gần hết hạn sử dụng (Expiry)</label>
                                <label class="switch-control">
                                    <input type="checkbox" v-model="configForm.expiry.isActive">
                                    <span class="switch-slider"></span>
                                </label>
                            </div>
