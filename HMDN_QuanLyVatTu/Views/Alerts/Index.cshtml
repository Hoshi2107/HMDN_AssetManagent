                </div>
            </div>

            <!-- 8. Lịch sử logs thay đổi cấu hình (Audit Log) -->
            <div class="config-card config-fullwidth" v-show="configTab === 'logs'">
                <div>
                    <div class="config-header mb-3">
                        <div class="config-title-group">
                            <div class="config-icon-box bg-secondary-light">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                            </div>
                            <div>
                                <div class="config-title">Nhật ký thay đổi Cấu hình (Audit Log)</div>
                                <div class="config-desc">Lịch sử điều chỉnh tham số, ngưỡng và trạng thái quy tắc cảnh báo của các quản trị viên hệ thống.</div>
                            </div>
                        </div>
                    </div>

                    <div class="timeline-logs p-2" style="max-height: 250px; overflow-y: auto;">
                        <div v-for="(log, idx) in configLogs" :key="idx" class="d-flex align-items-start gap-3 mb-3 border-bottom pb-2" style="font-size: 12.5px; line-height: 1.4;">
                            <div class="text-muted font-weight-bold" style="min-width: 125px;">${ log.time }</div>
                            <div class="badge badge-info px-2 py-1" style="font-size: 10px; border-radius: 8px;">${ log.user }</div>
                            <div class="text-dark font-weight-bold flex-grow-1">${ log.action }</div>
                        </div>
                        <div v-if="configLogs.length === 0" class="text-muted text-center py-4">
                            Không tìm thấy nhật ký thay đổi nào.
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section scripts {
    <script src="@Url.Content("~/Scripts/app/alerts.js?v=" + DateTime.Now.Ticks)"></script>
}
