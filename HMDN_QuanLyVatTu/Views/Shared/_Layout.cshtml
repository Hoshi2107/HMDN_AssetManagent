        <div class="page-wrapper">
            <header class="page-topbar">
                <div class="topbar-left">
                    <button class="btn-toggle-sidebar" onclick="toggleSidebarLayout()" title="Thu gọn/Mở rộng Menu">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <span class="topbar-title">@(ViewBag.PageTitle ?? ViewBag.Title ?? "Dashboard")</span>
                </div>
                
                <div style="display: flex; align-items: center; gap: 20px;">
                    @RenderSection("topbar_actions", required: false)
                    
                    @if (HasModule("Alerts"))
                    {
                        <div id="notification-app" style="position: relative;">
                            <button v-on:click="toggleDropdown($event)" style="background: none; border: none; font-size: 18px; color: #64748b; cursor: pointer; position: relative;">
                                <i class="fa-solid fa-bell"></i>
                                <span v-if="unreadCount > 0" style="position: absolute; top: -5px; right: -5px; background: var(--accent-red); color: white; font-size: 9px; font-weight: 700; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid #fff;">{{ unreadCount }}</span>
                            </button>

                            <div v-if="isOpen" v-on:click.stop style="position: absolute; top: 120%; right: 0; width: 340px; background: #fff; border-radius: 12px; border: 1px solid var(--border); box-shadow: 0 10px 25px rgba(0,0,0,0.1); z-index: 1000; overflow: hidden;">
                                <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px; border-bottom: 1px solid var(--border); background: #f8fafc;">
                                    <span style="font-weight: 700; font-size: 14px; color: #1e2a3a;">Thông báo</span>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <label style="display:flex; align-items:center; cursor:pointer; font-size:12px; color:#64748b; font-weight:500;" title="Chặn hiển thị popup thông báo (Trừ thông báo khẩn)">
                                            <input type="checkbox" style="margin-right:6px;" v-model="isDndEnabled"> Tắt Popup
                                        </label>
                                        <button v-on:click="markAllAsRead" style="background: none; border: none; color: var(--accent-blue); font-size: 12px; font-weight: 600; cursor: pointer;">Đọc tất cả</button>
                                    </div>
                                </div>
                                <div style="max-height: 300px; overflow-y: auto;">
                                    <div v-if="alerts.length === 0" style="padding: 30px; text-align: center; color: #94a3b8; font-size: 13px;">
                                        Không có thông báo mới.
                                    </div>
                                    <div v-else v-for="alert in alerts" :key="alert.Id" v-on:click="goToAlert(alert)" style="display: flex; gap: 12px; padding: 16px; border-bottom: 1px solid var(--border); cursor: pointer;" :style="isUnread(alert.Id) ? 'background: #f0f9ff;' : 'background: #fff;'">
                                        <div class="toast-mockup-icon-circle" :class="alert.Severity">
                                            <i class="fa-solid" :class="getIconClass(alert.Severity)"></i>
                                        </div>
                                        <div style="flex: 1;">
                                            <div style="font-size: 13px; font-weight: 700; color: #1e2a3a; margin-bottom: 4px;">{{ alert.Title }}</div>
                                            <div style="font-size: 12px; color: #64748b; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ alert.Body || (alert.ItemName + ' - Thiết bị gặp sự cố.') }}</div>
                                            <div style="font-size: 11px; color: #94a3b8; margin-top: 6px;">{{ alert.CreatedAtFriendly || alert.CreatedAtStr }}</div>
                                        </div>
                                    </div>
                                </div>
                                <div style="padding: 12px; text-align: center; border-top: 1px solid var(--border); background: #f8fafc;">
                                    <a href="@Url.Action("Index", "Alerts")" style="font-size: 13px; font-weight: 600; color: var(--hm-teal);">Xem tất cả thông báo</a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (Session["FullName"] != null)
                    {
                        <div style="display: flex; align-items: center; gap: 10px; padding: 6px 14px; background: var(--body-bg); border-radius: 20px; font-size: 13px; border: 1px solid var(--border);">
                            <i class="fa-solid fa-circle-user" style="color: var(--hm-navy); font-size: 18px;"></i>
                            <span style="font-weight: 600; color: #1e2a3a;">@Session["FullName"]</span>
                            <a href="@Url.Action("Logout", "Account")" title="Đăng xuất" style="margin-left: 8px; color: var(--accent-red);"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
                        </div>
                    }
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="toast-container"></div>

    @Scripts.Render("~/bundles/bootstrap")

    <script>
        function toggleSidebarLayout() {
            if (window.innerWidth <= 768) {
                document.body.classList.toggle('sidebar-open');
                document.body.classList.remove('sidebar-collapsed');
            } else {
                document.body.classList.toggle('sidebar-collapsed');
                document.body.classList.remove('sidebar-open');
                localStorage.setItem('sidebar_state', document.body.classList.contains('sidebar-collapsed') ? 'collapsed' : 'expanded');
            }
        }

        function toggleNavSection(sectionId) {
            if (document.body.classList.contains('sidebar-collapsed') && window.innerWidth > 768) return;
            var element = document.getElementById(sectionId);
            if (element) {
                element.classList.toggle('collapsed');
                localStorage.setItem('section_state_' + sectionId, element.classList.contains('collapsed') ? 'collapsed' : 'expanded');
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            if (localStorage.getItem('sidebar_state') === 'collapsed' && window.innerWidth > 768) {
                document.body.classList.add('sidebar-collapsed');
            }
            var sections = document.querySelectorAll('.nav-section');
            sections.forEach(function(sec) {
                var state = localStorage.getItem('section_state_' + sec.id);
                if (state === 'collapsed') {
                    sec.classList.add('collapsed');
                }
            });
        });
    </script>

    <script>
        window.getAlertRedirectUrl = function (alert) {
            if (!alert) return '@Url.Action("Index", "Alerts")';
            var code = alert.RuleCode || alert.ruleCode || '';
            var invId = alert.InventoryId || alert.inventoryId || 0;
            var assetCode = alert.AssetCode || alert.assetCode || '';
            if (code === 'MULTI_FAULT_3X') return '@Url.Action("Index", "Maintenance")' + '?inventoryId=' + invId + '&triggerCreate=1';
            if (code === 'WARRANTY_EXPIRY_30D' || code === 'EXPIRY_SOON_60D' || code === 'DEPRECIATION_END_30D') return '/VongDoiKhauHao/VongDoiKhauHao?searchCode=' + assetCode + '&inventoryId=' + invId;
            if (code === 'CHECKLIST_OVERDUE' || code === 'CHECKLIST_DUE_3D') return '@Url.Action("Index", "Checklists")' + '?inventoryId=' + invId;
            if (code === 'CONSUMABLES_LOW') return '@Url.Action("Index", "Inventory")' + '?searchCode=' + assetCode + '&inventoryId=' + invId;
            return '@Url.Action("Index", "Alerts")';
        };

        window.isAlertRelevantToCurrentPage = function (alert) {
            if (!alert) return false;
            var path = window.location.pathname.toLowerCase();
            var code = alert.RuleCode || alert.ruleCode || '';
            if (path.indexOf('/alerts') !== -1) return false;
            if (path.indexOf('/inventory') !== -1) return code === 'CONSUMABLES_LOW';
            if (path.indexOf('/maintenance') !== -1) return code === 'MULTI_FAULT_3X';
            if (path.indexOf('/checklists') !== -1) return code === 'CHECKLIST_OVERDUE' || code === 'CHECKLIST_DUE_3D';
            if (path.indexOf('/vongdoikhauhao') !== -1) return code === 'WARRANTY_EXPIRY_30D' || code === 'EXPIRY_SOON_60D' || code === 'DEPRECIATION_END_30D';
            return false;
        };

        window.MedEquip = window.MedEquip || {};
        MedEquip.toggleDND = function (isDndEnabled) {
            localStorage.setItem('notificationsEnabled', !isDndEnabled);
        };

        MedEquip.toast = function (title, message, type, alertObj) {
            type = type || 'info';
            var notificationsEnabled = localStorage.getItem('notificationsEnabled');
            var isDndEnabled = notificationsEnabled === 'false';
            if (isDndEnabled && type !== 'danger') return;

            var id = 'toast-' + Date.now() + '-' + Math.floor(Math.random() * 10000);
            var redirectUrl = alertObj ? window.getAlertRedirectUrl(alertObj) : '';
            var onclickAttr = redirectUrl ? ' onclick="window.location.href=\'' + redirectUrl + '\';"' : '';
            var icon = type === 'danger' || type === 'warning' ? 'fa-bell' : 'fa-info';
            
            var html = '<div class="toast-mockup toast-mockup-' + type + '" id="' + id + '"' + onclickAttr + ' style="cursor: pointer;">'
                + '<div class="toast-mockup-icon-circle ' + type + '"><i class="fa-solid ' + icon + '"></i></div>'
                + '<div class="toast-mockup-body">'
                + '<div class="toast-mockup-title">' + title + '</div>'
                + '<div class="toast-mockup-msg">' + message + '</div>'
                + '</div>'
                + '<button class="toast-mockup-close" onclick="MedEquip.closeToast(\'' + id + '\'); event.stopPropagation();"><i class="fa-solid fa-xmark"></i></button></div>';

            document.getElementById('toast-container').insertAdjacentHTML('beforeend', html);
            setTimeout(function () { MedEquip.closeToast(id); }, 7000);
        };

        MedEquip.closeToast = function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.style.opacity = '0';
                el.style.transform = 'translateX(20px)';
                setTimeout(function () { el.remove(); }, 300);
            }
        };



        (function () {
            var currentPath = window.location.pathname.toLowerCase();
            var segments = currentPath.split('/').filter(Boolean);
            var currentController = segments[0] || '';
            var currentAction = segments[1] || 'index';

            if (currentController) {
                document.querySelectorAll('.nav-item a').forEach(function (a) {
                    var hrefSegments = (a.getAttribute('href') || '').toLowerCase().split('/').filter(Boolean);
                    if ((hrefSegments[0] || '') === currentController && (hrefSegments[1] || 'index') === currentAction) {
                        document.querySelectorAll('.nav-item').forEach(function (li) { li.classList.remove('active'); });
                        var navItem = a.closest('.nav-item');
                        navItem.classList.add('active');
                        var parentSection = navItem.closest('.nav-section');
                        if (parentSection) parentSection.classList.remove('collapsed');
                    }
                });
            }
        })();
    </script>

    @if (HasModule("Alerts"))
    {
        <script>
            $(document).ready(function () {
                var currentUserId = @(Session["UserId"] ?? 1);
                var seenKey = 'seen_alerts_' + currentUserId;
                var readKey = 'read_alerts_' + currentUserId;

                new Vue({
                    el: '#notification-app',
                    data: {
                        alerts: [],
                        seenAlerts: [],
                        readAlerts: [],
                        isOpen: false,
                        isFirstLoad: true,
                        isDndEnabled: localStorage.getItem('notificationsEnabled') === 'false'
                    },
                    watch: {
                        isDndEnabled: function (newVal) {
                            localStorage.setItem('notificationsEnabled', newVal ? 'false' : 'true');
                        }
                    },
                    computed: {
                        unreadCount: function () {
                            var vm = this;
                            return vm.alerts.filter(function (a) { return vm.readAlerts.indexOf(a.Id) === -1; }).length;
                        }
                    },
                    methods: {
                        loadData: function () {
                            try { this.seenAlerts = JSON.parse(localStorage.getItem(seenKey)) || []; } catch(e) { this.seenAlerts = []; }
                            try { this.readAlerts = JSON.parse(localStorage.getItem(readKey)) || []; } catch(e) { this.readAlerts = []; }
                        },
                        saveData: function () {
                            if (this.seenAlerts.length > 200) this.seenAlerts = this.seenAlerts.slice(-200);
                            localStorage.setItem(seenKey, JSON.stringify(this.seenAlerts));
                            localStorage.setItem(readKey, JSON.stringify(this.readAlerts));
                        },
                        toggleDropdown: function (e) {
                            if(e) e.stopPropagation();
                            this.isOpen = !this.isOpen;
                            if (this.isOpen) this.markAllAsRead();
                        },
                        markAllAsRead: function () {
                            var vm = this, changed = false;
                            vm.alerts.forEach(function (a) {
                                if (vm.readAlerts.indexOf(a.Id) === -1) { vm.readAlerts.push(a.Id); changed = true; }
                            });
                            if (changed) vm.saveData();
                        },
                        isUnread: function (id) { return this.readAlerts.indexOf(id) === -1; },
                        getIconClass: function (sev) { return sev === 'danger' ? 'fa-triangle-exclamation' : sev === 'warning' ? 'fa-circle-exclamation' : 'fa-circle-info'; },
                        goToAlert: function (a) {
                            if (this.readAlerts.indexOf(a.Id) === -1) {
                                this.readAlerts.push(a.Id);
                                this.saveData();
                            }
                            window.location.href = window.getAlertRedirectUrl(a);
                        },
                        checkAlerts: function () {
                            var vm = this;
                            $.ajax({
                                url: '@Url.Content("~/api/alerts/check-new")', type: 'GET', 
                                success: function (res) {
                                    vm.loadData();
                                    if (res && res.length > 0) {
                                        var hasNew = false;
                                        res.forEach(function (alert) {
                                            if (window.isAlertRelevantToCurrentPage(alert) && vm.seenAlerts.indexOf(alert.Id) === -1) {
                                                vm.seenAlerts.push(alert.Id); hasNew = true;
                                                if (!vm.isFirstLoad && window.MedEquip) {
                                                    var type = alert.Severity === 'danger' ? 'danger' : alert.Severity === 'warning' ? 'warning' : 'info';
                                                    window.MedEquip.toast(alert.Title, alert.Body || (alert.ItemName + ' - Thiết bị gặp sự cố.'), type, alert);
                                                }
                                            }
                                        });
                                        vm.isFirstLoad = false;
                                        if (hasNew) vm.saveData();
                                        vm.alerts = res;
                                    } else { vm.alerts = []; vm.isFirstLoad = false; }
                                }
                            });
                        }
                    },
                    mounted: function () {
                        var vm = this;
                        vm.loadData(); vm.checkAlerts();
                        document.addEventListener('click', function () { vm.isOpen = false; });
                        setInterval(vm.checkAlerts, 15000);
                    }
                });
            });
        </script>
    }
    @RenderSection("scripts", required: false)
</body>
</html>