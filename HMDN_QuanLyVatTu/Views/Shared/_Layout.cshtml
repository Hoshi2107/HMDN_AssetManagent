    <div id="toast-container"></div>

    @Scripts.Render("~/bundles/bootstrap")

    <script>
        // ── Redirect utility ──────────────────────────────────
        window.getAlertRedirectUrl = function (alert) {
            if (!alert) return '/Alerts/Index';
            var code = alert.RuleCode || alert.ruleCode || '';
            var invId = alert.InventoryId || alert.inventoryId || 0;
            var assetCode = alert.AssetCode || alert.assetCode || '';
            
            if (code === 'MULTI_FAULT_3X') {
                return '/Maintenance/Index?inventoryId=' + invId + '&triggerCreate=1';
            }
            if (code === 'WARRANTY_EXPIRY_30D') {
                return '/VongDoiKhauHao/VongDoiKhauHao?searchCode=' + assetCode + '&inventoryId=' + invId;
            }
            if (code === 'CHECKLIST_OVERDUE' || code === 'CHECKLIST_DUE_3D') {
                return '/Checklists/Index?inventoryId=' + invId;
            }
            if (code === 'CONSUMABLES_LOW') {
                return '/Inventory/Index?searchCode=' + assetCode + '&inventoryId=' + invId;
            }
            if (code === 'EXPIRY_SOON_60D' || code === 'DEPRECIATION_END_30D') {
                return '/VongDoiKhauHao/VongDoiKhauHao?searchCode=' + assetCode + '&inventoryId=' + invId;
            }
            return '/Alerts/Index';
        };

        // ── Relevance utility ─────────────────────────────────
        window.isAlertRelevantToCurrentPage = function (alert) {
            if (!alert) return false;
            var path = window.location.pathname.toLowerCase();
            var code = alert.RuleCode || alert.ruleCode || '';

            if (path.indexOf('/alerts') !== -1) {
                return false;
            }
            if (path.indexOf('/inventory') !== -1) {
                return code === 'CONSUMABLES_LOW';
            }
            if (path.indexOf('/maintenance') !== -1) {
                return code === 'MULTI_FAULT_3X';
            }
            if (path.indexOf('/checklists') !== -1) {
                return code === 'CHECKLIST_OVERDUE' || code === 'CHECKLIST_DUE_3D';
            }
            if (path.indexOf('/vongdoikhauhao') !== -1) {
                return code === 'WARRANTY_EXPIRY_30D' || code === 'EXPIRY_SOON_60D' || code === 'DEPRECIATION_END_30D';
            }
            return false;
        };

        // ── Toast utility ──────────────────────────────────────
        window.MedEquip = window.MedEquip || {};

        MedEquip.toast = function (title, message, type, alertObj) {
            type = type || 'warning';
            
            // Ngăn chặn hiển thị lặp lại thông báo có cùng tiêu đề và nội dung đang hiển thị trên màn hình (Edge Case 1)
            var isDuplicate = false;
            var toasts = document.getElementsByClassName('toast-mockup');
            for (var i = 0; i < toasts.length; i++) {
                var existingTitleEl = toasts[i].getElementsByClassName('toast-mockup-title')[0];
                var existingMsgEl = toasts[i].getElementsByClassName('toast-mockup-msg')[0];
                if (existingTitleEl && existingMsgEl) {
                    if (existingTitleEl.innerText.trim() === title.trim() && existingMsgEl.innerText.trim() === message.trim()) {
                        isDuplicate = true;
                        break;
                    }
                }
            }
            if (isDuplicate) return;

            // Giới hạn số lượng toast hiển thị đồng thời tối đa là 3. Nếu vượt quá, xóa các toast cũ nhất.
            var maxToasts = 3;
            while (toasts.length >= maxToasts) {
                var oldestToast = toasts[0];
                if (oldestToast && oldestToast.parentNode) {
                    oldestToast.parentNode.removeChild(oldestToast);
                } else {
                    break;
                }
            }

            var redirectUrl = '';
            if (alertObj) {
                redirectUrl = window.getAlertRedirectUrl(alertObj);
            }

            // Dùng ID độc bản kết hợp thời gian và số ngẫu nhiên
            var id = 'toast-' + Date.now() + '-' + Math.floor(Math.random() * 10000);
            
            var badgeText = 'THÔNG BÁO MỚI';
            if (type === 'danger') badgeText = 'CẢNH BÁO KHẨN CẤP';
            else if (type === 'warning') badgeText = 'CẢNH BÁO MỚI';
            else if (type === 'info' || type === 'success') badgeText = 'THÔNG TIN MỚI';

            var onclickAttr = redirectUrl ? ' onclick="window.location.href=\'' + redirectUrl + '\'; event.stopPropagation();" style="cursor: pointer;"' : '';

            var html = '<div class="toast-mockup toast-mockup-' + type + '" id="' + id + '"' + onclickAttr + '>'
                + '<div class="toast-mockup-left">'
                + '  <div class="toast-mockup-icon-circle ' + type + '">'
                + '    <i class="fa-solid ' + (type === 'danger' || type === 'warning' ? 'fa-bell' : 'fa-info') + '"></i>'
                + '  </div>'
                + '</div>'
                + '<div class="toast-mockup-body">'
                + '  <div class="toast-mockup-badge">' + badgeText + '</div>'
                + '  <div class="toast-mockup-title">' + title + '</div>'
                + '  <div class="toast-mockup-msg">' + message + '</div>'
                + '</div>'
                + '<button class="toast-mockup-close" onclick="MedEquip.closeToast(\'' + id + '\'); event.stopPropagation();">'
                + '  <i class="fa-solid fa-xmark"></i>'
                + '</button></div>';

            document.getElementById('toast-container').insertAdjacentHTML('beforeend', html);
            setTimeout(function () { MedEquip.closeToast(id); }, 7000);
        };

        MedEquip.closeToast = function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.style.opacity = '0';
                el.style.transform = 'translateX(20px)';
                el.style.transition = '.2s ease';
                setTimeout(function () { el.remove(); }, 200);
            }
        };

        // ── Auto-highlight active nav (Đã vá lỗi cú pháp đóng hàm hoàn chỉnh) ────────────────
        (function () {
            var currentPath = window.location.pathname.toLowerCase();
            var segments = currentPath.split('/').filter(Boolean);
            
            var currentController = segments[0] || '';
            var currentAction = segments[1] || 'index';

            if (currentController) {
                document.querySelectorAll('.nav-item a').forEach(function (a) {
                    var href = (a.getAttribute('href') || '').toLowerCase();
                    var hrefSegments = href.split('/').filter(Boolean);
                    
                    var targetController = hrefSegments[0] || '';
                    var targetAction = hrefSegments[1] || 'index';

                    if (targetController === currentController && targetAction === currentAction) {
                        document.querySelectorAll('.nav-item').forEach(function (li) { li.classList.remove('active'); });
                        a.closest('.nav-item').classList.add('active');
                    }
                });
            }
        })();
    </script>

    @if (HasModule("Alerts"))
    {
        <script>
            $(document).ready(function () {
                var currentUserId = @(Session["UserId"] ?? 0);
                if (!currentUserId) {
                    var userStr = localStorage.getItem('current_user');
                    if (userStr) {
                        try {
                            var u = JSON.parse(userStr);
                            if (u && u.Id) currentUserId = u.Id;
                        } catch (e) {}
                    }
                }
                if (!currentUserId) currentUserId = 1; // Fallback so it always runs

                var seenKey = 'seen_alerts_' + currentUserId;
                var readKey = 'read_alerts_' + currentUserId;

                // Load arrays: seenAlerts and readAlerts are both persisted to localStorage
                var seenAlerts = [];
                var isFirstLoad = false;
                try {
                    var storedSeen = localStorage.getItem(seenKey);
                    if (storedSeen) {
                        seenAlerts = JSON.parse(storedSeen);
                    } else {
                        isFirstLoad = true;
                    }
                } catch (e) {
                    seenAlerts = [];
                    isFirstLoad = true;
                }
                var readAlerts = JSON.parse(localStorage.getItem(readKey) || '[]');

                function saveLocalStorage() {
                    // Giới hạn kích thước mảng seenAlerts để tránh quá tải dung lượng localStorage
                    if (seenAlerts.length > 200) {
                        seenAlerts = seenAlerts.slice(seenAlerts.length - 200);
                    }
                    localStorage.setItem(readKey, JSON.stringify(readAlerts));
                    localStorage.setItem(seenKey, JSON.stringify(seenAlerts));
                }

                // Click to toggle dropdown
                $('#notification-bell-btn').on('click', function (e) {
                    e.stopPropagation();
                    $('#notification-dropdown').toggle();
                    
                    // Mark all loaded alerts as "read" when opening
                    markAllAsRead();
                });

                $(document).on('click', function () {
                    $('#notification-dropdown').hide();
                });

                $('#notification-dropdown').on('click', function (e) {
                    e.stopPropagation();
                });

                $('#mark-all-read-btn').on('click', function () {
                    markAllAsRead();
                });

                function markAllAsRead() {
                    var items = $('#notification-list .notification-item');
                    var hasChange = false;
                    items.each(function () {
                        var id = $(this).data('id');
                        if (id && readAlerts.indexOf(id) === -1) {
                            readAlerts.push(id);
                            hasChange = true;
                        }
                        $(this).removeClass('unread');
                    });
                    if (hasChange) {
                        saveLocalStorage();
                        updateBadge();
                    }
                }

                function updateBadge() {
                    var unreadCount = 0;
                    $('#notification-list .notification-item').each(function () {
                        var id = $(this).data('id');
                        if (id && readAlerts.indexOf(id) === -1) {
                            unreadCount++;
                        }
                    });

                    if (unreadCount > 0) {
                        $('#notification-badge').text(unreadCount).addClass('show');
                    } else {
                        $('#notification-badge').removeClass('show');
                    }
                }

                function renderAlertsList(alerts) {
                    var listContainer = $('#notification-list');
                    if (!alerts || alerts.length === 0) {
                        listContainer.html(
                            '<div style="padding: 24px; text-align: center; color: #94a3b8; font-size: 12.5px;">' +
                            '<i class="fa-solid fa-bell-slash" style="font-size: 20px; display: block; margin-bottom: 6px;"></i>' +
                            'Không có cảnh báo chưa xử lý' +
                            '</div>'
                        );
                        return;
                    }

                    var html = '';
                    alerts.forEach(function (alert) {
                        var isUnread = readAlerts.indexOf(alert.Id) === -1;
                        var unreadClass = isUnread ? ' unread' : '';
                        var iconClass = alert.Severity === 'danger' ? 'danger' :
                                        alert.Severity === 'warning' ? 'warning' : 'info';
                        var iconHtml = alert.Severity === 'danger' ? '<i class="fa-solid fa-triangle-exclamation"></i>' :
                                       alert.Severity === 'warning' ? '<i class="fa-solid fa-circle-exclamation"></i>' :
                                       '<i class="fa-solid fa-circle-info"></i>';

                        var redirectUrl = window.getAlertRedirectUrl(alert);
                        html += '<div class="notification-item' + unreadClass + '" data-id="' + alert.Id + '" onclick="window.location.href=\'' + redirectUrl + '\'; event.stopPropagation();">' +
                            '<div class="notification-item-icon ' + iconClass + '">' + iconHtml + '</div>' +
                            '<div class="notification-item-content">' +
                            '<div class="notification-item-title">' + alert.Title + '</div>' +
                            '<div class="notification-item-body">' + (alert.Body || (alert.ItemName + ' - Thiết bị gặp sự cố.')) + '</div>' +
                            '<div class="notification-item-time">' + alert.CreatedAtFriendly + '</div>' +
                            '</div>' +
                            '</div>';
                    });

                    listContainer.html(html);
                    updateBadge();
                }

                function checkRealtimeAlerts() {
                    $.ajax({
                        url: '/api/alerts/check-new',
                        type: 'GET',
                        success: function (res) {
                            if (res && res.length > 0) {
                                var hasNew = false;
                                res.forEach(function (alert) {
                                    var relevant = window.isAlertRelevantToCurrentPage(alert);
                                    var seen = seenAlerts.indexOf(alert.Id) !== -1;

                                    // If not seen yet, show toast (only if relevant to current page)
                                    if (relevant) {
                                        if (!seen) {
                                            seenAlerts.push(alert.Id);
                                            hasNew = true;

                                            // Tránh hiện hàng loạt cảnh báo cũ trên màn hình khi mới load trang/refresh lần đầu
                                            if (!isFirstLoad) {
                                                var toastType = alert.Severity === 'danger' ? 'danger' :
                                                                alert.Severity === 'warning' ? 'warning' : 'success';

                                                if (window.MedEquip && window.MedEquip.toast) {
                                                    window.MedEquip.toast(
                                                        alert.Title,
                                                        alert.Body || (alert.ItemName + ' - Thiết bị gặp sự cố.'),
                                                        toastType,
                                                        alert
                                                    );
                                                }
                                            }
                                        }
                                    }
                                });

                                if (isFirstLoad) {
                                    isFirstLoad = false;
                                }

                                if (hasNew) {
                                    saveLocalStorage();
                                }

                                // Render list in dropdown
                                renderAlertsList(res);
                            } else {
                                if (isFirstLoad) {
                                    isFirstLoad = false;
                                }
                                renderAlertsList([]);
                            }
                        },
                        error: function (xhr) {
                            console.warn('Lỗi polling cảnh báo realtime:', xhr.responseText);
                        }
                    });
                }

                // Chạy kiểm tra lần đầu sau 1 giây, sau đó chạy mỗi 15 giây
                setTimeout(checkRealtimeAlerts, 1000);
                setInterval(checkRealtimeAlerts, 15000);
            });
        </script>
    }

    @RenderSection("scripts", required: false)
</body>
</html>