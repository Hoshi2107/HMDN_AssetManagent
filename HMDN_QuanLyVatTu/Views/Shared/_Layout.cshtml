@{
    var userModules = Session["UserModules"] as List<HMDN_QuanLyVatTu.Models.ModulePermissionDTO>;
    bool HasModule(string code)
    {
        if (userModules == null) return false;
        return System.Linq.Enumerable.Any(userModules, m => string.Equals(m.code, code, System.StringComparison.OrdinalIgnoreCase));
    }

    // Fetch other active users
    List<HMS.Models.Auth.User> activeUsersList = new List<HMS.Models.Auth.User>();
    int currentUserId = Session["UserId"] != null ? (int)Session["UserId"] : 0;
    try
    {
        using (var db = new HMS.Data.HospitalAssetDbContext())
        {
            activeUsersList = db.Users
                .Where(u => u.IsActive && u.Id != currentUserId)
                .OrderByDescending(u => u.LastLoginAt)
                .Take(5)
                .ToList();
        }
    }
    catch (Exception ex)
    {
        // Fallback
    }

    // If the database has no other users or very few, seed with some realistic active hospital staff
    if (activeUsersList.Count < 3)
    {
        var mockStaff = new List<HMS.Models.Auth.User>
        {
            new HMS.Models.Auth.User { FullName = "Trần Minh Hoàng", Email = "hoang.tm@hospital.com", Username = "hoangtm", IsActive = true },
            new HMS.Models.Auth.User { FullName = "Lê Thị Mai Anh", Email = "anh.ltm@hospital.com", Username = "maianh", IsActive = true },
            new HMS.Models.Auth.User { FullName = "Phạm Đức Thắng", Email = "thang.pd@hospital.com", Username = "thangpd", IsActive = true }
        };
        
        foreach (var mock in mockStaff)
        {
            if (!activeUsersList.Any(u => string.Equals(u.Username, mock.Username, StringComparison.OrdinalIgnoreCase)))
            {
                activeUsersList.Add(mock);
            }
        }
    }

    string GetAvatarGradient(string name)
    {
        if (string.IsNullOrEmpty(name)) return "linear-gradient(135deg, #00AFA9, #003366)";
        int hash = name.GetHashCode();
        string[] gradients = new string[]
        {
            "linear-gradient(135deg, #00AFA9, #003366)", 
            "linear-gradient(135deg, #10b981, #059669)", 
            "linear-gradient(135deg, #f59e0b, #d97706)", 
            "linear-gradient(135deg, #ec4899, #8b5cf6)", 
            "linear-gradient(135deg, #ef4444, #f43f5e)"  
        };
        int index = Math.Abs(hash) % gradients.Length;
        return gradients[index];
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MedEquip Enterprise</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="@Url.Content("~/Addon/vue/vue.js")"></script>
    <script>
        window.userModules = @Html.Raw(Session["UserModules"] != null ? Newtonsoft.Json.JsonConvert.SerializeObject(Session["UserModules"]) : "[]");
        window.hasPermission = function (moduleCode, permission) {
            if (!window.userModules || !window.userModules.length) return false;
            var mod = window.userModules.find(function (m) {
                return m.code && m.code.toLowerCase() === moduleCode.toLowerCase();
            });
            if (!mod || !mod.permissions) return false;
            return mod.permissions.map(function(p) { return p.toLowerCase(); }).indexOf(permission.toLowerCase()) !== -1;
        };

        if (window.Vue) {
            Vue.mixin({
                methods: {
                    hasPermission: function(moduleCode, permission) {
                        return window.hasPermission(moduleCode, permission);
                    }
                }
            });
        }
    </script>
    <style>
        :root {
            /* Hoàn Mỹ Hospital Official Colors */
            --hm-navy: #0090a1;      /* Màu xanh đại dương đậm chuẩn Hoàn Mỹ */
            --hm-teal: #00AFA9;      /* Màu xanh ngọc thương hiệu */
            --hm-light-teal: rgba(0, 175, 169, 0.1);
            
            --sidebar-bg: var(--hm-navy); 
            --sidebar-width: 260px;
            --sidebar-collapsed-width: 70px;
            --body-bg: #f4f6f9;
            --card-bg: #ffffff;
            --border: #e2e8f0;
            
            --text-primary: #1e2a3a;
            --text-secondary: rgba(255, 255, 255, 0.85); 
            
            --accent-blue: #0056b3;
            --accent-red: #e53e3e;
            --accent-amber: #f6ad55;
            --accent-green: #38a169;
            
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --radius: 12px;
            
            /* ── FONT LEXEND LOCAL ── */
            --font-main: 'Lexend';
            --font-mono: 'JetBrains Mono', monospace;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            font-family: var(--font-main);
            font-size: 14px;
            background: var(--body-bg);
            color: var(--text-primary);
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        /* ── APP SHELL ── */
        .app-shell {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        /* ── SIDEBAR ── */
        #app-sidebar.sidebar {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            z-index: 100;
            position: relative;
            transition: width var(--transition), min-width var(--transition);
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        /* Khi Sidebar ở trạng thái thu gọn */
        body.sidebar-collapsed #app-sidebar.sidebar {
            width: var(--sidebar-collapsed-width);
            min-width: var(--sidebar-collapsed-width);
        }

        /* ── BRAND LOGO CẤU HÌNH TỐI ƯU KÍCH THƯỚC SÁT LỀ ── */
        #app-sidebar .sidebar-brand {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            padding: 10px 10px !important;
            border-bottom: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0;
            height: 60px;
            overflow: hidden;
        }

        #app-sidebar .sidebar-logo {
            width: 100% !important;
            height: 100% !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
        }

        /* Khi menu mở rộng: Ép logo chữ Hoàn Mỹ lớn rộng tối đa ra sát lề */
        #app-sidebar .sidebar-logo .logo-large {
            display: block !important;
            width: 100% !important;
            height: auto !important;
            max-height: 46px !important;
            object-fit: contain !important;
        }

        /* Ẩn hoàn toàn logo icon nhỏ khi menu đang mở rộng */
        #app-sidebar .sidebar-logo .logo-icon {
            display: none !important;
        }

        #app-sidebar .sidebar-nav {
            flex: 1;
            padding: 15px 10px;
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.1) transparent;
        }

        /* ── DANH MỤC HEADER (COLLAPSIBLE SECTION) ── */
        #app-sidebar .nav-section {
            margin-bottom: 8px;
            border-radius: 8px;
            overflow: hidden;
        }

        #app-sidebar .nav-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 12px;
            cursor: pointer;
            user-select: none;
            color: rgba(255, 255, 255, 0.55);
            transition: all var(--transition);
            border-radius: 6px;
        }

        #app-sidebar .nav-section-header:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.08);
        }

        #app-sidebar .nav-section-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            white-space: nowrap;
            transition: opacity var(--transition);
        }

        /* Icon mũi tên chỉ trạng thái đóng mở */
        #app-sidebar .section-chevron {
            font-size: 10px;
            transition: transform var(--transition);
        }

        /* Giao diện đóng danh mục menu */
        #app-sidebar .nav-section.collapsed .nav-section-content {
            max-height: 0 !important;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
        }

        #app-sidebar .nav-section.collapsed .section-chevron {
            transform: rotate(-90deg);
        }

        #app-sidebar .nav-section-content {
            transition: max-height var(--transition), opacity var(--transition);
            max-height: 500px;
            opacity: 1;
        }

        /* Ẩn chữ và mũi tên khi Sidebar thu nhỏ */
        body.sidebar-collapsed #app-sidebar .nav-section-label,
        body.sidebar-collapsed #app-sidebar .section-chevron {
            opacity: 0;
            display: none;
        }
        
        body.sidebar-collapsed #app-sidebar .nav-section-header {
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 5px 0;
            justify-content: center;
        }

        /* ── ITEMS MENU ── */
        #app-sidebar .nav-item {
            position: relative;
            margin-bottom: 2px;
            display: block !important;
            padding: 0 !important;
            background: transparent !important;
            border: none !important;
        }

        #app-sidebar .nav-item a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            border-radius: 8px;
            color: var(--text-secondary) !important;
            font-size: 13.5px;
            font-weight: 500;
            transition: all var(--transition);
            white-space: nowrap;
        }

        #app-sidebar .nav-item a .nav-icon {
            width: 20px;
            text-align: center;
            font-size: 14px;
            flex-shrink: 0;
            opacity: .85;
            transition: transform var(--transition);
        }

        #app-sidebar .nav-item a span.nav-text {
            transition: opacity var(--transition);
            opacity: 1;
        }

        /* ── KHI SIDEBAR Ở TRẠNG THÁI THU NHỎ (SIDEBAR-COLLAPSED) ── */
        body.sidebar-collapsed #app-sidebar .nav-item a span.nav-text,
        body.sidebar-collapsed #app-sidebar .nav-badge {
            opacity: 0;
            display: none !important; 
        }

        body.sidebar-collapsed #app-sidebar .nav-item a {
            justify-content: center;
            padding: 12px 0;
            transition: all var(--transition);
        }

        /* 1. Ẩn hoàn toàn logo chữ lớn Hoàn Mỹ */
        body.sidebar-collapsed #app-sidebar .sidebar-logo .logo-large {
            display: none !important;
        }
        /* 2. Ép hiển thị logo icon vuông to rõ ở chính giữa menu thu nhỏ */
        body.sidebar-collapsed #app-sidebar .sidebar-logo .logo-icon {
            display: block !important;
            width: 40px !important;
            height: 40px !important;
            max-width: 40px !important;
            max-height: 40px !important;
            object-fit: contain !important;
            margin: 0 auto !important;
        }

        /* Sửa lỗi đẩy lệch tâm icon của tab active khi có border-left */
        body.sidebar-collapsed #app-sidebar .nav-item.active a {
            background: #006673 !important; 
            border-left: 4px solid #ffffff; 
            padding-right: 4px !important;  /* Bù trừ 4px để đẩy ngược icon vào chính giữa */
            border-top-left-radius: 0;
            border-bottom-left-radius: 0;
        }

        /* HOVER & ACTIVE EFFECTS */
        #app-sidebar .nav-item a:hover {
            background: rgba(255,255,255,.12) !important;
            color: #ffffff !important;
        }
        
        #app-sidebar .nav-item a:hover .nav-icon {
            transform: scale(1.08);
        }

        #app-sidebar .nav-item.active a {
            background: #006673 !important;
            color: #ffffff !important;
            font-weight: 600;
            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.1), 0 2px 6px rgba(0,0,0,0.06);
            
            border-left: 4px solid #ffffff;
            border-top-left-radius: 0;
            border-bottom-left-radius: 0;
        }

        #app-sidebar .nav-item.active a .nav-icon {
            opacity: 1;
            color: #ffffff !important;
        }

        #app-sidebar .nav-badge {
            margin-left: auto;
            background: var(--accent-red);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 12px;
            font-family: var(--font-mono);
        }

        /* ── MAIN CONTENT & TOPBAR ── */
        .page-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            width: calc(100vw - var(--sidebar-width));
            transition: width var(--transition);
        }

        body.sidebar-collapsed .page-wrapper {
            width: calc(100vw - var(--sidebar-collapsed-width));
        }

        .page-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            height: 60px;
            background: #ffffff;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .btn-toggle-sidebar {
            background: none;
            border: none;
            font-size: 18px;
            color: var(--hm-navy);
            cursor: pointer;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .btn-toggle-sidebar:hover {
            background: #f1f5f9;
        }

        .topbar-title {
            font-size: 17px;
            font-weight: 700;
            color: var(--hm-navy);
        }

        .page-content {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
        }

        /* ── SHARED HELPERS ── */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-md);
            padding: 20px;
        }

        /* ── TOAST MOCKUP STYLE ── */
        #toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .toast-mockup {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            min-width: 320px;
            max-width: 400px;
            position: relative;
            animation: slideIn .3s ease;
            border-left: 4px solid #cbd5e1;
        }

        .toast-mockup-danger { border-left-color: var(--accent-red); }
        .toast-mockup-warning { border-left-color: var(--accent-amber); }
        .toast-mockup-info { border-left-color: var(--hm-teal); }

        .toast-mockup-icon-circle {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .toast-mockup-icon-circle.danger { background: rgba(229, 62, 62, 0.1); color: var(--accent-red); }
        .toast-mockup-icon-circle.warning { background: rgba(246, 173, 85, 0.1); color: var(--accent-amber); }
        .toast-mockup-icon-circle.info { background: rgba(0, 175, 169, 0.1); color: var(--hm-teal); }

        .toast-mockup-body { flex: 1; min-width: 0; padding-right: 16px; }
        .toast-mockup-title { font-size: 14px; font-weight: 700; color: #0f172a; margin-bottom: 4px; }
        .toast-mockup-msg { font-size: 12.5px; color: #475569; line-height: 1.5; }
        
        .toast-mockup-close {
            background: none; border: none; cursor: pointer; color: #94a3b8;
            position: absolute; top: 12px; right: 12px; font-size: 16px;
        }

        /* SỬ DỤNG @@ KEYFRAMES ĐỂ TRANH LỖI RAZOR */
        @@keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        /* ── RESPONSIVE CHO MOBILE ── */
        @@media (max-width: 768px) {
            #app-sidebar.sidebar {
                position: fixed;
                left: calc(-1 * var(--sidebar-width));
                height: 100vh;
                box-shadow: 5px 0 15px rgba(0,0,0,0.15);
            }

            body.sidebar-open #app-sidebar.sidebar {
                left: 0;
                width: var(--sidebar-width) !important;
                min-width: var(--sidebar-width) !important;
            }

            body.sidebar-open #app-sidebar .nav-section-label,
            body.sidebar-open #app-sidebar .section-chevron,
            body.sidebar-open #app-sidebar .nav-item a span.nav-text {
                display: block !important;
                opacity: 1 !important;
            }

            .page-wrapper {
                width: 100vw !important;
            }
        }
    </style>
    <style>
        /* ── ĐÃ CẬP NHẬT ĐƯỜNG DẪN CHUẨN ĐẾN THƯ MỤC FONT THEO THỰC TẾ TRÊN F12 CỦA BẠN ── */
        @@font-face {
          font-family: 'Lexend';
          font-style: normal;
          font-weight: 100 900;
          font-display: swap;
          src: url('@Url.Content("~/Addon/vue/fonts/Lexend/wlpwgwvFAVdoq2_v9KQU4Wc.woff")') format('woff2');
          unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;
        }
        @@font-face {
          font-family: 'Lexend';
          font-style: normal;
          font-weight: 100 900;
          font-display: swap;
          src: url('@Url.Content("~/Addon/vue/fonts/Lexend/wlpwgwvFAVdoq2_v9aQU4Wc.woff")') format('woff2');
          unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
        }
        @@font-face {
          font-family: 'Lexend';
          font-style: normal;
          font-weight: 100 900;
          font-display: swap;
          src: url('@Url.Content("~/Addon/vue/fonts/Lexend/wlpwgwvFAVdoq2_v-6QU.woff")') format('woff2');
          unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
        }
    </style>
    <script>
        var originalFetch = window.fetch;
        window.fetch = function () {
            var args = Array.prototype.slice.call(arguments);
            if (args[0] && typeof args[0] === 'string' && args[0].indexOf('/api/') !== -1) {
                if (!args[1]) args[1] = {};
                args[1].credentials = 'same-origin';
            }
            return originalFetch.apply(this, args);
        };
    </script>
</head>
<body>
    <div class="app-shell">

        <aside id="app-sidebar" class="sidebar">
            <div class="sidebar-brand">
                <div class="sidebar-logo">
                    <img src="@Url.Content("~/Content/images1/whitelogo_bvhm.png")" class="logo-large" alt="MedEquip Logo">
                    <img src="@Url.Content("~/favicon.ico")" class="logo-icon" alt="MedEquip Icon">
                </div>
            </div>

            <nav class="sidebar-nav">
                @if (HasModule("Analytics"))
                {
                    <div class="nav-section" id="sec-overview">
                        <div class="nav-section-header" onclick="toggleNavSection('sec-overview')">
                            <span class="nav-section-label">Tổng quan</span>
                            <i class="fa-solid fa-chevron-down section-chevron"></i>
                        </div>
                        <div class="nav-section-content">
                            <div class="nav-item @(ViewBag.ActiveNav == "Analytics" ? "active" : "")">
                                <a href="@Url.Action("Index","Analytics")">
                                    <i class="fa-solid fa-chart-pie nav-icon"></i>
                                    <span class="nav-text">Dashboard</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }

                @if (HasModule("Inventory") || HasModule("Catalog") || HasModule("Locations") || HasModule("MaintainList"))
                {
                    <div class="nav-section" id="sec-assets">
                        <div class="nav-section-header" onclick="toggleNavSection('sec-assets')">
                            <span class="nav-section-label">Tài sản & Kho</span>
                            <i class="fa-solid fa-chevron-down section-chevron"></i>
                        </div>
                        <div class="nav-section-content">
                            @if (HasModule("Inventory")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Inventory" ? "active" : "")">
                                    <a href="@Url.Action("Index","Inventory")">
                                        <i class="fa-solid fa-box-archive nav-icon"></i> <span class="nav-text">Tổng tài sản</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("Catalog")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Catalog" ? "active" : "")">
                                    <a href="@Url.Action("Category","Category")">
                                        <i class="fa-solid fa-layer-group nav-icon"></i> <span class="nav-text">Danh mục</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("Locations")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Locations" ? "active" : "")">
                                    <a href="@Url.Action("Location","Location")">
                                        <i class="fa-solid fa-map-pin nav-icon"></i> <span class="nav-text">Vị trí</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("MaintainList")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "MaintainList" ? "active" : "")">
                                    <a href="@Url.Action("Index","MaintainList")">
