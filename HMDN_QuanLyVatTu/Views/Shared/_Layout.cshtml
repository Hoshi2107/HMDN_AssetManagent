@{
    var userModules = Session["UserModules"] as List<HMDN_QuanLyVatTu.Models.ModulePermissionDTO>;
    bool HasModule(string code)
    {
        if (userModules == null) return false;
        return System.Linq.Enumerable.Any(userModules, m => string.Equals(m.code, code, System.StringComparison.OrdinalIgnoreCase));
    }
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MedEquip Enterprise</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --sidebar-bg: #0f1623;
            --sidebar-hover: #1a2236;
            --sidebar-active: #2563eb;
            --sidebar-width: 230px;
            --text-primary: #f0f4ff;
            --text-secondary: #8a96b0;
            --text-muted: #4a5568;
            --body-bg: #f4f7fb;
            --card-bg: #ffffff;
            --border: #e5eaf3;
            --accent-blue: #2563eb;
            --accent-cyan: #06b6d4;
            --accent-red: #ef4444;
            --accent-amber: #f59e0b;
            --accent-green: #10b981;
            --shadow-sm: 0 1px 4px rgba(0,0,0,.06);
            --shadow-md: 0 4px 16px rgba(0,0,0,.10);
            --radius: 10px;
            --font-main: 'Be Vietnam Pro', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            font-family: var(--font-main);
            font-size: 14px;
            background: var(--body-bg);
            color: #1e2a3a;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        /* ── APP SHELL ── */
        .app-shell {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            z-index: 100;
            position: relative;
        }

        .sidebar::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.015) 1px, transparent 1px);
            background-size: 24px 24px;
            pointer-events: none;
        }

        /* ── BRAND ── */
        .sidebar-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px 14px;
            border-bottom: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0;
        }

        .slidebar-logo {
            width: 100%;
            height: 52px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            overflow: hidden;
        }

        .slidebar-logo img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
        }

        .sidebar-nav {
            flex: 1;
            padding: 8px 10px;
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.1) transparent;
        }

        .sidebar-nav::-webkit-scrollbar {
            width: 4px;
        }
        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
        }

        .nav-section {
            margin-bottom: 10px;
        }

        .nav-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 6px 8px 4px;
            cursor: pointer;
            user-select: none;
            color: var(--text-muted);
            transition: color var(--transition);
        }
        .nav-section-header:hover {
            color: var(--text-secondary);
        }

        .nav-section-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
        }

        .nav-section-toggle {
            font-size: 10px;
            transition: transform 0.3s ease;
        }
        
        .nav-section.collapsed .nav-section-toggle {
            transform: rotate(-90deg);
        }
        
        .nav-section.collapsed .nav-section-content {
            display: none;
        }

        .nav-item a span {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .nav-item {
            position: relative;
            margin-bottom: 2px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6.5px 10px;
            border-radius: 6px;
            color: var(--text-secondary);
            font-size: 13.5px;
            font-weight: 500;
            transition: background var(--transition),
                        color var(--transition),
                        transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
            white-space: nowrap;
        }

        .nav-item a .nav-icon {
            width: 16px;
            text-align: center;
            font-size: 12.5px;
            flex-shrink: 0;
            opacity: .75;
            transition: transform var(--transition), opacity var(--transition);
        }

        /* [HOVER EFFECT] */
        .nav-item a:hover {
            background: var(--sidebar-hover);
            color: var(--text-primary);
        }

        .nav-item a:hover .nav-icon {
            opacity: 1;
            transform: scale(1.1);
        }

        /* [ACTIVE EFFECT] */
        .nav-item.active a {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-cyan));
            color: #fff;
            box-shadow: 0 3px 10px rgba(6, 182, 212, 0.25);
            font-weight: 600;
            transform: scale(1.01);
        }

        .nav-item.active a .nav-icon {
            opacity: 1;
            transform: scale(1.05);
        }

        /* [LEFT INDICATOR GLOW] */
        .nav-item.active::before {
            content: '';
            position: absolute;
            left: -10px;
            top: 50%;
            transform: translateY(-50%);
            width: 3.5px;
            height: 16px;
            background: var(--accent-cyan);
            border-radius: 0 4px 4px 0;
            animation: activeIndicator 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        /* [MICRO-INTERACTION CLICK] */
        .nav-item a:active {
            transform: scale(0.98);
        }

        .nav-badge {
            margin-left: auto;
            background: var(--accent-red);
            color: #fff;
            font-size: 9px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 20px;
            font-family: var(--font-mono);
            flex-shrink: 0;
        }

        /* ── FOOTER ── */
        .sidebar-footer {
            padding: 8px 10px 14px;
            border-top: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0;
        }

        .sidebar-footer .nav-section-label {
            padding-top: 8px;
        }

        .staff-pill {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 9px 11px;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.07);
            border-radius: 10px;
            cursor: pointer;
            transition: background var(--transition);
            margin-top: 8px;
        }

        .staff-pill:hover {
            background: rgba(255,255,255,.08);
        }

        .staff-avatars {
            display: flex;
        }

        .staff-avatars img,
        .staff-avatars .av-count {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid var(--sidebar-bg);
            margin-left: -6px;
            object-fit: cover;
        }

        .staff-avatars img:first-child {
            margin-left: 0;
        }

        .av-count {
            background: var(--accent-cyan);
            color: #fff;
            font-size: 9px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .staff-info {
            flex: 1;
            min-width: 0;
        }

        .staff-info small {
            display: block;
            font-size: 9px;
            color: var(--text-muted);
            line-height: 1.2;
        }

        .staff-info strong {
            display: block;
            font-size: 11.5px;
            color: var(--text-primary);
            font-weight: 600;
        }

        .staff-dot {
            width: 7px;
            height: 7px;
            background: var(--accent-green);
            border-radius: 50%;
            box-shadow: 0 0 6px rgba(16,185,129,.6);
            flex-shrink: 0;
        }

        /* ── MAIN CONTENT ── */
        .page-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .page-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            height: 56px;
            background: linear-gradient(90deg, #ffffff, #f0f4ff);
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            gap: 16px;
        }

        .topbar-title {
            font-size: 18px;
            font-weight: 700;
            color: #1e2a3a;
            letter-spacing: 0.5px;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            font-family: var(--font-main);
            transition: background var(--transition);
        }

        .btn-ghost {
            background: transparent;
            color: #64748b;
            border: 1px solid var(--border);
        }

        .btn-ghost:hover {
            background: var(--body-bg);
        }

        .btn-primary {
            background: var(--accent-blue);
            color: #fff;
        }

        .btn-primary:hover {
            background: #1d4ed8;
        }

        .page-content {
            flex: 1;
            overflow-y: auto;
            padding: 26px 28px;
            scrollbar-width: thin;
            scrollbar-color: #d1d9e6 transparent;
        }

        .page-content::-webkit-scrollbar {
            width: 5px;
        }

        .page-content::-webkit-scrollbar-thumb {
            background: #d1d9e6;
            border-radius: 4px;
        }

        /* ── SHARED HELPERS ── */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
        }

        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 9px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-status::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            opacity: .7;
        }

        .badge-active { background: #d1fae5; color: #065f46; }
        .badge-warning { background: #fef3c7; color: #92400e; }
        .badge-danger { background: #fee2e2; color: #991b1b; }
        .badge-maint { background: #e0e7ff; color: #3730a3; }
        .badge-pending { background: #f0f9ff; color: #075985; }

        /* ── TOAST ── */
        #toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px 16px;
            box-shadow: 0 8px 24px rgba(0,0,0,.12);
            min-width: 300px;
            max-width: 380px;
            animation: slideIn .25s ease;
        }

        .toast-danger { border-left: 4px solid var(--accent-red); }
        .toast-warning { border-left: 4px solid var(--accent-amber); }
        .toast-success { border-left: 4px solid var(--accent-green); }
        .toast-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
        .toast-danger .toast-icon { color: var(--accent-red); }
        .toast-warning .toast-icon { color: var(--accent-amber); }
        .toast-success .toast-icon { color: var(--accent-green); }
        .toast-body { flex: 1; }
        .toast-title { font-size: 13px; font-weight: 700; color: #1e2a3a; margin-bottom: 3px; }
        .toast-msg { font-size: 12px; color: #64748b; line-height: 1.4; }
        .toast-close { background: none; border: none; cursor: pointer; color: #94a3b8; font-size: 14px; padding: 0; flex-shrink: 0; }
        .toast-close:hover { color: #1e2a3a; }

        /* ── KEYFRAMES ── */
        @@keyframes slideIn {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @@keyframes activeIndicator {
            from { height: 0; opacity: 0; }
            to { height: 18px; opacity: 1; }
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .sidebar {
                width: 58px;
                min-width: 58px;
            }

            .brand-text,
            .nav-item a span,
            .staff-info,
            .nav-section-label,
            .nav-badge,
            .slidebar-logo img {
                display: none !important;
            }

            .sidebar-brand {
                justify-content: center;
                padding: 14px 10px;
            }

            .nav-item a {
                justify-content: center;
                gap: 0;
                padding: 10px;
            }

            .nav-item.active::before {
                left: 2px;
            }

            .staff-pill {
                justify-content: center;
                padding: 10px;
            }

            .page-content { padding: 18px; }
            .page-topbar { padding: 0 18px; }
        }
    </style>
</head>
<body>
    <div class="app-shell">

        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="slidebar-logo">
                    <img src="@Url.Content("~/Content/images1/logobv.png")" alt="MedEquip Logo">
                </div>
            </div>

            <nav class="sidebar-nav">
                @if (HasModule("Analytics"))
                {
                    <div class="nav-section">
                        <div class="nav-section-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <div class="nav-section-label">Tổng quan</div>
                            <i class="fa-solid fa-chevron-down nav-section-toggle"></i>
                        </div>
                        <ul class="nav-section-content">
                            <li class="nav-item @(ViewBag.ActiveNav == "Analytics" ? "active" : "")">
                                <a href="@Url.Action("Index","Analytics")">
                                    <i class="fa-solid fa-chart-pie nav-icon"></i>
                                    <span>Dashboard</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                }

                @if (HasModule("Inventory") || HasModule("Catalog") || HasModule("Locations") || HasModule("QrCodes"))
                {
                    <div class="nav-section">
                        <div class="nav-section-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <div class="nav-section-label">Tài sản & Kho</div>
                            <i class="fa-solid fa-chevron-down nav-section-toggle"></i>
                        </div>
                        <ul class="nav-section-content">
                            @if (HasModule("Inventory"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Inventory" ? "active" : "")">
                                    <a href="@Url.Action("Index","Inventory")">
                                        <i class="fa-solid fa-box-archive nav-icon"></i>
                                        <span>Tổng tài sản</span>
                                    </a>
                                </li>
                            }
                            @if (HasModule("Catalog"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Catalog" ? "active" : "")">
                                    <a href="@Url.Action("Category","Category")">
                                        <i class="fa-solid fa-layer-group nav-icon"></i>
                                        <span>Danh mục</span>
                                    </a>
                                </li>
                            }
                            @if (HasModule("Locations"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Locations" ? "active" : "")">
                                    <a href="@Url.Action("Location","Location")">
                                        <i class="fa-solid fa-map-pin nav-icon"></i>
                                        <span>Vị trí</span>
                                    </a>
                                </li>
                            }
                            @if (HasModule("QrCodes"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "QrCodes" ? "active" : "")">
                                    <a href="@Url.Action("Index","QrCodes")">
                                        <i class="fa-solid fa-qrcode nav-icon"></i>
                                        <span>QR Code</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }

                @if (HasModule("Lifecycle") || HasModule("VongDoiKhauHao"))
                {
                    <div class="nav-section">
                        <div class="nav-section-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <div class="nav-section-label">Vòng đời</div>
                            <i class="fa-solid fa-chevron-down nav-section-toggle"></i>
                        </div>
                        <ul class="nav-section-content">
                            @if (HasModule("Lifecycle"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Lifecycle" ? "active" : "")">
                                    <a href="@Url.Action("Index","Lifecycle")">
                                        <i class="fa-solid fa-rotate nav-icon"></i>
                                        <span>Trạng thái</span>
                                    </a>
                                </li>
                            }
                            @if (HasModule("VongDoiKhauHao"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "VongDoiKhauHao" ? "active" : "")">
                                    <a href="@Url.Action("VongDoiKhauHao", "VongDoiKhauHao")">
                                        <i class="fa-solid fa-recycle nav-icon"></i>
                                        <span>Vòng đời & Khấu hao</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }

                @if (HasModule("Checklists") || HasModule("Maintenance") || HasModule("TiepNhanBaoHong"))
                {
                    <div class="nav-section">
                        <div class="nav-section-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <div class="nav-section-label">Bảo trì</div>
                            <i class="fa-solid fa-chevron-down nav-section-toggle"></i>
                        </div>
                        <ul class="nav-section-content">
                            @if (HasModule("Checklists"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Checklists" ? "active" : "")">
                                    <a href="@Url.Action("Index","Checklists")">
                                        <i class="fa-solid fa-list-check nav-icon"></i>
                                        <span>Checklist</span>
                                    </a>
                                </li>
                            }
                            @if (HasModule("Maintenance"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Maintenance" ? "active" : "")">
                                    <a href="@Url.Action("Index","Maintenance")">
                                        <i class="fa-solid fa-screwdriver-wrench nav-icon"></i>
                                        <span>Sửa chữa</span>
                                    </a>
                                </li>
                            }
                            @if (HasModule("TiepNhanBaoHong"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "TiepNhanBaoHong" ? "active" : "")">
                                    <a href="@Url.Action("TiepNhanBaoHong","Maintenance")">
                                        <i class="fa-solid fa-triangle-exclamation nav-icon"></i>
                                        <span>Tiếp nhận báo hỏng</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }

                @if (HasModule("CreateTicket") || HasModule("Alerts") || HasModule("Approvals"))
                {
                    <div class="nav-section">
                        <div class="nav-section-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <div class="nav-section-label">Vận hành</div>
                            <i class="fa-solid fa-chevron-down nav-section-toggle"></i>
                        </div>
                        <ul class="nav-section-content">
                            
                            @if (HasModule("Alerts"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Alerts" ? "active" : "")">
                                    <a href="@Url.Action("Index","Alerts")">
                                        <i class="fa-solid fa-bell nav-icon"></i>
                                        <span>Cảnh báo</span>
                                        @if (ViewBag.AlertCount != null && (int)ViewBag.AlertCount > 0)
                                        {
                                            <span class="nav-badge">@ViewBag.AlertCount</span>
                                        }
                                    </a>
                                </li>
                            }
                            @if (HasModule("Approvals"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Approvals" ? "active" : "")">
                                    <a href="@Url.Action("Index","Approvals")">
                                        <i class="fa-solid fa-clipboard-check nav-icon"></i>
                                        <span>Phê duyệt</span>
                                        @if (ViewBag.PendingApprovals != null && (int)ViewBag.PendingApprovals > 0)
                                        {
                                            <span class="nav-badge">@ViewBag.PendingApprovals</span>
                                        }
                                    </a>
                                </li>
                            }
                            @if (HasModule("CreateTicket"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "CreateTicket" ? "active" : "")">
                                    <a href="@Url.Action("Index", "CreateTicket")">
                                        <i class="fa-solid fa-file-circle-plus nav-icon"></i>
                                        <span>Tạo phiếu</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
                @if (HasModule("Settings") || HasModule("Support"))
                {
                    <div class="nav-section" style="margin-top: 15px; border-top: 1px solid rgba(255,255,255,.06); padding-top: 10px;">
                        <div class="nav-section-header" onclick="this.parentElement.classList.toggle('collapsed')">
                            <div class="nav-section-label" style="padding: 0;">Hệ thống</div>
                            <i class="fa-solid fa-chevron-down nav-section-toggle"></i>
                        </div>
                        <ul class="nav-section-content">
                            @if (HasModule("Settings"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Settings" ? "active" : "")">
                                    <a href="@Url.Action("Index","Settings")">
                                        <i class="fa-solid fa-gear nav-icon"></i>
                                        <span>Cài đặt</span>
                                    </a>
                                </li>
                            }
                            @if (HasModule("Support"))
                            {
                                <li class="nav-item @(ViewBag.ActiveNav == "Support" ? "active" : "")">
                                    <a href="@Url.Action("Index","Support")">
                                        <i class="fa-solid fa-circle-question nav-icon"></i>
                                        <span>Hỗ trợ</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </nav>
        </aside>

        <div class="page-wrapper">
            <header class="page-topbar">
                <span class="topbar-title">@(ViewBag.PageTitle ?? ViewBag.Title ?? "")</span>
                <div class="topbar-actions" style="display: flex; align-items: center; gap: 12px;">
                    @RenderSection("topbar_actions", required: false)
                    @if (Session["FullName"] != null)
                    {
                        <div class="user-profile-chip" style="display: flex; align-items: center; gap: 8px; padding: 5px 12px; background: var(--body-bg); border-radius: 20px; border: 1px solid var(--border); font-size: 12.5px;">
                            <i class="fa-solid fa-circle-user" style="color: var(--accent-blue); font-size: 15px;"></i>
                            <span style="font-weight: 600; color: #1e2a3a;">@Session["FullName"]</span>
                            <a href="/Account/Logout" title="Đăng xuất" style="margin-left: 6px; color: var(--accent-red); display: flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; background: rgba(239, 68, 68, 0.08); transition: all 0.2s;" onmouseover="this.style.background='rgba(239, 68, 68, 0.15)'" onmouseout="this.style.background='rgba(239, 68, 68, 0.08)'">
                                <i class="fa-solid fa-arrow-right-from-bracket" style="font-size: 10px;"></i>
                            </a>
                        </div>
                    }
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>

    </div>

    <div id="toast-container"></div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <script>
        // ── Toast utility ──────────────────────────────────────
        window.MedEquip = window.MedEquip || {};

        MedEquip.toast = function (title, message, type) {
            type = type || 'warning';
            var icons = {
                danger: 'fa-triangle-exclamation',
                warning: 'fa-circle-exclamation',
                success: 'fa-circle-check'
            };
            var id = 'toast-' + Date.now();
            var html = '<div class="toast toast-' + type + '" id="' + id + '">'
                + '<i class="fa-solid ' + icons[type] + ' toast-icon"></i>'
                + '<div class="toast-body">'
                + '<div class="toast-title">' + title + '</div>'
                + '<div class="toast-msg">' + message + '</div>'
                + '</div>'
                + '<button class="toast-close" onclick="MedEquip.closeToast(\'' + id + '\')">'
                + '<i class="fa-solid fa-xmark"></i>'
                + '</button></div>';
            document.getElementById('toast-container').insertAdjacentHTML('beforeend', html);
            setTimeout(function () { MedEquip.closeToast(id); }, 6000);
        };

        MedEquip.closeToast = function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.style.opacity = '0';
                el.style.transform = 'translateX(20px)';
                el.style.transition = '.2s ease';
                setTimeout(function () { el.remove(); }, 200);
            }
        };

        // ── Auto-highlight active nav (Đã vá lỗi cú pháp đóng hàm hoàn chỉnh) ────────────────
        (function () {
            var currentPath = window.location.pathname.toLowerCase();
            var segments = currentPath.split('/').filter(Boolean);
            
            var currentController = segments[0] || '';
            var currentAction = segments[1] || 'index';

            if (currentController) {
                document.querySelectorAll('.nav-item a').forEach(function (a) {
                    var href = (a.getAttribute('href') || '').toLowerCase();
                    var hrefSegments = href.split('/').filter(Boolean);
                    
                    var targetController = hrefSegments[0] || '';
                    var targetAction = hrefSegments[1] || 'index';

                    if (targetController === currentController && targetAction === currentAction) {
                        document.querySelectorAll('.nav-item').forEach(function (li) { li.classList.remove('active'); });
                        a.closest('.nav-item').classList.add('active');
                    }
                });
            }
        })();
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>