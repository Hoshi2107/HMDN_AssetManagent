@{
    var userModules = Session["UserModules"] as List<HMDN_QuanLyVatTu.Models.ModulePermissionDTO>;
    bool HasModule(string code)
    {
        if (userModules == null) return false;
        return System.Linq.Enumerable.Any(userModules, m => string.Equals(m.code, code, System.StringComparison.OrdinalIgnoreCase));
    }

    // Fetch other active users
    List<HMS.Models.Auth.User> activeUsersList = new List<HMS.Models.Auth.User>();
    int currentUserId = Session["UserId"] != null ? (int)Session["UserId"] : 0;
    try
    {
        using (var db = new HMS.Data.HospitalAssetDbContext())
        {
            activeUsersList = db.Users
                .Where(u => u.IsActive && u.Id != currentUserId)
                .OrderByDescending(u => u.LastLoginAt)
                .Take(5)
                .ToList();
        }
    }
    catch (Exception ex)
    {
        // Fallback
    }

    // If the database has no other users or very few, seed with some realistic active hospital staff
    if (activeUsersList.Count < 3)
    {
        var mockStaff = new List<HMS.Models.Auth.User>
        {
            new HMS.Models.Auth.User { FullName = "Trần Minh Hoàng", Email = "hoang.tm@hospital.com", Username = "hoangtm", IsActive = true },
            new HMS.Models.Auth.User { FullName = "Lê Thị Mai Anh", Email = "anh.ltm@hospital.com", Username = "maianh", IsActive = true },
            new HMS.Models.Auth.User { FullName = "Phạm Đức Thắng", Email = "thang.pd@hospital.com", Username = "thangpd", IsActive = true }
        };
        
        foreach (var mock in mockStaff)
        {
            if (!activeUsersList.Any(u => string.Equals(u.Username, mock.Username, StringComparison.OrdinalIgnoreCase)))
            {
                activeUsersList.Add(mock);
            }
        }
    }

    string GetAvatarGradient(string name)
    {
        if (string.IsNullOrEmpty(name)) return "linear-gradient(135deg, #00AFA9, #003366)";
        int hash = name.GetHashCode();
        string[] gradients = new string[]
        {
            "linear-gradient(135deg, #00AFA9, #003366)", 
            "linear-gradient(135deg, #10b981, #059669)", 
            "linear-gradient(135deg, #f59e0b, #d97706)", 
            "linear-gradient(135deg, #ec4899, #8b5cf6)", 
            "linear-gradient(135deg, #ef4444, #f43f5e)"  
        };
        int index = Math.Abs(hash) % gradients.Length;
        return gradients[index];
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MedEquip Enterprise</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="~/Addon/vue/vue.js"></script>
    <script>
        window.userModules = @Html.Raw(Session["UserModules"] != null ? Newtonsoft.Json.JsonConvert.SerializeObject(Session["UserModules"]) : "[]");
        window.hasPermission = function (moduleCode, permission) {
            if (!window.userModules || !window.userModules.length) return false;
            var mod = window.userModules.find(function (m) {
                return m.code && m.code.toLowerCase() === moduleCode.toLowerCase();
            });
            if (!mod || !mod.permissions) return false;
            return mod.permissions.map(function(p) { return p.toLowerCase(); }).indexOf(permission.toLowerCase()) !== -1;
        };

        if (window.Vue) {
            Vue.mixin({
                methods: {
                    hasPermission: function(moduleCode, permission) {
                        return window.hasPermission(moduleCode, permission);
                    }
                }
            });
        }
    </script>
    <style>
        :root {
            /* Hoàn Mỹ Hospital Official Colors */
            --hm-navy: #002855;      /* Màu xanh đại dương đậm chuẩn Hoàn Mỹ */
            --hm-teal: #00AFA9;      /* Màu xanh ngọc thương hiệu */
            --hm-light-teal: rgba(0, 175, 169, 0.1);
            
            --sidebar-bg: var(--hm-navy);
            --sidebar-width: 260px;
            --sidebar-collapsed-width: 70px;
            --body-bg: #f4f6f9;
            --card-bg: #ffffff;
            --border: #e2e8f0;
            
            --text-primary: #1e2a3a;
            --text-secondary: rgba(255, 255, 255, 0.75);
            
            --accent-blue: #0056b3;
            --accent-red: #e53e3e;
            --accent-amber: #f6ad55;
            --accent-green: #38a169;
            
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --radius: 12px;
            --font-main: 'Be Vietnam Pro', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            font-family: var(--font-main);
            font-size: 14px;
            background: var(--body-bg);
            color: var(--text-primary);
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        /* ── APP SHELL ── */
        .app-shell {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        /* ── SIDEBAR ── */
        #app-sidebar.sidebar {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            z-index: 100;
            position: relative;
            transition: width var(--transition), min-width var(--transition);
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        /* Khi Sidebar ở trạng thái thu gọn */
        body.sidebar-collapsed #app-sidebar.sidebar {
            width: var(--sidebar-collapsed-width);
            min-width: var(--sidebar-collapsed-width);
        }

        /* ── BRAND LOGO ── */
        #app-sidebar .sidebar-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px 14px;
            border-bottom: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0;
            height: 60px;
        }

        #app-sidebar .slidebar-logo {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
        }

        #app-sidebar .slidebar-logo img {
            width: 85%;
            max-height: 42px;
            object-fit: contain;
            display: block;
            transition: all var(--transition);
        }

        /* Khi thu nhỏ thì biến logo thành icon nhỏ hoặc thu bé lại */
        body.sidebar-collapsed #app-sidebar .slidebar-logo img {
            width: 40px;
            content: url('/favicon.ico'); /* Có thể đổi thành icon logo thu gọn nếu có */
        }

        #app-sidebar .sidebar-nav {
            flex: 1;
            padding: 15px 10px;
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.1) transparent;
        }

        /* ── DANH MỤC HEADER (COLLAPSIBLE SECTION) ── */
        #app-sidebar .nav-section {
            margin-bottom: 8px;
            border-radius: 8px;
            overflow: hidden;
        }

        #app-sidebar .nav-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 12px;
            cursor: pointer;
            user-select: none;
            color: rgba(255,255,255,0.45);
            transition: all var(--transition);
            border-radius: 6px;
        }

        #app-sidebar .nav-section-header:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.03);
        }

        #app-sidebar .nav-section-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            white-space: nowrap;
            transition: opacity var(--transition);
        }

        /* Icon mũi tên chỉ trạng thái đóng mở */
        #app-sidebar .section-chevron {
            font-size: 10px;
            transition: transform var(--transition);
        }

        /* Giao diện đóng danh mục menu */
        #app-sidebar .nav-section.collapsed .nav-section-content {
            max-height: 0 !important;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
        }

        #app-sidebar .nav-section.collapsed .section-chevron {
            transform: rotate(-90deg);
        }

        #app-sidebar .nav-section-content {
            transition: max-height var(--transition), opacity var(--transition);
            max-height: 500px; /* Đủ lớn để chứa danh sách con */
            opacity: 1;
        }

        /* Ẩn chữ và mũi tên khi Sidebar thu nhỏ */
        body.sidebar-collapsed #app-sidebar .nav-section-label,
        body.sidebar-collapsed #app-sidebar .section-chevron {
            opacity: 0;
            display: none;
        }
        
        body.sidebar-collapsed #app-sidebar .nav-section-header {
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 5px 0;
            justify-content: center;
        }

        /* ── ITEMS MENU ── */
        #app-sidebar .nav-item {
            position: relative;
            margin-bottom: 2px;
            display: block !important;
            padding: 0 !important;
            background: transparent !important;
            border: none !important;
        }

        #app-sidebar .nav-item a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            border-radius: 8px;
            color: var(--text-secondary) !important;
            font-size: 13.5px;
            font-weight: 500;
            transition: all var(--transition);
            white-space: nowrap;
        }

        #app-sidebar .nav-item a .nav-icon {
            width: 20px;
            text-align: center;
            font-size: 14px;
            flex-shrink: 0;
            opacity: .85;
            transition: transform var(--transition);
        }

        #app-sidebar .nav-item a span.nav-text {
            transition: opacity var(--transition);
            opacity: 1;
        }

        /* Ẩn Text của Item khi Sidebar thu gọn */
        body.sidebar-collapsed #app-sidebar .nav-item a span.nav-text,
        body.sidebar-collapsed #app-sidebar .nav-badge {
            opacity: 0;
            display: none;
        }

        body.sidebar-collapsed #app-sidebar .nav-item a {
            justify-content: center;
            padding: 12px 0;
        }

        /* [HOVER & ACTIVE EFFECTS ĐÚNG MÀU HOÀN MỸ] */
        #app-sidebar .nav-item a:hover {
            background: rgba(255,255,255,.07) !important;
            color: #ffffff !important;
        }
        
        #app-sidebar .nav-item a:hover .nav-icon {
            transform: scale(1.1);
        }

        #app-sidebar .nav-item.active a {
            background: var(--hm-teal) !important; /* Đổi màu nền active thành màu xanh ngọc Hoàn Mỹ */
            color: #ffffff !important;
            font-weight: 600;
        }

        #app-sidebar .nav-item.active a .nav-icon {
            opacity: 1;
        }

        #app-sidebar .nav-badge {
            margin-left: auto;
            background: var(--accent-red);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 12px;
            font-family: var(--font-mono);
        }

        /* ── MAIN CONTENT & TOPBAR ── */
        .page-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            width: calc(100vw - var(--sidebar-width));
            transition: width var(--transition);
        }

        body.sidebar-collapsed .page-wrapper {
            width: calc(100vw - var(--sidebar-collapsed-width));
        }

        .page-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            height: 60px;
            background: #ffffff;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        /* Nút thu tab nav */
        .btn-toggle-sidebar {
            background: none;
            border: none;
            font-size: 18px;
            color: var(--hm-navy);
            cursor: pointer;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .btn-toggle-sidebar:hover {
            background: #f1f5f9;
        }

        .topbar-title {
            font-size: 17px;
            font-weight: 700;
            color: var(--hm-navy);
        }

        .page-content {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
        }

        /* ── SHARED HELPERS ── */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-md);
            padding: 20px;
        }

        /* ── TOAST MOCKUP STYLE ── */
        #toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .toast-mockup {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            min-width: 320px;
            max-width: 400px;
            position: relative;
            animation: slideIn .3s ease;
            border-left: 4px solid #cbd5e1;
        }

        .toast-mockup-danger { border-left-color: var(--accent-red); }
        .toast-mockup-warning { border-left-color: var(--accent-amber); }
        .toast-mockup-info { border-left-color: var(--hm-teal); }

        .toast-mockup-icon-circle {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .toast-mockup-icon-circle.danger { background: rgba(229, 62, 62, 0.1); color: var(--accent-red); }
        .toast-mockup-icon-circle.warning { background: rgba(246, 173, 85, 0.1); color: var(--accent-amber); }
        .toast-mockup-icon-circle.info { background: rgba(0, 175, 169, 0.1); color: var(--hm-teal); }

        .toast-mockup-body { flex: 1; min-width: 0; padding-right: 16px; }
        .toast-mockup-title { font-size: 14px; font-weight: 700; color: #0f172a; margin-bottom: 4px; }
        .toast-mockup-msg { font-size: 12.5px; color: #475569; line-height: 1.5; }
        
        .toast-mockup-close {
            background: none; border: none; cursor: pointer; color: #94a3b8;
            position: absolute; top: 12px; right: 12px; font-size: 16px;
        }

        @@keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        /* ── RESPONSIVE CHO MOBILE ── */
        @@media (max-width: 768px) {
            #app-sidebar.sidebar {
                position: fixed;
                left: calc(-1 * var(--sidebar-width));
                height: 100vh;
                box-shadow: 5px 0 15px rgba(0,0,0,0.15);
            }

            body.sidebar-open #app-sidebar.sidebar {
                left: 0;
                width: var(--sidebar-width) !important;
                min-width: var(--sidebar-width) !important;
            }

            body.sidebar-open #app-sidebar .nav-section-label,
            body.sidebar-open #app-sidebar .section-chevron,
            body.sidebar-open #app-sidebar .nav-item a span.nav-text {
                display: block !important;
                opacity: 1 !important;
            }

            .page-wrapper {
                width: 100vw !important;
            }
        }
    </style>
    <script>
        var originalFetch = window.fetch;
        window.fetch = function () {
            var args = Array.prototype.slice.call(arguments);
            if (args[0] && typeof args[0] === 'string' && args[0].indexOf('/api/') !== -1) {
                if (!args[1]) args[1] = {};
                args[1].credentials = 'same-origin';
            }
            return originalFetch.apply(this, args);
        };
    </script>
</head>
<body>
    <div class="app-shell">

        <aside id="app-sidebar" class="sidebar">
            <div class="sidebar-brand">
                <div class="slidebar-logo">
                    <img src="@Url.Content("~/Content/images1/Logofull_bvhm.png")" alt="MedEquip Logo">
                </div>
            </div>

            <nav class="sidebar-nav">
                @if (HasModule("Analytics"))
                {
                    <div class="nav-section" id="sec-overview">
                        <div class="nav-section-header" onclick="toggleNavSection('sec-overview')">
                            <span class="nav-section-label">Tổng quan</span>
                            <i class="fa-solid fa-chevron-down section-chevron"></i>
                        </div>
                        <div class="nav-section-content">
                            <div class="nav-item @(ViewBag.ActiveNav == "Analytics" ? "active" : "")">
                                <a href="@Url.Action("Index","Analytics")">
                                    <i class="fa-solid fa-chart-pie nav-icon"></i>
                                    <span class="nav-text">Dashboard</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }

                @if (HasModule("Inventory") || HasModule("Catalog") || HasModule("Locations") || HasModule("QrCodes"))
                {
                    <div class="nav-section" id="sec-assets">
                        <div class="nav-section-header" onclick="toggleNavSection('sec-assets')">
                            <span class="nav-section-label">Tài sản & Kho</span>
                            <i class="fa-solid fa-chevron-down section-chevron"></i>
                        </div>
                        <div class="nav-section-content">
                            @if (HasModule("Inventory")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Inventory" ? "active" : "")">
                                    <a href="@Url.Action("Index","Inventory")">
                                        <i class="fa-solid fa-box-archive nav-icon"></i> <span class="nav-text">Tổng tài sản</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("Catalog")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Catalog" ? "active" : "")">
                                    <a href="@Url.Action("Category","Category")">
                                        <i class="fa-solid fa-layer-group nav-icon"></i> <span class="nav-text">Danh mục</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("Locations")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Locations" ? "active" : "")">
                                    <a href="@Url.Action("Location","Location")">
                                        <i class="fa-solid fa-map-pin nav-icon"></i> <span class="nav-text">Vị trí</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("QrCodes")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "QrCodes" ? "active" : "")">
                                    <a href="@Url.Action("Index","QrCodes")">
                                        <i class="fa-solid fa-qrcode nav-icon"></i> <span class="nav-text">QR Code</span>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (HasModule("Lifecycle") || HasModule("VongDoiKhauHao"))
                {
                    <div class="nav-section" id="sec-lifecycle">
                        <div class="nav-section-header" onclick="toggleNavSection('sec-lifecycle')">
                            <span class="nav-section-label">Vòng đời</span>
                            <i class="fa-solid fa-chevron-down section-chevron"></i>
                        </div>
                        <div class="nav-section-content">
                            @if (HasModule("Lifecycle")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Lifecycle" ? "active" : "")">
                                    <a href="@Url.Action("Index","Lifecycle")">
                                        <i class="fa-solid fa-rotate nav-icon"></i> <span class="nav-text">Trạng thái</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("VongDoiKhauHao")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "VongDoiKhauHao" ? "active" : "")">
                                    <a href="@Url.Action("VongDoiKhauHao", "VongDoiKhauHao")">
                                        <i class="fa-solid fa-recycle nav-icon"></i> <span class="nav-text">Vòng đời & Khấu hao</span>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (HasModule("Checklists") || HasModule("Maintenance"))
                {
                    <div class="nav-section" id="sec-maintenance">
                        <div class="nav-section-header" onclick="toggleNavSection('sec-maintenance')">
                            <span class="nav-section-label">Bảo trì</span>
                            <i class="fa-solid fa-chevron-down section-chevron"></i>
                        </div>
                        <div class="nav-section-content">
                            @if (HasModule("Checklists")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Checklists" ? "active" : "")">
                                    <a href="@Url.Action("Index","Checklists")">
                                        <i class="fa-solid fa-list-check nav-icon"></i> <span class="nav-text">Checklist</span>
                                    </a>
                                </div>
                            }
                            @if (HasModule("Maintenance")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Maintenance" ? "active" : "")">
                                    <a href="@Url.Action("Index","Maintenance")">
                                        <i class="fa-solid fa-screwdriver-wrench nav-icon"></i> <span class="nav-text">Sửa chữa</span>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (HasModule("CreateTicket") || HasModule("Alerts") || HasModule("Approvals"))
                {
                    <div class="nav-section" id="sec-operation">
                        <div class="nav-section-header" onclick="toggleNavSection('sec-operation')">
                            <span class="nav-section-label">Vận hành</span>
                            <i class="fa-solid fa-chevron-down section-chevron"></i>
                        </div>
                        <div class="nav-section-content">
                            @if (HasModule("Alerts")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Alerts" ? "active" : "")">
                                    <a href="@Url.Action("Index","Alerts")">
                                        <i class="fa-solid fa-bell nav-icon"></i> <span class="nav-text">Cảnh báo</span>
                                        @if (ViewBag.AlertCount != null && (int)ViewBag.AlertCount > 0) {
                                            <span class="nav-badge">@ViewBag.AlertCount</span>
                                        }
                                    </a>
                                </div>
                            }
                            @if (HasModule("Approvals")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "Approvals" ? "active" : "")">
                                    <a href="@Url.Action("Index","Approvals")">
                                        <i class="fa-solid fa-clipboard-check nav-icon"></i> <span class="nav-text">Phê duyệt</span>
                                        @if (ViewBag.PendingApprovals != null && (int)ViewBag.PendingApprovals > 0) {
                                            <span class="nav-badge">@ViewBag.PendingApprovals</span>
                                        }
                                    </a>
                                </div>
                            }
                            @if (HasModule("CreateTicket")) {
                                <div class="nav-item @(ViewBag.ActiveNav == "CreateTicket" ? "active" : "")">
                                    <a href="@Url.Action("Index", "CreateTicket")">
                                        <i class="fa-solid fa-file-circle-plus nav-icon"></i> <span class="nav-text">Tạo phiếu</span>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </nav>
        </aside>

        <div class="page-wrapper">
            <header class="page-topbar">
                <div class="topbar-left">
                    <button class="btn-toggle-sidebar" onclick="toggleSidebarLayout()" title="Thu gọn/Mở rộng Menu">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <span class="topbar-title">@(ViewBag.PageTitle ?? ViewBag.Title ?? "Dashboard")</span>
                </div>
                
                <div style="display: flex; align-items: center; gap: 20px;">
                    @RenderSection("topbar_actions", required: false)
                    
                    @if (HasModule("Alerts"))
                    {
                        <div id="notification-app" style="position: relative;">
                            <button v-on:click="toggleDropdown($event)" style="background: none; border: none; font-size: 18px; color: #64748b; cursor: pointer; position: relative;">
                                <i class="fa-solid fa-bell"></i>
                                <span v-if="unreadCount > 0" style="position: absolute; top: -5px; right: -5px; background: var(--accent-red); color: white; font-size: 9px; font-weight: 700; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid #fff;">{{ unreadCount }}</span>
                            </button>

                            <div v-if="isOpen" v-on:click.stop style="position: absolute; top: 120%; right: 0; width: 340px; background: #fff; border-radius: 12px; border: 1px solid var(--border); box-shadow: 0 10px 25px rgba(0,0,0,0.1); z-index: 1000; overflow: hidden;">
                                <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px; border-bottom: 1px solid var(--border); background: #f8fafc;">
                                    <span style="font-weight: 700; font-size: 14px; color: #1e2a3a;">Thông báo</span>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <label style="display:flex; align-items:center; cursor:pointer; font-size:12px; color:#64748b; font-weight:500;" title="Chặn hiển thị popup thông báo (Trừ thông báo khẩn)">
                                            <input type="checkbox" id="dnd-toggle-checkbox" style="margin-right:6px;" onchange="MedEquip.toggleDND(this.checked)"> Tắt Popup
                                        </label>
                                        <button v-on:click="markAllAsRead" style="background: none; border: none; color: var(--accent-blue); font-size: 12px; font-weight: 600; cursor: pointer;">Đọc tất cả</button>
                                    </div>
                                </div>
                                <div style="max-height: 300px; overflow-y: auto;">
                                    <div v-if="alerts.length === 0" style="padding: 30px; text-align: center; color: #94a3b8; font-size: 13px;">
                                        Không có thông báo mới.
                                    </div>
                                    <div v-else v-for="alert in alerts" :key="alert.Id" v-on:click="goToAlert(alert)" style="display: flex; gap: 12px; padding: 16px; border-bottom: 1px solid var(--border); cursor: pointer;" :style="isUnread(alert.Id) ? 'background: #f0f9ff;' : 'background: #fff;'">
                                        <div class="toast-mockup-icon-circle" :class="alert.Severity">
                                            <i class="fa-solid" :class="getIconClass(alert.Severity)"></i>
                                        </div>
                                        <div style="flex: 1;">
                                            <div style="font-size: 13px; font-weight: 700; color: #1e2a3a; margin-bottom: 4px;">{{ alert.Title }}</div>
                                            <div style="font-size: 12px; color: #64748b; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ alert.Body || (alert.ItemName + ' - Thiết bị gặp sự cố.') }}</div>
                                            <div style="font-size: 11px; color: #94a3b8; margin-top: 6px;">{{ alert.CreatedAtFriendly || alert.CreatedAtStr }}</div>
                                        </div>
                                    </div>
                                </div>
                                <div style="padding: 12px; text-align: center; border-top: 1px solid var(--border); background: #f8fafc;">
                                    <a href="/Alerts/Index" style="font-size: 13px; font-weight: 600; color: var(--hm-teal);">Xem tất cả thông báo</a>
                                </div>
                            </div>
                        </div>
                    }

                    @if (Session["FullName"] != null)
                    {
                        <div style="display: flex; align-items: center; gap: 10px; padding: 6px 14px; background: var(--body-bg); border-radius: 20px; font-size: 13px; border: 1px solid var(--border);">
                            <i class="fa-solid fa-circle-user" style="color: var(--hm-navy); font-size: 18px;"></i>
                            <span style="font-weight: 600; color: #1e2a3a;">@Session["FullName"]</span>
                            <a href="/Account/Logout" title="Đăng xuất" style="margin-left: 8px; color: var(--accent-red);"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
                        </div>
                    }
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="toast-container"></div>

    @Scripts.Render("~/bundles/bootstrap")

    <script>
        // Hàm thu gọn / mở rộng toàn bộ sidebar
        function toggleSidebarLayout() {
            if (window.innerWidth <= 768) {
                document.body.classList.toggle('sidebar-open');
                document.body.classList.remove('sidebar-collapsed');
            } else {
                document.body.classList.toggle('sidebar-collapsed');
                document.body.classList.remove('sidebar-open');
                
                // Lưu trạng thái cấu hình vào máy người dùng
                localStorage.setItem('sidebar_state', document.body.classList.contains('sidebar-collapsed') ? 'collapsed' : 'expanded');
            }
        }

        // Hàm Đóng/Mở từng mục header con (Accordion)
        function toggleNavSection(sectionId) {
            // Nếu sidebar đang bị thu nhỏ trên PC, click vào header không đóng mở mà giữ nguyên
            if (document.body.classList.contains('sidebar-collapsed') && window.innerWidth > 768) return;

            var element = document.getElementById(sectionId);
            if (element) {
                element.classList.toggle('collapsed');
                // Lưu trạng thái đóng mở của danh mục
                localStorage.setItem('section_state_' + sectionId, element.classList.contains('collapsed') ? 'collapsed' : 'expanded');
            }
        }

        // Tự động khôi phục cấu hình giao diện người dùng cũ đã lưu
        document.addEventListener("DOMContentLoaded", function() {
            // Khôi phục trạng thái thu gọn sidebar
            if (localStorage.getItem('sidebar_state') === 'collapsed' && window.innerWidth > 768) {
                document.body.classList.add('sidebar-collapsed');
            }

            // Khôi phục trạng thái đóng/mở của từng danh mục
            var sections = document.querySelectorAll('.nav-section');
            sections.forEach(function(sec) {
                var state = localStorage.getItem('section_state_' + sec.id);
                if (state === 'collapsed') {
                    sec.classList.add('collapsed');
                }
            });
        });
    </script>

    <script>
        window.getAlertRedirectUrl = function (alert) {
            if (!alert) return '/Alerts/Index';
            var code = alert.RuleCode || alert.ruleCode || '';
            var invId = alert.InventoryId || alert.inventoryId || 0;
            var assetCode = alert.AssetCode || alert.assetCode || '';
            if (code === 'MULTI_FAULT_3X') return '/Maintenance/Index?inventoryId=' + invId + '&triggerCreate=1';
            if (code === 'WARRANTY_EXPIRY_30D' || code === 'EXPIRY_SOON_60D' || code === 'DEPRECIATION_END_30D') return '/VongDoiKhauHao/VongDoiKhauHao?searchCode=' + assetCode + '&inventoryId=' + invId;
            if (code === 'CHECKLIST_OVERDUE' || code === 'CHECKLIST_DUE_3D') return '/Checklists/Index?inventoryId=' + invId;
            if (code === 'CONSUMABLES_LOW') return '/Inventory/Index?searchCode=' + assetCode + '&inventoryId=' + invId;
            return '/Alerts/Index';
        };

        window.isAlertRelevantToCurrentPage = function (alert) {
            if (!alert) return false;
            var path = window.location.pathname.toLowerCase();
            var code = alert.RuleCode || alert.ruleCode || '';
            if (path.indexOf('/alerts') !== -1) return false;
            if (path.indexOf('/inventory') !== -1) return code === 'CONSUMABLES_LOW';
            if (path.indexOf('/maintenance') !== -1) return code === 'MULTI_FAULT_3X';
            if (path.indexOf('/checklists') !== -1) return code === 'CHECKLIST_OVERDUE' || code === 'CHECKLIST_DUE_3D';
            if (path.indexOf('/vongdoikhauhao') !== -1) return code === 'WARRANTY_EXPIRY_30D' || code === 'EXPIRY_SOON_60D' || code === 'DEPRECIATION_END_30D';
            return false;
        };

        window.MedEquip = window.MedEquip || {};

        MedEquip.toggleDND = function (isDndEnabled) {
            localStorage.setItem('notificationsEnabled', !isDndEnabled);
        };

        MedEquip.toast = function (title, message, type, alertObj) {
            type = type || 'info';

            var notificationsEnabled = localStorage.getItem('notificationsEnabled');
            var isDndEnabled = notificationsEnabled === 'false';
            if (isDndEnabled && type !== 'danger') return;

            var id = 'toast-' + Date.now() + '-' + Math.floor(Math.random() * 10000);
            var redirectUrl = alertObj ? window.getAlertRedirectUrl(alertObj) : '';
            var onclickAttr = redirectUrl ? ' onclick="window.location.href=\'' + redirectUrl + '\';"' : '';
            var icon = type === 'danger' || type === 'warning' ? 'fa-bell' : 'fa-info';
            
            var html = '<div class="toast-mockup toast-mockup-' + type + '" id="' + id + '"' + onclickAttr + ' style="cursor: pointer;">'
                + '<div class="toast-mockup-icon-circle ' + type + '"><i class="fa-solid ' + icon + '"></i></div>'
                + '<div class="toast-mockup-body">'
                + '<div class="toast-mockup-title">' + title + '</div>'
                + '<div class="toast-mockup-msg">' + message + '</div>'
                + '</div>'
                + '<button class="toast-mockup-close" onclick="MedEquip.closeToast(\'' + id + '\'); event.stopPropagation();"><i class="fa-solid fa-xmark"></i></button></div>';

            document.getElementById('toast-container').insertAdjacentHTML('beforeend', html);
            setTimeout(function () { MedEquip.closeToast(id); }, 7000);
        };

        MedEquip.closeToast = function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.style.opacity = '0';
                el.style.transform = 'translateX(20px)';
                setTimeout(function () { el.remove(); }, 300);
            }
        };

        document.addEventListener("DOMContentLoaded", function() {
            var dndCheckbox = document.getElementById('dnd-toggle-checkbox');
            if (dndCheckbox && localStorage.getItem('notificationsEnabled') === 'false') {
                dndCheckbox.checked = true;
            }
        });

        (function () {
            var currentPath = window.location.pathname.toLowerCase();
            var segments = currentPath.split('/').filter(Boolean);
            var currentController = segments[0] || '';
            var currentAction = segments[1] || 'index';

            if (currentController) {
                document.querySelectorAll('.nav-item a').forEach(function (a) {
                    var hrefSegments = (a.getAttribute('href') || '').toLowerCase().split('/').filter(Boolean);
                    if ((hrefSegments[0] || '') === currentController && (hrefSegments[1] || 'index') === currentAction) {
                        document.querySelectorAll('.nav-item').forEach(function (li) { li.classList.remove('active'); });
                        var navItem = a.closest('.nav-item');
                        navItem.classList.add('active');
                        
                        // Tự động mở danh mục chứa Item đang active
                        var parentSection = navItem.closest('.nav-section');
                        if (parentSection) parentSection.classList.remove('collapsed');
                    }
                });
            }
        })();
    </script>

    @if (HasModule("Alerts"))
    {
        <script>
            $(document).ready(function () {
                var currentUserId = @(Session["UserId"] ?? 1);
                var seenKey = 'seen_alerts_' + currentUserId;
                var readKey = 'read_alerts_' + currentUserId;

                new Vue({
                    el: '#notification-app',
                    data: {
                        alerts: [],
                        seenAlerts: [],
                        readAlerts: [],
                        isOpen: false,
                        isFirstLoad: true
                    },
                    computed: {
                        unreadCount: function () {
                            var vm = this;
                            return vm.alerts.filter(function (a) { return vm.readAlerts.indexOf(a.Id) === -1; }).length;
                        }
                    },
                    methods: {
                        loadData: function () {
                            try { this.seenAlerts = JSON.parse(localStorage.getItem(seenKey)) || []; } catch(e) { this.seenAlerts = []; }
                            try { this.readAlerts = JSON.parse(localStorage.getItem(readKey)) || []; } catch(e) { this.readAlerts = []; }
                        },
                        saveData: function () {
                            if (this.seenAlerts.length > 200) this.seenAlerts = this.seenAlerts.slice(-200);
                            localStorage.setItem(seenKey, JSON.stringify(this.seenAlerts));
                            localStorage.setItem(readKey, JSON.stringify(this.readAlerts));
                        },
                        toggleDropdown: function (e) {
                            if(e) e.stopPropagation();
                            this.isOpen = !this.isOpen;
                            if (this.isOpen) this.markAllAsRead();
                        },
                        markAllAsRead: function () {
                            var vm = this, changed = false;
                            vm.alerts.forEach(function (a) {
                                if (vm.readAlerts.indexOf(a.Id) === -1) { vm.readAlerts.push(a.Id); changed = true; }
                            });
                            if (changed) vm.saveData();
                        },
                        isUnread: function (id) { return this.readAlerts.indexOf(id) === -1; },
                        getIconClass: function (sev) { return severity === 'danger' ? 'fa-triangle-exclamation' : sev === 'warning' ? 'fa-circle-exclamation' : 'fa-circle-info'; },
                        goToAlert: function (a) { window.location.href = window.getAlertRedirectUrl(a); },
                        checkAlerts: function () {
                            var vm = this;
                            $.ajax({
                                url: '/api/alerts/check-new', type: 'GET',
                                success: function (res) {
                                    vm.loadData();
                                    if (res && res.length > 0) {
                                        var hasNew = false;
                                        res.forEach(function (alert) {
                                            if (window.isAlertRelevantToCurrentPage(alert) && vm.seenAlerts.indexOf(alert.Id) === -1) {
                                                vm.seenAlerts.push(alert.Id); hasNew = true;
                                                if (!vm.isFirstLoad && window.MedEquip) {
                                                    var type = alert.Severity === 'danger' ? 'danger' : alert.Severity === 'warning' ? 'warning' : 'info';
                                                    window.MedEquip.toast(alert.Title, alert.Body || (alert.ItemName + ' - Thiết bị gặp sự cố.'), type, alert);
                                                }
                                            }
                                        });
                                        vm.isFirstLoad = false;
                                        if (hasNew) vm.saveData();
                                        vm.alerts = res;
                                    } else { vm.alerts = []; vm.isFirstLoad = false; }
                                }
                            });
                        }
                    },
                    mounted: function () {
                        var vm = this;
                        vm.loadData(); vm.checkAlerts();
                        document.addEventListener('click', function () { vm.isOpen = false; });
                        setInterval(vm.checkAlerts, 15000);
                    }
                });
            });
        </script>
    }
    @RenderSection("scripts", required: false)
</body>
</html>