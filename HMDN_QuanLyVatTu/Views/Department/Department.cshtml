@{
    ViewBag.Title = "Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/location/location.css" rel="stylesheet" />

<div id="app-dept">

    <div class="main-wrap">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-search">
                    <span class="search-icon">⌕</span>
                    <input type="text"
                           placeholder="Tìm khoa phòng..."
                           v-model="searchQuery">
                </div>
            </div>
            <div class="user-chip">Admin</div>
        </header>

        <!-- CONTENT -->
        <main class="page-content">

            <div class="page-header">
                <div>
                    <h2>Quản lý khoa phòng</h2>
                </div>
                <button class="btn-primary" v-on:click="openAdd">
                    ＋ Thêm khoa phòng
                </button>
            </div>

            <!-- STATS -->
            <div class="stats-strip">
                <div class="stat-card">
                    <div class="stat-icon blue">🏥</div>
                    <div>
                        <div class="stat-num">${ departments.length }</div>
                        <div class="stat-label">Tổng khoa phòng</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green">✅</div>
                    <div>
                        <div class="stat-num">${ activeDepartments }</div>
                        <div class="stat-label">Đang hoạt động</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon orange">📦</div>
                    <div>
                        <div class="stat-num">${ totalAssets }</div>
                        <div class="stat-label">Tổng tài sản</div>
                    </div>
                </div>
            </div>

            <!-- TABLE -->
            <div class="table-card">
                <table>
                    <thead>
                        <tr>
                            <th class="sortable" v-on:click="sortBy('Id')">
                                ID ${ sortIcon('Id') }
                            </th>
                            <th class="sortable" v-on:click="sortBy('Code')">
                                Mã ${ sortIcon('Code') }
                            </th>
                            <th class="sortable" v-on:click="sortBy('Name')">
                                Tên khoa phòng ${ sortIcon('Name') }
                            </th>
                            <th>Số tài sản</th>
                            <th>Trạng Thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr v-if="paginatedDepartments.length === 0">
                            <td colspan="6">
                                <div class="empty-state">
                                    <div class="empty-icon">📭</div>
                                    <p>Không tìm thấy khoa phòng nào</p>
                                </div>
                            </td>
                        </tr>

                        <tr v-for="item in paginatedDepartments"
                            :key="item.Id"
                            class="table-row"
                            v-on:click="openDetail(item)">

                            <td><span class="mono">#${ item.Id }</span></td>
                            <td>
                                <span class="badge badge-floor">${ item.Code }</span>
                            </td>
                            <td><strong>${ item.Name }</strong></td>
                            <td>${ item.AssetCount }</td>
                            <td>
                                <span :class="item.IsActive ? 'st-active' : 'st-inactive'">
                                    ${ item.IsActive ? 'Đang hoạt động' : 'Ngưng hoạt động' }
                                </span>
                            </td>
                            <td>
                                <div class="action-btns" v-on:click.stop>

                                    <button class="btn-icon"
                                            v-on:click="openEdit(item)"
                                            title="Sửa">
                                        ✏️
                                    </button>

                                    <button class="btn-icon lock"
                                            v-on:click="openToggleStatus(item)"
                                            :title="item.IsActive ? 'Ngưng sử dụng' : 'Kích hoạt'">
                                        ${ item.IsActive ? '🔒' : '🔓' }
                                    </button>

                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            <div class="pagination">
                <button v-on:click="prevPage" :disabled="currentPage == 1">← Prev</button>
                <button v-for="page in pages"
                        :key="page"
                        v-on:click="changePage(page)"
                        :class="{ active: currentPage == page }">
                    ${ page }
                </button>
                <button v-on:click="nextPage" :disabled="currentPage == totalPages">Next →</button>
            </div>

        </main>
    </div>

    <!-- ── MODAL THÊM / SỬA ── -->
    <div class="modal-overlay"
         v-if="showModal"
         v-on:click.self="showModal = false">

        <div class="loc-modal">

            <div class="modal-header">
                <div>
                    <h3>${ isEdit ? 'Chỉnh sửa khoa phòng' : 'Thêm khoa phòng mới' }</h3>
                    <div class="modal-subtitle" v-if="isEdit">#${ form.Id }</div>
                </div>
                <button class="close-btn" v-on:click="showModal = false">×</button>
            </div>

            <div class="modal-body">
                <div class="form-grid">

                    <div class="form-group">
                        <label>Mã khoa phòng *</label>
                        <input type="text"
                               placeholder="VD: KHOA-01"
                               v-model="form.Code">
                    </div>

                    <div class="form-group">
                        <label>Tên khoa phòng *</label>
                        <input type="text"
                               placeholder="VD: Khoa Nội tổng quát"
                               v-model="form.Name">
                    </div>

                    <div class="form-group full">
                        <label>Ghi chú</label>
                        <textarea placeholder="Mô tả thêm nếu cần..."
                                  v-model="form.Description"></textarea>
                    </div>

                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" v-on:click="showModal = false">Huỷ</button>
                <button class="btn-save" v-on:click="saveDepartment">
                    ${ isEdit ? '💾 Lưu thay đổi' : '＋ Thêm khoa phòng' }
                </button>
            </div>

        </div>
    </div>

    <!-- ── MODAL TOGGLE STATUS ── -->
    <div class="modal-overlay"
         v-if="showStatusModal"
         v-on:click.self="showStatusModal = false">

        <div class="confirm-modal">

            <div class="confirm-body">

                <div class="confirm-icon">
                    ${ statusTarget?.IsActive ? '🔒' : '🔓' }
                </div>

                <h3>
                    ${ statusTarget?.IsActive
                    ? 'Ngưng sử dụng khoa phòng'
                    : 'Kích hoạt khoa phòng'
                    }
                </h3>

                <p>
                    Bạn có chắc muốn
                    <strong>
                        ${ statusTarget?.IsActive
                        ? 'ngưng sử dụng'
                        : 'kích hoạt lại'
                        }
                    </strong>
                    khoa phòng
                    <strong>
                        ${ statusTarget?.Name }
                    </strong>
                    không?
                </p>

            </div>

            <div class="confirm-footer">

                <button class="btn-cancel"
                        v-on:click="showStatusModal = false">
                    Huỷ
                </button>

                <button class="btn-danger"
                        v-on:click="confirmToggleStatus">
                    ${ statusTarget?.IsActive
                    ? '🔒 Ngưng sử dụng'
                    : '🔓 Kích hoạt'
                    }
                </button>

            </div>

        </div>

    </div>

    <!-- DETAIL MODAL -->
    <div class="modal-overlay"
         v-if="showDetailModal"
         v-on:click.self="showDetailModal = false">

        <div class="detail-modal">

            <div class="modal-header">

                <div>
                    <h3>${ departmentDetail?.Name }</h3>
                    <div class="modal-subtitle">${ departmentDetail?.Code }</div>
                </div>

                <button class="close-btn"
                        v-on:click="showDetailModal = false">
                    ×
                </button>

            </div>

            <div class="modal-body">

                <h4>Tài sản thuộc ${ departmentDetail?.Name }</h4>

                <table class="asset-table">

                    <thead>
                        <tr>
                            <th>Asset Code</th>
                            <th>Tài sản</th>
                            <th>Nhóm</th>
                            <th>Brand</th>
                            <th>Model</th>
                            <th>SL</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr v-if="departmentInventories.length == 0">
                            <td colspan="7">Không có tài sản</td>
                        </tr>

                        @*<tr v-for="inv in departmentInventories"
                :key="inv.InventoryId">*@
                        <tr v-for="inv in paginatedInventories"
                            :key="inv.InventoryId">

                            <td>${ inv.AssetCode }</td>
                            <td><strong>${ inv.ItemName }</strong></td>
                            <td>${ inv.GroupName }</td>
                            <td>${ inv.Brand || '—' }</td>
                            <td>${ inv.Model || '—' }</td>
                            <td>${ inv.Quantity }</td>
                            <td>${ inv.LifeStatus }</td>

                        </tr>

                    </tbody>

                </table>

                <div class="pagination"
                     v-if="departmentInventories.length > invPageSize">

                    <button v-on:click="invPrevPage" :disabled="invPage == 1">← Prev</button>
                    <button v-for="page in invPages"
                            :key="page"
                            v-on:click="invChangePage(page)"
                            :class="{ active: invPage == page }">
                        ${ page }
                    </button>
                    <button v-on:click="invNextPage" :disabled="invPage == invTotalPages">Next →</button>
                </div>

            </div>

        </div>

    </div>

    <!-- ── TOAST ── -->
    <div class="toast" :class="toast.type" v-if="toast.show">
        ${ toast.msg }
    </div>

</div>
<script src="~/Scripts/app/department.js"></script>